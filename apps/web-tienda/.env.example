# Tienda Next.js — apunta a la API GaesSoft y al tenant de la tienda
API_URL=http://localhost:3000
TIENDA_TENANT_SLUG=tienda-demo
TIENDA_USER_EMAIL=tienda@demo.mx
TIENDA_USER_PASSWORD=Tienda!2026

# Conekta — llave PÚBLICA para tokenizar la tarjeta en el navegador (Conekta.js).
# Con esto, el checkout muestra el formulario de tarjeta real con MSI; sin esto,
# usa el flujo demo (mock). La llave PRIVADA va en la API (CONEKTA_API_KEY).
# NEXT_PUBLIC_CONEKTA_PUBLIC_KEY="key_test_public_xxxxxxxx"
