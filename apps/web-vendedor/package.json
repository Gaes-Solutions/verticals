{
  "name": "@gaespos/web-vendedor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "PWA de campo del vendedor mayorista: ruta de visitas del día, CRM ligero del cliente, pedidos con firma (offline-first) y comisiones gamificadas. SPA Vite+React conectada a la API GaesSoft.",
  "scripts": {
    "dev": "vite --port 5179",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 5179",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@gaespos/ui": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
