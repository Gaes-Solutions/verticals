{
  "name": "@gaespos/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "demo:retail": "tsx scripts/demo-cajero-retail.ts",
    "demo:comercial": "tsx scripts/demo-comercial.ts",
    "demo:clinica-vet": "tsx scripts/demo-clinica-vet.ts",
    "demo:abarrotes": "tsx scripts/demo-abarrotes.ts",
    "demo:despacho": "dotenv -e ../../.env -- tsx scripts/demo-despacho.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.4",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/sensible": "^6.0.3",
    "@gaespos/ai": "workspace:*",
    "@gaespos/db": "workspace:*",
    "@gaespos/email": "workspace:*",
    "@gaespos/fiscal": "workspace:*",
    "@gaespos/pagos": "workspace:*",
    "@gaespos/permissions": "workspace:*",
    "@gaespos/pricing": "workspace:*",
    "@gaespos/recargas": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "decimal.js": "^10.4.3",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
