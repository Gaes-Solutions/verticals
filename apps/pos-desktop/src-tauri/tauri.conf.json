{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GaesSoft POS",
  "version": "0.1.0",
  "identifier": "mx.gaessoft.pos",
  "build": {
    "frontendDist": "../../web-pos/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @gaespos/web-pos dev",
    "beforeBuildCommand": "pnpm --filter @gaespos/web-pos build"
  },
  "app": {
    "windows": [
      {
        "title": "GaesSoft POS",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.gaessoft.com http://localhost:3000; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "deb", "appimage"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"],
    "windows": {
      "wix": { "language": ["es-MX"] },
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": null,
      "entitlements": null
    },
    "linux": {
      "deb": { "depends": [] }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:gaespos-local.db"]
    },
    "updater": {
      "active": false
    }
  }
}
