{
  "name": "@gaespos/pos-desktop",
  "version": "0.0.0",
  "private": true,
  "description": "Shell Tauri del POS de escritorio (Windows/macOS/Linux). Empaqueta el web-pos con SQLite local + @gaespos/sync-client para operar offline-first.",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build",
    "build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "build:macos": "tauri build --target universal-apple-darwin",
    "build:linux": "tauri build --target x86_64-unknown-linux-gnu"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0"
  },
  "dependencies": {
    "@gaespos/sync-client": "workspace:*"
  }
}
