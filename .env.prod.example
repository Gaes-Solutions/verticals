# Plantilla de variables productivas — copiar a .env.prod y rellenar con secrets reales.
# NUNCA commitear .env.prod al repo. Coolify guarda estas variables en su panel UI.

# Postgres
POSTGRES_USER=gaespos
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_32_CHARS
POSTGRES_DB=gaespos_master

# Redis
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_32_CHARS

# API secrets — generar con: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_32_PLUS_CHARS_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_32_PLUS_CHARS_HEX_DIFFERENT
COOKIE_SECRET=REPLACE_WITH_32_PLUS_CHARS_HEX_DIFFERENT

ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30

# CORS — dominio del frontend (no incluir trailing slash)
CORS_ORIGIN=https://app.gaespos.mx

# Rate limit
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute

# Admin seed inicial (cambiar password tras el primer login)
SEED_ADMIN_EMAIL=admin@gaessoft.local
SEED_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Imagen Docker (la pone Coolify automáticamente cuando GitHub Actions hace push a GHCR)
GITHUB_REPOSITORY=gaes-solutions/gaespos
API_TAG=latest

# Puerto local (Coolify pone su reverse proxy enfrente; default 3000)
API_PORT=3000

LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# PROVEEDORES REALES (go-live). En Railway: pegar en Variables del servicio "api".
# Si una llave queda vacía, ese proveedor cae a su mock (no cobra/envía de verdad).
# ─────────────────────────────────────────────────────────────────────────────

# Pagos — Conekta (MX: tarjeta, OXXO, SPEI). Llave secreta + secret de webhook.
CONEKTA_API_KEY=
CONEKTA_WEBHOOK_SECRET=
# Llave PÚBLICA de Conekta para la tienda (web-tienda, tokeniza la tarjeta en el navegador).
NEXT_PUBLIC_CONEKTA_PUBLIC_KEY=

# Pagos — Stripe (tarjeta internacional). Llave secreta + secret de webhook.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# CFDI / Facturama: la llave es POR NEGOCIO (cada tenant la captura en su panel).
# Dejar FISCAL_PROVIDER SIN definir en prod = usa FacturamaClient real.
# FISCAL_PROVIDER=mock   # <- solo dev/staging

# Email — Resend. Una llave global + remitente (dominio verificado en Resend).
RESEND_API_KEY=
EMAIL_REMITENTE=no-reply@gaespos.mx

# WhatsApp Cloud (Meta). Token permanente + ID del número aprobado.
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=

# SMS — Twilio (opcional, fallback de WhatsApp).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Paqueterías — Skydropx y/o Envía (guías automáticas de la tienda).
SKYDROPX_API_KEY=
SKYDROPX_WEBHOOK_SECRET=
ENVIA_API_KEY=
ENVIA_WEBHOOK_SECRET=

# Push web (VAPID) — generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soporte@gaespos.mx

# Automatizaciones (flows): scheduler en proceso. En prod: true.
FLOWS_SCHEDULER_ENABLED=true
FLOWS_RUN_INTERVAL_MIN=360

# Recordatorios de citas (anti-no-show): scheduler en proceso. En prod: true.
# PUBLIC_BASE_URL = dominio público del API (base del link de confirmación).
RECORDATORIOS_SCHEDULER_ENABLED=true
RECORDATORIOS_RUN_INTERVAL_MIN=60
PUBLIC_BASE_URL=https://api.tudominio.com

# Observabilidad (opcional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
