{
  "name": "@gaespos/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./master-client": "./src/generated/master/index.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "prisma:generate": "prisma generate --schema=./prisma/master.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/master.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=./prisma/master.prisma",
    "prisma:studio": "prisma studio --schema=./prisma/master.prisma",
    "prisma:reset": "prisma migrate reset --schema=./prisma/master.prisma --force",
    "seed:master": "tsx src/seed-master.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2"
  }
}
