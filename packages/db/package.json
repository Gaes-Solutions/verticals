{
  "name": "@gaespos/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./master-client": "./src/generated/master/index.js",
    "./tenant-client": "./src/generated/tenant/index.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "prisma:generate": "prisma generate --schema=./prisma/master/schema.prisma && prisma generate --schema=./prisma/tenant/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/master/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=./prisma/master/schema.prisma",
    "prisma:studio": "prisma studio --schema=./prisma/master/schema.prisma",
    "prisma:reset": "prisma migrate reset --schema=./prisma/master/schema.prisma --force",
    "seed:master": "tsx src/seed-master.ts",
    "migrate": "tsx src/cli/migrate.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.6.0",
    "commander": "^13.0.0",
    "execa": "^9.5.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "prisma": "^6.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
