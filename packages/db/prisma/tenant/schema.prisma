model ProductoResena {
  id                  String       @id @default(cuid())
  productoPublicadoId String       @map("producto_publicado_id")
  pedidoId            String       @map("pedido_id")
  clienteId           String?      @map("cliente_id")
  rating              Int
  titulo              String?
  comentario          String?
  imagenesArray       Json         @default("[]") @map("imagenes_array")
  videoUrl            String?      @map("video_url")
  estado              ResenaEstado @default(pendiente)
  moderacionIaNota    String?      @map("moderacion_ia_nota")
  verificadaPorCompra Boolean      @default(true) @map("verificada_por_compra")
