  siguienteControlDias        Int?               @map("siguiente_control_dias")
  notasClinicasInternas       String?            @map("notas_clinicas_internas")
  resumenParaTutor            String?            @map("resumen_para_tutor")
  estado                      ConsultaEstado     @default(borrador)
  firmadaAt                   DateTime?          @map("firmada_at")
  firmadaPorMedicoUsuarioId   String?            @map("firmada_por_medico_usuario_id")
  firmaElectronicaAplicadaUrl String?            @map("firma_electronica_aplicada_url")
  consultaOriginalId          String?            @map("consulta_original_id")
  enmiendaMotivo              String?            @map("enmienda_motivo")
  canceladaAt                 DateTime?          @map("cancelada_at")
  canceladaMotivo             String?            @map("cancelada_motivo")
  createdAt                   DateTime           @default(now()) @map("created_at")
  updatedAt                   DateTime           @updatedAt @map("updated_at")

  cita                   Cita?                @relation(fields: [citaId], references: [id], onDelete: SetNull)
  paciente               Paciente?            @relation(fields: [pacienteId], references: [id], onDelete: Restrict)
  mascota                Mascota?             @relation(fields: [mascotaId], references: [id], onDelete: Restrict)
  medico                 Usuario              @relation("ConsultaMedico", fields: [medicoUsuarioId], references: [id], onDelete: Restrict)
  enfermeraAsistente     Usuario?             @relation("ConsultaEnfermeraAsistente", fields: [enfermeraAsistenteId], references: [id], onDelete: SetNull)
  sucursal               Sucursal             @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  diagnosticoPrincipal   DiagnosticoCatalogo? @relation("ConsultaDiagnosticoPrincipal", fields: [diagnosticoPrincipalId], references: [id], onDelete: SetNull)
  firmadaPor             Usuario?             @relation("ConsultaFirmadaPor", fields: [firmadaPorMedicoUsuarioId], references: [id], onDelete: SetNull)
  consultaOriginal       Consulta?            @relation("ConsultaEnmiendas", fields: [consultaOriginalId], references: [id], onDelete: SetNull)
  enmiendas              Consulta[]           @relation("ConsultaEnmiendas")
  signosVitalesHistorial ConsultaSignoVital[]
  recetas                Receta[]

  @@index([pacienteId, fechaConsulta])
  @@index([mascotaId, fechaConsulta])
  @@index([medicoUsuarioId, fechaConsulta])
  @@index([estado])
  @@map("consultas")
}

