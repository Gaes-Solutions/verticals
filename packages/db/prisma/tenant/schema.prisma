enum CarritoCanal {
  web
  mobile
  whatsapp
}

enum CarritoEstado {
  activo
  abandonado
  convertido
  expirado
}

enum PedidoEcommerceEstadoPago {
  pendiente
  pago_confirmado
  pago_fallido
  reembolsado
}

enum PedidoEcommerceEstado {
  recibido
  pago_confirmado
  preparando
  listo_pickup
  enviado
  en_camino
  entregado
  recogido
  cancelado
}

enum PedidoEcommerceMetodoEnvio {
  paqueteria
  click_collect
  envio_local
}

enum TarifaEnvioTipoCalculo {
  fija
  por_peso
  por_monto
}

enum EnvioPaqueteria {
