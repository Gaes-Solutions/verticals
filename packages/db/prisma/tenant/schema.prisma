  bio                       String?
  fotoPerfilUrl             String?  @map("foto_perfil_url")
  consultorios              Json     @default("[]")
  precioConsultaPrimera     Decimal? @map("precio_consulta_primera") @db.Decimal(14, 2)
  precioConsultaSeguimiento Decimal? @map("precio_consulta_seguimiento") @db.Decimal(14, 2)
  aceptaSeguros             Json     @default("[]") @map("acepta_seguros")
