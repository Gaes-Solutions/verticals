  mostrarRatingProducto          Boolean    @default(true) @map("mostrar_rating_producto")
  cuponEnCheckout                Boolean    @default(true) @map("cupon_en_checkout")
  comprarAhora                   Boolean    @default(true) @map("comprar_ahora")
  cancelacionCliente             Boolean    @default(true) @map("cancelacion_cliente")
  facturacionSelfService         Boolean    @default(true) @map("facturacion_self_service")
  preguntasPublicas              Boolean    @default(true) @map("preguntas_publicas")
  createdAt                      DateTime   @default(now()) @map("created_at")
