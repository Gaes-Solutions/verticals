// Plantilla del schema de cada tenant.
// Cada tenant tiene su propio schema postgres con copia de estos modelos.
// El cliente Prisma de tenant aplica `SET search_path TO tenant_<slug>` por request.
// Ver ADR-001 y docs/analisis/04-modelo-datos/ (4.6+)
//
// Roadmap por hito:
//   - Hito 1.1 (este archivo): usuarios, roles, sucursales, cajas, vistas guardadas
//   - Hito 1.2: productos, variantes, inventario, motor precios
//   - Hito 1.3: ventas básicas, multi-pago, tickets
//   - Hito 1.4: cortes X/Z + caja_aperturas/movimientos
//   - Hito 1.5: cfdis
//   - Hito 2+: clientes, apartados, CxC, cotizaciones, promociones
//   - Hito 3+: módulos verticales (abarrotes, salud, etc.)

generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/tenant"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_TENANT")
}

// ============================================================
// 4.6 — Usuarios, roles, sucursales, cajas, vistas guardadas
// ============================================================

enum SucursalTipo {
  tienda_fisica
  bodega
  consultorio
  kiosko
  oficina
}

enum CajaTipo {
  fija
  movil_tablet
  movil_celular
}

enum UsuarioTipo {
  empleado
  vendedor_externo
  medico
  enfermera
  recepcion
  almacen
  contador_interno
}

model Sucursal {
  id                String       @id @default(cuid())
  codigo            String       @unique
  nombre            String
  direccion         Json?
  telefono          String?
  emailContacto     String?      @map("email_contacto")
  horario           Json?
  tipo              SucursalTipo @default(tienda_fisica)
  verticalPrincipal String?      @map("vertical_principal")
  isVisiblePublico  Boolean      @default(false) @map("is_visible_publico")
  isDefault         Boolean      @default(false) @map("is_default")
  isActive          Boolean      @default(true) @map("is_active")
  archivedAt        DateTime?    @map("archived_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  cajas              Caja[]
  usuarioSucursales  UsuarioSucursal[]
  usuariosLastLogin  Usuario[]              @relation("UsuarioLastLoginSucursal")
  inventarioSucursal InventarioSucursal[]
  movimientos        InventarioMovimiento[]
  movimientosOrigen  InventarioMovimiento[] @relation("MovimientoSucursalOrigen")
  lotes              ProductoLote[]
  series             ProductoSerie[]
  ventas             Venta[]
  ventaFolioCounter  VentaFolioCounter?

  @@index([isActive])
  @@map("sucursales")
}

model Caja {
  id                  String   @id @default(cuid())
  sucursalId          String   @map("sucursal_id")
  codigo              String
  nombre              String
  tipo                CajaTipo @default(fija)
  impresoraDefault    String?  @map("impresora_default")
  lectorBarrasDefault String?  @map("lector_barras_default")
  balanzaDefault      String?  @map("balanza_default")
  terminalPagoDefault String?  @map("terminal_pago_default")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  sucursal  Sucursal       @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  ventas    Venta[]
  aperturas CajaApertura[]

  @@unique([sucursalId, codigo])
  @@index([sucursalId, isActive])
  @@map("cajas")
}

model Usuario {
  id                  String      @id @default(cuid())
  email               String      @unique
  passwordHash        String      @map("password_hash")
  pinHash             String?     @map("pin_hash")
  codigoEscaneo       String?     @unique @map("codigo_escaneo")
  qrCodeUrl           String?     @map("qr_code_url")
  fotoUrl             String?     @map("foto_url")
  nombre              String
  apellidos           String?
  telefono            String?
  mfaEnabled          Boolean     @default(false) @map("mfa_enabled")
  mfaSecret           String?     @map("mfa_secret")
  tipoUsuario         UsuarioTipo @default(empleado) @map("tipo_usuario")
  languagePreferred   String      @default("es-MX") @map("language_preferred")
  isActive            Boolean     @default(true) @map("is_active")
  lastLoginAt         DateTime?   @map("last_login_at")
  lastLoginSucursalId String?     @map("last_login_sucursal_id")
  terminatedAt        DateTime?   @map("terminated_at")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  lastLoginSucursal    Sucursal?                    @relation("UsuarioLastLoginSucursal", fields: [lastLoginSucursalId], references: [id], onDelete: SetNull)
  sucursales           UsuarioSucursal[]
  roles                UsuarioRol[]                 @relation("UsuarioRol_Usuario")
  rolesAsignados       UsuarioRol[]                 @relation("UsuarioRol_AsignadoPor")
  vistasGuardadas      UsuarioVistaGuardada[]
  movimientos          InventarioMovimiento[]
  ventasCreadas        Venta[]                      @relation("VentaUsuarioCreador")
  ventasCanceladas     Venta[]                      @relation("VentaUsuarioCancelador")
  aperturasAbiertas    CajaApertura[]               @relation("CajaAperturaUsuario")
  aperturasCerradas    CajaApertura[]               @relation("CajaAperturaCerradaPor")
  cajaMovimientos      CajaMovimiento[]
  cortes               Corte[]
  cfdisEmitidos        Cfdi[]                       @relation("CfdiEmitidoPor")
  cfdisCancelados      Cfdi[]                       @relation("CfdiCanceladoPor")
  clientesAsignados    Cliente[]                    @relation("ClienteVendedorAsignado")
  clientesB2bAsignados ClienteB2bVendedorAsignado[]
  fiadoMovimientos     FiadoMovimiento[]
  creditosB2bAprobados ClienteB2bCredito[]          @relation("ClienteB2bCreditoAprobadoPor")

  @@index([isActive])
  @@index([tipoUsuario])
  @@map("usuarios")
}

model UsuarioSucursal {
  usuarioId  String   @map("usuario_id")
  sucursalId String   @map("sucursal_id")
  isPrimary  Boolean  @default(false) @map("is_primary")
  assignedAt DateTime @default(now()) @map("assigned_at")

  usuario  Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  sucursal Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@id([usuarioId, sucursalId])
  @@index([sucursalId])
  @@map("usuario_sucursales")
}

model Rol {
  id          String   @id @default(cuid())
  codigo      String   @unique
  nombre      String
  descripcion String?
  isPreset    Boolean  @default(false) @map("is_preset")
  isActive    Boolean  @default(true) @map("is_active")
  permisos    Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  usuarios UsuarioRol[]

  @@index([isActive])
  @@map("roles")
}

model UsuarioRol {
  usuarioId        String   @map("usuario_id")
  rolId            String   @map("rol_id")
  assignedAt       DateTime @default(now()) @map("assigned_at")
  assignedByUserId String?  @map("assigned_by_user_id")

  usuario        Usuario  @relation("UsuarioRol_Usuario", fields: [usuarioId], references: [id], onDelete: Cascade)
  rol            Rol      @relation(fields: [rolId], references: [id], onDelete: Restrict)
  assignedByUser Usuario? @relation("UsuarioRol_AsignadoPor", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@id([usuarioId, rolId])
  @@index([rolId])
  @@map("usuario_roles")
}

model UsuarioVistaGuardada {
  id               String   @id @default(cuid())
  usuarioId        String   @map("usuario_id")
  recurso          String
  nombre           String
  filtros          Json     @default("{}")
  ordenamiento     Json     @default("{}")
  columnasVisibles Json     @default("[]") @map("columnas_visibles")
  isDefault        Boolean  @default(false) @map("is_default")
  esCompartida     Boolean  @default(false) @map("es_compartida")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, recurso])
  @@map("usuario_vistas_guardadas")
}

// ============================================================
// 4.7 — Productos, variantes, inventario, lotes, series, precios
// pgvector + particionamiento mensual de movimientos diferidos a V1.5
// ============================================================

enum TipoVenta {
  unidad
  peso
  volumen
  tiempo
  servicio
}

enum UnidadMedida {
  pza
  kg
  g
  lt
  ml
  m
  m2
  hora
  servicio
}

enum CodigoBarrasTipo {
  ean13
  upc
  corto_interno
  qr
}

enum ProductoImagenTipo {
  principal
  lifestyle
  detalle
  lateral
  back
}

enum InventarioMovimientoTipo {
  compra
  venta
  devolucion_cliente
  devolucion_proveedor
  ajuste_positivo
  ajuste_negativo
  transferencia_salida
  transferencia_entrada
  merma
  apartado_reservado
  apartado_liberado
  consumo_interno
}

enum SerieEstado {
  disponible
  vendido
  devuelto
  garantia
  reparacion
}

enum ListaPrecioTipo {
  publico
  mayoreo_nivel
  cliente_individual
}

enum ReglaPrecioTipo {
  descuento_global_por_monto
  descuento_producto
  descuento_categoria
  descuento_cliente
  bogo_compra_x_lleva_y
  precio_temporada
  mayoreo_por_total_ticket
}

enum ReglaPrecioCanal {
  pos_fisico
  ecommerce
  b2b
  todos
}

enum CuponTipo {
  monto_fijo
  porcentaje
  envio_gratis
  producto_gratis
}

model Categoria {
  id                String   @id @default(cuid())
  parentId          String?  @map("parent_id")
  nombre            String
  slug              String   @unique
  descripcion       String?
  imagenUrl         String?  @map("imagen_url")
  icono             String?
  color             String?
  orden             Int      @default(0)
  verticalAplicable String?  @map("vertical_aplicable")
  isVisiblePos      Boolean  @default(true) @map("is_visible_pos")
  isVisiblePublico  Boolean  @default(true) @map("is_visible_publico")
  isActive          Boolean  @default(true) @map("is_active")
  metadata          Json?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  parent                Categoria?             @relation("CategoriaTree", fields: [parentId], references: [id], onDelete: Restrict)
  children              Categoria[]            @relation("CategoriaTree")
  productos             Producto[]
  reglasPrecioCategoria ReglaPrecioCategoria[]

  @@index([parentId])
  @@index([isActive])
  @@map("categorias")
}

model Marca {
  id          String   @id @default(cuid())
  nombre      String
  slug        String   @unique
  descripcion String?
  logoUrl     String?  @map("logo_url")
  paisOrigen  String?  @map("pais_origen")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  productos Producto[]

  @@map("marcas")
}

model Producto {
  id                 String       @id @default(cuid())
  skuPadre           String       @unique @map("sku_padre")
  nombre             String
  descripcionCorta   String?      @map("descripcion_corta")
  descripcionLarga   String?      @map("descripcion_larga")
  categoriaId        String?      @map("categoria_id")
  marcaId            String?      @map("marca_id")
  tipoVenta          TipoVenta    @default(unidad) @map("tipo_venta")
  unidadMedida       UnidadMedida @default(pza) @map("unidad_medida")
  unidadMedidaCompra UnidadMedida @default(pza) @map("unidad_medida_compra")
  factorCompraAVenta Decimal      @default(1) @map("factor_compra_a_venta") @db.Decimal(18, 6)
  tieneVariantes     Boolean      @default(false) @map("tiene_variantes")
  requiresRecipe     Boolean      @default(false) @map("requires_recipe")
  claveSat           String?      @map("clave_sat")
  claveUnidadSat     String?      @map("clave_unidad_sat")
  aplicaIva          Boolean      @default(true) @map("aplica_iva")
  tasaIva            Decimal      @default(16) @map("tasa_iva") @db.Decimal(5, 2)
  aplicaIeps         Boolean      @default(false) @map("aplica_ieps")
  tasaIeps           Json?        @map("tasa_ieps")
  permiteDescuento   Boolean      @default(true) @map("permite_descuento")
  permiteFiado       Boolean      @default(true) @map("permite_fiado")
  permiteApartado    Boolean      @default(true) @map("permite_apartado")
  permiteDevolucion  Boolean      @default(true) @map("permite_devolucion")
  diasDevolucion     Int          @default(15) @map("dias_devolucion")
  diasGarantia       Int          @default(0) @map("dias_garantia")
  requiresLote       Boolean      @default(false) @map("requires_lote")
  requiresSerie      Boolean      @default(false) @map("requires_serie")
  requiresBalanza    Boolean      @default(false) @map("requires_balanza")
  pesoKg             Decimal?     @map("peso_kg") @db.Decimal(10, 3)
  dimensiones        Json?
  isActive           Boolean      @default(true) @map("is_active")
  isVisiblePublico   Boolean      @default(true) @map("is_visible_publico")
  isVisibleB2b       Boolean      @default(true) @map("is_visible_b2b")
  archivedAt         DateTime?    @map("archived_at")
  metadata           Json?
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  categoria            Categoria?            @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  marca                Marca?                @relation(fields: [marcaId], references: [id], onDelete: SetNull)
  variantes            ProductoVariante[]
  imagenes             ProductoImagen[]
  atributos            ProductoAtributo[]
  tags                 ProductoTag[]
  reglasPrecioProducto ReglaPrecioProducto[]

  @@index([categoriaId])
  @@index([marcaId])
  @@index([isActive])
  @@map("productos")
}

model ProductoVariante {
  id             String    @id @default(cuid())
  productoId     String    @map("producto_id")
  sku            String    @unique
  nombreVariante String?   @map("nombre_variante")
  opciones       Json      @default("{}")
  precioBase     Decimal   @map("precio_base") @db.Decimal(14, 4)
  costoPromedio  Decimal   @default(0) @map("costo_promedio") @db.Decimal(14, 4)
  costoUltimo    Decimal   @default(0) @map("costo_ultimo") @db.Decimal(14, 4)
  pesoKg         Decimal?  @map("peso_kg") @db.Decimal(10, 3)
  imagenUrl      String?   @map("imagen_url")
  isDefault      Boolean   @default(false) @map("is_default")
  isActive       Boolean   @default(true) @map("is_active")
  archivedAt     DateTime? @map("archived_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  producto           Producto                   @relation(fields: [productoId], references: [id], onDelete: Cascade)
  codigosBarras      ProductoCodigoBarras[]
  imagenes           ProductoImagen[]
  inventario         InventarioSucursal[]
  movimientos        InventarioMovimiento[]
  lotes              ProductoLote[]
  series             ProductoSerie[]
  listaItems         ListaPrecioItem[]
  preciosEscalonados ProductoPrecioEscalonado[]

  @@index([productoId])
  @@index([isActive])
  @@map("producto_variantes")
}

model ProductoCodigoBarras {
  id         String           @id @default(cuid())
  varianteId String           @map("variante_id")
  codigo     String           @unique
  tipo       CodigoBarrasTipo @default(ean13)
  isPrimary  Boolean          @default(false) @map("is_primary")
  createdAt  DateTime         @default(now()) @map("created_at")

  variante ProductoVariante @relation(fields: [varianteId], references: [id], onDelete: Cascade)

  @@index([varianteId])
  @@map("producto_codigos_barras")
}

model ProductoImagen {
  id         String             @id @default(cuid())
  productoId String?            @map("producto_id")
  varianteId String?            @map("variante_id")
  s3Key      String?            @map("s3_key")
  cdnUrl     String             @map("cdn_url")
  orden      Int                @default(0)
  tipo       ProductoImagenTipo @default(principal)
  altText    String?            @map("alt_text")
  metadata   Json?
  createdAt  DateTime           @default(now()) @map("created_at")

  producto Producto?         @relation(fields: [productoId], references: [id], onDelete: Cascade)
  variante ProductoVariante? @relation(fields: [varianteId], references: [id], onDelete: Cascade)

  @@index([productoId])
  @@index([varianteId])
  @@map("producto_imagenes")
}

model ProductoAtributo {
  id         String   @id @default(cuid())
  productoId String   @map("producto_id")
  clave      String
  valor      String
  tipoDato   String   @default("string") @map("tipo_dato")
  createdAt  DateTime @default(now()) @map("created_at")

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([productoId, clave])
  @@map("producto_atributos")
}

model ProductoTag {
  productoId String   @map("producto_id")
  tag        String
  createdAt  DateTime @default(now()) @map("created_at")

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@id([productoId, tag])
  @@index([tag])
  @@map("producto_tags")
}

model InventarioSucursal {
  varianteId      String    @map("variante_id")
  sucursalId      String    @map("sucursal_id")
  stockActual     Decimal   @default(0) @map("stock_actual") @db.Decimal(18, 3)
  stockReservado  Decimal   @default(0) @map("stock_reservado") @db.Decimal(18, 3)
  stockMinimo     Decimal   @default(0) @map("stock_minimo") @db.Decimal(18, 3)
  stockMaximo     Decimal?  @map("stock_maximo") @db.Decimal(18, 3)
  ubicacion       String?
  lastInventoryAt DateTime? @map("last_inventory_at")
  nextInventoryAt DateTime? @map("next_inventory_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  variante ProductoVariante @relation(fields: [varianteId], references: [id], onDelete: Cascade)
  sucursal Sucursal         @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@id([varianteId, sucursalId])
  @@index([sucursalId])
  @@map("inventario_sucursal")
}

model InventarioMovimiento {
  id               String                   @id @default(cuid())
  varianteId       String                   @map("variante_id")
  sucursalId       String                   @map("sucursal_id")
  sucursalOrigenId String?                  @map("sucursal_origen_id")
  tipo             InventarioMovimientoTipo
  cantidad         Decimal                  @db.Decimal(18, 3)
  costoUnitario    Decimal?                 @map("costo_unitario") @db.Decimal(14, 4)
  referenciaTipo   String?                  @map("referencia_tipo")
  referenciaId     String?                  @map("referencia_id")
  loteId           String?                  @map("lote_id")
  serieId          String?                  @map("serie_id")
  motivo           String?
  usuarioId        String?                  @map("usuario_id")
  createdAt        DateTime                 @default(now()) @map("created_at")

  variante       ProductoVariante @relation(fields: [varianteId], references: [id], onDelete: Restrict)
  sucursal       Sucursal         @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  sucursalOrigen Sucursal?        @relation("MovimientoSucursalOrigen", fields: [sucursalOrigenId], references: [id], onDelete: SetNull)
  lote           ProductoLote?    @relation(fields: [loteId], references: [id], onDelete: SetNull)
  serie          ProductoSerie?   @relation(fields: [serieId], references: [id], onDelete: SetNull)
  usuario        Usuario?         @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([varianteId, sucursalId, createdAt])
  @@index([referenciaTipo, referenciaId])
  @@map("inventario_movimientos")
}

model ProductoLote {
  id              String    @id @default(cuid())
  varianteId      String    @map("variante_id")
  sucursalId      String    @map("sucursal_id")
  numeroLote      String    @map("numero_lote")
  fechaCaducidad  DateTime? @map("fecha_caducidad")
  cantidadInicial Decimal   @map("cantidad_inicial") @db.Decimal(18, 3)
  cantidadActual  Decimal   @map("cantidad_actual") @db.Decimal(18, 3)
  proveedorId     String?   @map("proveedor_id")
  notas           String?
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  variante    ProductoVariante       @relation(fields: [varianteId], references: [id], onDelete: Restrict)
  sucursal    Sucursal               @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  movimientos InventarioMovimiento[]

  @@unique([varianteId, sucursalId, numeroLote])
  @@index([fechaCaducidad])
  @@map("producto_lotes")
}

model ProductoSerie {
  id                String      @id @default(cuid())
  varianteId        String      @map("variante_id")
  sucursalId        String      @map("sucursal_id")
  numeroSerie       String      @unique @map("numero_serie")
  estado            SerieEstado @default(disponible)
  vendidoAClienteId String?     @map("vendido_a_cliente_id")
  ventaId           String?     @map("venta_id")
  vendidoAt         DateTime?   @map("vendido_at")
  garantiaHasta     DateTime?   @map("garantia_hasta")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  variante    ProductoVariante       @relation(fields: [varianteId], references: [id], onDelete: Restrict)
  sucursal    Sucursal               @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  movimientos InventarioMovimiento[]

  @@index([varianteId, estado])
  @@map("producto_series")
}

model NivelPrecioMayoreo {
  id                  String   @id @default(cuid())
  codigo              String   @unique
  nombre              String
  descripcion         String?
  descuentoDefaultPct Decimal? @map("descuento_default_pct") @db.Decimal(5, 2)
  montoMinimoCompra   Decimal? @map("monto_minimo_compra") @db.Decimal(14, 2)
  orden               Int      @default(0)
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  listas      ListaPrecio[]
  clientesB2b ClienteB2b[]

  @@map("niveles_precio_mayoreo")
}

model ListaPrecio {
  id             String          @id @default(cuid())
  codigo         String          @unique
  nombre         String
  tipo           ListaPrecioTipo @default(publico)
  nivelMayoreoId String?         @map("nivel_mayoreo_id")
  clienteB2bId   String?         @map("cliente_b2b_id")
  currency       String          @default("MXN")
  vigenteDesde   DateTime?       @map("vigente_desde")
  vigenteHasta   DateTime?       @map("vigente_hasta")
  isDefault      Boolean         @default(false) @map("is_default")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  nivelMayoreo NivelPrecioMayoreo?     @relation(fields: [nivelMayoreoId], references: [id], onDelete: SetNull)
  items        ListaPrecioItem[]
  clientesB2b  ClienteB2bListaPrecio[]

  @@index([tipo, isActive])
  @@map("listas_precios")
}

model ListaPrecioItem {
  listaPrecioId           String   @map("lista_precio_id")
  varianteId              String   @map("variante_id")
  precio                  Decimal  @db.Decimal(14, 4)
  precioMinimoNegociacion Decimal? @map("precio_minimo_negociacion") @db.Decimal(14, 4)
  incluyeIva              Boolean  @default(true) @map("incluye_iva")

  lista    ListaPrecio      @relation(fields: [listaPrecioId], references: [id], onDelete: Cascade)
  variante ProductoVariante @relation(fields: [varianteId], references: [id], onDelete: Cascade)

  @@id([listaPrecioId, varianteId])
  @@index([varianteId])
  @@map("lista_precio_items")
}

model ProductoPrecioEscalonado {
  id             String   @id @default(cuid())
  varianteId     String   @map("variante_id")
  nivel          Int
  cantidadMinima Decimal  @map("cantidad_minima") @db.Decimal(18, 3)
  cantidadMaxima Decimal? @map("cantidad_maxima") @db.Decimal(18, 3)
  precioUnitario Decimal  @map("precio_unitario") @db.Decimal(14, 4)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  variante ProductoVariante @relation(fields: [varianteId], references: [id], onDelete: Cascade)

  @@unique([varianteId, nivel])
  @@index([varianteId, isActive])
  @@map("producto_precios_escalonados")
}

model ReglaPrecio {
  id                            String           @id @default(cuid())
  codigo                        String           @unique
  nombre                        String
  descripcion                   String?
  tipo                          ReglaPrecioTipo
  prioridad                     Int              @default(100)
  stackable                     Boolean          @default(false)
  excluyeProductosConEscalonado Boolean          @default(true) @map("excluye_productos_con_escalonado")
  aplicaA                       ReglaPrecioCanal @default(todos) @map("aplica_a")
  condicion                     Json             @default("{}")
  accion                        Json             @default("{}")
  vigenteDesde                  DateTime?        @map("vigente_desde")
  vigenteHasta                  DateTime?        @map("vigente_hasta")
  diasSemana                    Json?            @map("dias_semana")
  horarios                      Json?
  usosMaxPorCliente             Int?             @map("usos_max_por_cliente")
  usosTotal                     Int?             @map("usos_total")
  usosActuales                  Int              @default(0) @map("usos_actuales")
  isActive                      Boolean          @default(true) @map("is_active")
  createdAt                     DateTime         @default(now()) @map("created_at")
  updatedAt                     DateTime         @updatedAt @map("updated_at")

  productos  ReglaPrecioProducto[]
  categorias ReglaPrecioCategoria[]

  @@index([tipo, isActive])
  @@index([vigenteDesde, vigenteHasta])
  @@map("reglas_precio")
}

model ReglaPrecioProducto {
  reglaId    String @map("regla_id")
  productoId String @map("producto_id")

  regla    ReglaPrecio @relation(fields: [reglaId], references: [id], onDelete: Cascade)
  producto Producto    @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@id([reglaId, productoId])
  @@map("regla_precio_productos")
}

model ReglaPrecioCategoria {
  reglaId     String @map("regla_id")
  categoriaId String @map("categoria_id")

  regla     ReglaPrecio @relation(fields: [reglaId], references: [id], onDelete: Cascade)
  categoria Categoria   @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@id([reglaId, categoriaId])
  @@map("regla_precio_categorias")
}

model CuponTenant {
  id                   String    @id @default(cuid())
  codigo               String    @unique
  nombre               String
  tipo                 CuponTipo
  valor                Decimal   @db.Decimal(14, 4)
  montoMinimoCompra    Decimal?  @map("monto_minimo_compra") @db.Decimal(14, 2)
  productosAplicables  Json      @default("[]") @map("productos_aplicables")
  categoriasAplicables Json      @default("[]") @map("categorias_aplicables")
  clientesAplicables   Json      @default("[]") @map("clientes_aplicables")
  usosMaxPorCliente    Int?      @map("usos_max_por_cliente")
  usosTotal            Int?      @map("usos_total")
  usosActuales         Int       @default(0) @map("usos_actuales")
  vigenteDesde         DateTime? @map("vigente_desde")
  vigenteHasta         DateTime? @map("vigente_hasta")
  isActive             Boolean   @default(true) @map("is_active")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("cupones_tenant")
}

// ============================================================
// 4.9 — Ventas, líneas, pagos (subset retail V1)
// Apartados, CxC, devoluciones parciales diferidos a Hito 2+
// CFDI integration diferido a Hito 1.5 (campo cfdiId nullable)
// ============================================================

enum VentaEstado {
  borrador
  cobrada
  cancelada
}

enum VentaCanal {
  pos
  ecommerce
  mayoreo
}

enum VentaPagoMetodo {
  efectivo
  tarjeta_debito
  tarjeta_credito
  transferencia
  vale
  monedero
  credito_fiado
  otro
}

model Venta {
  id                String      @id @default(cuid())
  folio             String
  sucursalId        String      @map("sucursal_id")
  cajaId            String?     @map("caja_id")
  usuarioId         String      @map("usuario_id")
  clienteId         String?     @map("cliente_id")
  clienteB2bId      String?     @map("cliente_b2b_id")
  estado            VentaEstado @default(borrador)
  canal             VentaCanal  @default(pos)
  moneda            String      @default("MXN")
  listaPrecioCodigo String?     @map("lista_precio_codigo")
  cuponCodigo       String?     @map("cupon_codigo")
  subtotal          Decimal     @default(0) @db.Decimal(14, 4)
  descuentoTotal    Decimal     @default(0) @map("descuento_total") @db.Decimal(14, 4)
  ivaTotal          Decimal     @default(0) @map("iva_total") @db.Decimal(14, 4)
  iepsTotal         Decimal     @default(0) @map("ieps_total") @db.Decimal(14, 4)
  total             Decimal     @default(0) @db.Decimal(14, 4)
  totalCobrado      Decimal     @default(0) @map("total_cobrado") @db.Decimal(14, 4)
  cambioDado        Decimal     @default(0) @map("cambio_dado") @db.Decimal(14, 4)
  observaciones     String?
  cfdiId            String?     @unique @map("cfdi_id")
  canceladaMotivo   String?     @map("cancelada_motivo")
  canceladaPorId    String?     @map("cancelada_por_id")
  cobradaAt         DateTime?   @map("cobrada_at")
  canceladaAt       DateTime?   @map("cancelada_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  sucursal     Sucursal          @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  caja         Caja?             @relation(fields: [cajaId], references: [id], onDelete: SetNull)
  usuario      Usuario           @relation("VentaUsuarioCreador", fields: [usuarioId], references: [id], onDelete: Restrict)
  canceladaPor Usuario?          @relation("VentaUsuarioCancelador", fields: [canceladaPorId], references: [id], onDelete: SetNull)
  cliente      Cliente?          @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  clienteB2b   ClienteB2b?       @relation(fields: [clienteB2bId], references: [id], onDelete: SetNull)
  lineas       VentaLinea[]
  pagos        VentaPago[]
  cfdis        Cfdi[]
  fiadoCargos  FiadoMovimiento[]

  @@unique([sucursalId, folio])
  @@index([estado, createdAt])
  @@index([sucursalId, cobradaAt])
  @@index([clienteId])
  @@index([clienteB2bId])
  @@map("ventas")
}

model VentaLinea {
  id                  String  @id @default(cuid())
  ventaId             String  @map("venta_id")
  numero              Int
  productoId          String  @map("producto_id")
  varianteId          String  @map("variante_id")
  loteId              String? @map("lote_id")
  serieId             String? @map("serie_id")
  cantidad            Decimal @db.Decimal(18, 3)
  precioUnitario      Decimal @map("precio_unitario") @db.Decimal(14, 4)
  precioOriginal      Decimal @map("precio_original") @db.Decimal(14, 4)
  descuentoUnitario   Decimal @default(0) @map("descuento_unitario") @db.Decimal(14, 4)
  subtotal            Decimal @db.Decimal(14, 4)
  ivaUnitario         Decimal @default(0) @map("iva_unitario") @db.Decimal(14, 4)
  ivaTotal            Decimal @default(0) @map("iva_total") @db.Decimal(14, 4)
  iepsUnitario        Decimal @default(0) @map("ieps_unitario") @db.Decimal(14, 4)
  iepsTotal           Decimal @default(0) @map("ieps_total") @db.Decimal(14, 4)
  totalLinea          Decimal @map("total_linea") @db.Decimal(14, 4)
  descuentosAplicados Json    @default("[]") @map("descuentos_aplicados")
  snapshotProducto    Json    @map("snapshot_producto")

  venta Venta @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  @@unique([ventaId, numero])
  @@index([productoId])
  @@index([varianteId])
  @@map("venta_lineas")
}

model VentaPago {
  id                 String          @id @default(cuid())
  ventaId            String          @map("venta_id")
  metodo             VentaPagoMetodo
  monto              Decimal         @db.Decimal(14, 4)
  referencia         String?
  autorizacion       String?
  terminalReferencia String?         @map("terminal_referencia")
  ultimosCuatro      String?         @map("ultimos_cuatro")
  createdAt          DateTime        @default(now()) @map("created_at")

  venta Venta @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  @@index([ventaId])
  @@map("venta_pagos")
}

model VentaFolioCounter {
  sucursalId   String   @id @map("sucursal_id")
  ultimoNumero Int      @default(0) @map("ultimo_numero")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@map("venta_folio_counters")
}

// ============================================================
// 4.11 — Cortes X/Z + apertura/cierre caja + movimientos
// ============================================================

enum CajaAperturaEstado {
  abierta
  cerrada
}

enum CajaMovimientoTipo {
  entrada_fondo
  entrada_prestamo
  entrada_devolucion
  entrada_otro
  salida_retiro
  salida_gasto
  salida_deposito
  salida_otro
}

enum CorteTipo {
  X
  Z
}

model CajaApertura {
  id                    String             @id @default(cuid())
  cajaId                String             @map("caja_id")
  sucursalId            String             @map("sucursal_id")
  usuarioId             String             @map("usuario_id")
  montoInicial          Decimal            @map("monto_inicial") @db.Decimal(14, 4)
  observacionesApertura String?            @map("observaciones_apertura")
  estado                CajaAperturaEstado @default(abierta)
  cerradaAt             DateTime?          @map("cerrada_at")
  cerradaPorId          String?            @map("cerrada_por_id")
  cerradaForzosa        Boolean            @default(false) @map("cerrada_forzosa")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  caja        Caja             @relation(fields: [cajaId], references: [id], onDelete: Restrict)
  usuario     Usuario          @relation("CajaAperturaUsuario", fields: [usuarioId], references: [id], onDelete: Restrict)
  cerradaPor  Usuario?         @relation("CajaAperturaCerradaPor", fields: [cerradaPorId], references: [id], onDelete: SetNull)
  movimientos CajaMovimiento[]
  cortes      Corte[]

  @@index([cajaId, estado])
  @@index([sucursalId, estado])
  @@index([usuarioId, estado])
  @@map("caja_aperturas")
}

model CajaMovimiento {
  id         String             @id @default(cuid())
  aperturaId String             @map("apertura_id")
  tipo       CajaMovimientoTipo
  monto      Decimal            @db.Decimal(14, 4)
  motivo     String
  referencia String?
  usuarioId  String             @map("usuario_id")
  createdAt  DateTime           @default(now()) @map("created_at")

  apertura CajaApertura @relation(fields: [aperturaId], references: [id], onDelete: Restrict)
  usuario  Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([aperturaId, createdAt])
  @@map("caja_movimientos")
}

model Corte {
  id                  String    @id @default(cuid())
  aperturaId          String    @map("apertura_id")
  tipo                CorteTipo
  numero              Int
  desdeAt             DateTime  @map("desde_at")
  hastaAt             DateTime  @map("hasta_at")
  ventasCount         Int       @map("ventas_count")
  ventasCanceladas    Int       @default(0) @map("ventas_canceladas")
  ventasTotal         Decimal   @map("ventas_total") @db.Decimal(14, 4)
  efectivoEsperado    Decimal   @map("efectivo_esperado") @db.Decimal(14, 4)
  efectivoContado     Decimal   @map("efectivo_contado") @db.Decimal(14, 4)
  diferencia          Decimal   @db.Decimal(14, 4)
  desglosePorMetodo   Json      @map("desglose_por_metodo")
  desgloseMovimientos Json      @map("desglose_movimientos")
  denominaciones      Json
  observaciones       String?
  usuarioId           String    @map("usuario_id")
  createdAt           DateTime  @default(now()) @map("created_at")

  apertura CajaApertura @relation(fields: [aperturaId], references: [id], onDelete: Restrict)
  usuario  Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@unique([aperturaId, numero])
  @@index([aperturaId, tipo])
  @@map("cortes")
}

// ============================================================
// 4.19 — CFDI 4.0 emisión vía Facturama + autofactura QR
// Certificados .cer/.key NO almacenados V1 (Facturama panel los tiene)
// XML/PDF inline V1; S3 a V1.5
// ============================================================

enum CfdiAmbiente {
  sandbox
  prod
}

enum CfdiEstado {
  pendiente
  vigente
  cancelado
  error
}

enum CfdiTipoComprobante {
  I
  E
  T
  N
  P
}

enum CfdiMetodoPago {
  PUE
  PPD
}

model CfdiConfig {
  id                 String       @id @default(cuid())
  rfcEmisor          String       @map("rfc_emisor")
  razonSocialEmisor  String       @map("razon_social_emisor")
  regimenFiscalSat   String       @map("regimen_fiscal_sat")
  codigoPostalEmisor String       @map("codigo_postal_emisor")
  lugarExpedicion    String       @map("lugar_expedicion")
  serieDefault       String       @default("A") @map("serie_default")
  folioCounter       Int          @default(0) @map("folio_counter")
  facturamaApiKey    String       @map("facturama_api_key")
  facturamaAmbiente  CfdiAmbiente @default(sandbox) @map("facturama_ambiente")
  correoEmisor       String?      @map("correo_emisor")
  telefonoEmisor     String?      @map("telefono_emisor")
  autofacturaActiva  Boolean      @default(true) @map("autofactura_activa")
  diasAutofactura    Int          @default(30) @map("dias_autofactura")
  isActive           Boolean      @default(true) @map("is_active")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  @@unique([rfcEmisor])
  @@map("cfdi_config")
}

model Cfdi {
  id                       String              @id @default(cuid())
  ventaId                  String              @unique @map("venta_id")
  serie                    String
  folio                    String
  folioFiscal              String?             @unique @map("folio_fiscal")
  fechaEmision             DateTime            @default(now()) @map("fecha_emision")
  fechaTimbrado            DateTime?           @map("fecha_timbrado")
  tipoComprobante          CfdiTipoComprobante @default(I) @map("tipo_comprobante")
  metodoPago               CfdiMetodoPago      @default(PUE) @map("metodo_pago")
  formaPago                String              @map("forma_pago")
  usoCfdi                  String              @map("uso_cfdi")
  rfcEmisor                String              @map("rfc_emisor")
  razonSocialEmisor        String              @map("razon_social_emisor")
  regimenFiscalEmisor      String              @map("regimen_fiscal_emisor")
  lugarExpedicion          String              @map("lugar_expedicion")
  rfcReceptor              String              @map("rfc_receptor")
  razonSocialReceptor      String              @map("razon_social_receptor")
  codigoPostalReceptor     String              @map("codigo_postal_receptor")
  regimenFiscalReceptor    String              @map("regimen_fiscal_receptor")
  correoReceptor           String?             @map("correo_receptor")
  subtotal                 Decimal             @db.Decimal(14, 4)
  descuento                Decimal             @default(0) @db.Decimal(14, 4)
  iva                      Decimal             @default(0) @db.Decimal(14, 4)
  ieps                     Decimal             @default(0) @db.Decimal(14, 4)
  total                    Decimal             @db.Decimal(14, 4)
  moneda                   String              @default("MXN")
  estado                   CfdiEstado          @default(pendiente)
  facturamaId              String?             @map("facturama_id")
  selloDigitalCfdi         String?             @map("sello_digital_cfdi")
  selloSat                 String?             @map("sello_sat")
  noCertificadoSat         String?             @map("no_certificado_sat")
  cadenaOriginalSat        String?             @map("cadena_original_sat")
  xml                      String?             @db.Text
  pdfBase64                String?             @map("pdf_base64") @db.Text
  errorMensaje             String?             @map("error_mensaje")
  cancelacionMotivo        String?             @map("cancelacion_motivo")
  cancelacionFolioRelacion String?             @map("cancelacion_folio_relacion")
  canceladoAt              DateTime?           @map("cancelado_at")
  emitidoPorId             String              @map("emitido_por_id")
  canceladoPorId           String?             @map("cancelado_por_id")
  autofacturaToken         String?             @unique @map("autofactura_token")
  esAutofactura            Boolean             @default(false) @map("es_autofactura")
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")

  venta        Venta    @relation(fields: [ventaId], references: [id], onDelete: Restrict)
  emitidoPor   Usuario  @relation("CfdiEmitidoPor", fields: [emitidoPorId], references: [id], onDelete: Restrict)
  canceladoPor Usuario? @relation("CfdiCanceladoPor", fields: [canceladoPorId], references: [id], onDelete: SetNull)

  @@unique([serie, folio])
  @@index([estado])
  @@index([rfcReceptor])
  @@index([fechaEmision])
  @@map("cfdis")
}

// ============================================================
// 4.8 — Clientes B2C + grupos + etiquetas + direcciones + teléfonos + fiados
// B2B (clientes_b2b) → 2.2 ; vinculación PHR → Hito 3 Salud ; pgvector → V1.5
// ============================================================

enum ClienteTipo {
  publico_general
  frecuente
  vip
  empleado
}

enum FiadoEstado {
  activo
  liquidado
  incobrable
}

enum FiadoMovimientoTipo {
  cargo_venta
  abono_pago
  ajuste_positivo
  ajuste_negativo
  regularizacion_cxc
}

model Cliente {
  id                   String      @id @default(cuid())
  tipo                 ClienteTipo @default(frecuente)
  isDefault            Boolean     @default(false) @map("is_default")
  nombre               String
  apellidos            String?
  emailPrincipal       String?     @map("email_principal")
  telefonoPrincipal    String?     @map("telefono_principal")
  fechaNacimiento      DateTime?   @map("fecha_nacimiento") @db.Date
  genero               String?
  rfc                  String?
  regimenFiscalSat     String?     @map("regimen_fiscal_sat")
  usoCfdiDefault       String?     @map("uso_cfdi_default")
  codigoPostalFiscal   String?     @map("codigo_postal_fiscal")
  direccionFacturacion Json?       @map("direccion_facturacion")
  clienteGrupoId       String?     @map("cliente_grupo_id")
  vendedorAsignadoId   String?     @map("vendedor_asignado_id")
  permiteFiado         Boolean     @default(false) @map("permite_fiado")
  limiteFiado          Decimal     @default(0) @map("limite_fiado") @db.Decimal(14, 2)
  aceptaMarketing      Boolean     @default(false) @map("acepta_marketing")
  idiomaPreferido      String      @default("es-MX") @map("idioma_preferido")
  notas                String?
  isActive             Boolean     @default(true) @map("is_active")
  archivedAt           DateTime?   @map("archived_at")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  grupo            ClienteGrupo?      @relation(fields: [clienteGrupoId], references: [id], onDelete: SetNull)
  vendedorAsignado Usuario?           @relation("ClienteVendedorAsignado", fields: [vendedorAsignadoId], references: [id], onDelete: SetNull)
  direcciones      ClienteDireccion[]
  telefonos        ClienteTelefono[]
  etiquetas        ClienteEtiqueta[]
  fiado            Fiado?
  ventas           Venta[]

  @@unique([rfc])
  @@index([nombre])
  @@index([telefonoPrincipal])
  @@index([emailPrincipal])
  @@index([isActive])
  @@index([clienteGrupoId])
  @@map("clientes")
}

model ClienteDireccion {
  id                   String   @id @default(cuid())
  clienteId            String   @map("cliente_id")
  etiqueta             String
  calle                String
  numeroExterior       String?  @map("numero_exterior")
  numeroInterior       String?  @map("numero_interior")
  colonia              String?
  municipio            String?
  estado               String?
  codigoPostal         String?  @map("codigo_postal")
  pais                 String   @default("MX")
  referencias          String?
  lat                  Decimal? @db.Decimal(10, 7)
  lng                  Decimal? @db.Decimal(10, 7)
  isDefaultEnvio       Boolean  @default(false) @map("is_default_envio")
  isDefaultFacturacion Boolean  @default(false) @map("is_default_facturacion")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@map("cliente_direcciones")
}

model ClienteTelefono {
  id          String   @id @default(cuid())
  clienteId   String   @map("cliente_id")
  etiqueta    String
  telefono    String
  whatsapp    Boolean  @default(false)
  esPrincipal Boolean  @default(false) @map("es_principal")
  createdAt   DateTime @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([telefono])
  @@map("cliente_telefonos")
}

model ClienteGrupo {
  id                  String   @id @default(cuid())
  codigo              String   @unique
  nombre              String
  descripcion         String?
  descuentoDefaultPct Decimal? @map("descuento_default_pct") @db.Decimal(5, 2)
  listaPrecioCodigo   String?  @map("lista_precio_codigo")
  color               String?
  icono               String?
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  clientes Cliente[]

  @@map("cliente_grupos")
}

model ClienteEtiqueta {
  clienteId String   @map("cliente_id")
  etiqueta  String
  createdAt DateTime @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@id([clienteId, etiqueta])
  @@index([etiqueta])
  @@map("cliente_etiquetas")
}

model Fiado {
  id                    String      @id @default(cuid())
  clienteId             String      @unique @map("cliente_id")
  montoTotal            Decimal     @default(0) @map("monto_total") @db.Decimal(14, 2)
  fechaUltimoMovimiento DateTime?   @map("fecha_ultimo_movimiento")
  estado                FiadoEstado @default(activo)
  notas                 String?
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  cliente     Cliente           @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  movimientos FiadoMovimiento[]

  @@index([estado])
  @@map("fiados")
}

model FiadoMovimiento {
  id             String              @id @default(cuid())
  fiadoId        String              @map("fiado_id")
  tipo           FiadoMovimientoTipo
  monto          Decimal             @db.Decimal(14, 2)
  ventaId        String?             @map("venta_id")
  referenciaTipo String?             @map("referencia_tipo")
  referenciaId   String?             @map("referencia_id")
  metodoPago     String?             @map("metodo_pago")
  comprobanteUrl String?             @map("comprobante_url")
  motivo         String?
  usuarioId      String              @map("usuario_id")
  createdAt      DateTime            @default(now()) @map("created_at")

  fiado   Fiado   @relation(fields: [fiadoId], references: [id], onDelete: Restrict)
  venta   Venta?  @relation(fields: [ventaId], references: [id], onDelete: SetNull)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([fiadoId, createdAt])
  @@index([ventaId])
  @@map("fiado_movimientos")
}

// ============================================================
// 4.8.b — Clientes B2B + crédito formal + multi-vendedor con comisión
// Documentos S3 → V1.5 ; portal autoservicio (usuarios) → Hito 3
// ============================================================

enum CondicionesPagoB2b {
  contado
  credito
  mixto
}

enum FormatoFacturaB2b {
  pdf
  xml
  pdf_xml
}

enum VendedorB2bTipo {
  principal
  secundario
  cobranza
}

model ClienteB2b {
  id                         String             @id @default(cuid())
  razonSocial                String             @map("razon_social")
  nombreComercial            String?            @map("nombre_comercial")
  rfc                        String             @unique
  regimenFiscalSat           String             @map("regimen_fiscal_sat")
  usoCfdiDefault             String?            @map("uso_cfdi_default")
  codigoPostalFiscal         String?            @map("codigo_postal_fiscal")
  direccionFiscal            Json?              @map("direccion_fiscal")
  emailPrincipal             String?            @map("email_principal")
  telefonoPrincipal          String?            @map("telefono_principal")
  sitioWeb                   String?            @map("sitio_web")
  representanteLegal         String?            @map("representante_legal")
  industria                  String?
  tamanoNegocio              String?            @map("tamano_negocio")
  nivelMayoreoId             String?            @map("nivel_mayoreo_id")
  listaPrecioPrincipalCodigo String?            @map("lista_precio_principal_codigo")
  diasCreditoDefault         Int                @default(0) @map("dias_credito_default")
  condicionesPago            CondicionesPagoB2b @default(contado) @map("condiciones_pago")
  requiereOrdenCompra        Boolean            @default(false) @map("requiere_orden_compra")
  formatoFacturaPreferido    FormatoFacturaB2b  @default(pdf_xml) @map("formato_factura_preferido")
  requiereAprobacionInterna  Boolean            @default(false) @map("requiere_aprobacion_interna")
  montoAprobacionRequired    Decimal?           @map("monto_aprobacion_required") @db.Decimal(14, 2)
  notas                      String?
  isActive                   Boolean            @default(true) @map("is_active")
  archivedAt                 DateTime?          @map("archived_at")
  createdAt                  DateTime           @default(now()) @map("created_at")
  updatedAt                  DateTime           @updatedAt @map("updated_at")

  nivelMayoreo        NivelPrecioMayoreo?          @relation(fields: [nivelMayoreoId], references: [id], onDelete: SetNull)
  contactos           ClienteB2bContacto[]
  direcciones         ClienteB2bDireccion[]
  creditos            ClienteB2bCredito[]
  listasPrecio        ClienteB2bListaPrecio[]
  vendedoresAsignados ClienteB2bVendedorAsignado[]
  ventas              Venta[]

  @@index([razonSocial])
  @@index([rfc])
  @@index([nivelMayoreoId])
  @@index([isActive])
  @@map("clientes_b2b")
}

model ClienteB2bContacto {
  id           String   @id @default(cuid())
  clienteB2bId String   @map("cliente_b2b_id")
  nombre       String
  apellidos    String?
  puesto       String?
  email        String?
  telefono     String?
  whatsapp     Boolean  @default(false)
  esDecisor    Boolean  @default(false) @map("es_decisor")
  esPagador    Boolean  @default(false) @map("es_pagador")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  clienteB2b ClienteB2b @relation(fields: [clienteB2bId], references: [id], onDelete: Cascade)

  @@index([clienteB2bId])
  @@map("cliente_b2b_contactos")
}

model ClienteB2bDireccion {
  id                        String   @id @default(cuid())
  clienteB2bId              String   @map("cliente_b2b_id")
  etiqueta                  String
  calle                     String
  numeroExterior            String?  @map("numero_exterior")
  numeroInterior            String?  @map("numero_interior")
  colonia                   String?
  municipio                 String?
  estado                    String?
  codigoPostal              String?  @map("codigo_postal")
  pais                      String   @default("MX")
  referencias               String?
  lat                       Decimal? @db.Decimal(10, 7)
  lng                       Decimal? @db.Decimal(10, 7)
  contactoRecepcionNombre   String?  @map("contacto_recepcion_nombre")
  contactoRecepcionTelefono String?  @map("contacto_recepcion_telefono")
  horarioRecepcion          String?  @map("horario_recepcion")
  isDefaultEnvio            Boolean  @default(false) @map("is_default_envio")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  clienteB2b ClienteB2b @relation(fields: [clienteB2bId], references: [id], onDelete: Cascade)

  @@index([clienteB2bId])
  @@map("cliente_b2b_direcciones")
}

model ClienteB2bCredito {
  id                      String    @id @default(cuid())
  clienteB2bId            String    @map("cliente_b2b_id")
  lineaAutorizada         Decimal   @map("linea_autorizada") @db.Decimal(14, 2)
  diasCredito             Int       @default(30) @map("dias_credito")
  tasaInteresMoraPct      Decimal?  @map("tasa_interes_mora_pct") @db.Decimal(5, 2)
  permiteFacturasVencidas Boolean   @default(false) @map("permite_facturas_vencidas")
  garantiaDocumentada     String?   @map("garantia_documentada")
  vigenteDesde            DateTime  @default(now()) @map("vigente_desde")
  vigenteHasta            DateTime? @map("vigente_hasta")
  aprobadoPorId           String    @map("aprobado_por_id")
  aprobadoAt              DateTime  @default(now()) @map("aprobado_at")
  notasAutorizacion       String?   @map("notas_autorizacion")
  isActive                Boolean   @default(true) @map("is_active")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  clienteB2b  ClienteB2b @relation(fields: [clienteB2bId], references: [id], onDelete: Cascade)
  aprobadoPor Usuario    @relation("ClienteB2bCreditoAprobadoPor", fields: [aprobadoPorId], references: [id], onDelete: Restrict)

  @@index([clienteB2bId, isActive])
  @@map("cliente_b2b_creditos")
}

model ClienteB2bListaPrecio {
  clienteB2bId  String    @map("cliente_b2b_id")
  listaPrecioId String    @map("lista_precio_id")
  prioridad     Int       @default(100)
  vigenteDesde  DateTime? @map("vigente_desde")
  vigenteHasta  DateTime? @map("vigente_hasta")
  createdAt     DateTime  @default(now()) @map("created_at")

  clienteB2b ClienteB2b  @relation(fields: [clienteB2bId], references: [id], onDelete: Cascade)
  lista      ListaPrecio @relation(fields: [listaPrecioId], references: [id], onDelete: Restrict)

  @@id([clienteB2bId, listaPrecioId])
  @@index([clienteB2bId])
  @@map("cliente_b2b_listas_precio")
}

model ClienteB2bVendedorAsignado {
  clienteB2bId        String          @map("cliente_b2b_id")
  usuarioId           String          @map("usuario_id")
  tipo                VendedorB2bTipo @default(principal)
  comisionPctOverride Decimal?        @map("comision_pct_override") @db.Decimal(5, 2)
  vigenteDesde        DateTime        @default(now()) @map("vigente_desde")
  vigenteHasta        DateTime?       @map("vigente_hasta")
  createdAt           DateTime        @default(now()) @map("created_at")

  clienteB2b ClienteB2b @relation(fields: [clienteB2bId], references: [id], onDelete: Cascade)
  usuario    Usuario    @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@id([clienteB2bId, usuarioId, tipo])
  @@index([usuarioId])
  @@map("cliente_b2b_vendedores_asignados")
}
