// 4.15 Salud Vet (Hito 3.3) — Mascota + Vacunas + Cartilla
// Diferidos a 3.4/V1.5: hospitalización N3, laboratorio, imagenología.
// Polimorfismo: Consulta/Receta/ConsultaSignoVital/Cita aceptan paciente
// humano XOR mascota (validado en service layer).
// ============================================================

enum MascotaEspecie {
  perro
  gato
  ave
  conejo
  huron
  reptil
  pez
  roedor
  otro
}

enum MascotaSexo {
  macho
  hembra
  desconocido
}

enum CartillaTipo {
  humano_basico_ssa
  humano_complementario
  vet_perro
  vet_gato
  vet_otro
}

model Mascota {
  id                        String         @id @default(cuid())
  numeroExpediente          String         @map("numero_expediente")
  nombre                    String
  especie                   MascotaEspecie
  raza                      String?
  sexo                      MascotaSexo    @default(desconocido)
  esEsterilizado            Boolean        @default(false) @map("es_esterilizado")
  fechaNacimiento           DateTime?      @map("fecha_nacimiento")
  fechaNacimientoAproximada Boolean        @default(false) @map("fecha_nacimiento_aproximada")
  color                     String?
  microchip                 String?
  pesoActualKg              Decimal?       @map("peso_actual_kg") @db.Decimal(6, 2)
  fotoUrl                   String?        @map("foto_url")
  tutorClienteId            String?        @map("tutor_cliente_id")
  medicoAsignadoId          String?        @map("medico_asignado_id")
  alergias                  Json           @default("[]")
  antecedentesPatologicos   Json           @default("[]") @map("antecedentes_patologicos")
  medicamentosCronicos      Json           @default("[]") @map("medicamentos_cronicos")
  etiquetas                 Json           @default("[]")
  notasInternas             String?        @map("notas_internas")
  alertasPersonalizadas     Json           @default("[]") @map("alertas_personalizadas")
  fechaPrimeraVisita        DateTime?      @map("fecha_primera_visita")
  fechaDefuncion            DateTime?      @map("fecha_defuncion")
  causaDefuncion            String?        @map("causa_defuncion")
  isActive                  Boolean        @default(true) @map("is_active")
  archivedAt                DateTime?      @map("archived_at")
  createdAt                 DateTime       @default(now()) @map("created_at")
  updatedAt                 DateTime       @updatedAt @map("updated_at")

  tutor             Cliente?             @relation("MascotaTutor", fields: [tutorClienteId], references: [id], onDelete: SetNull)
  medicoAsignado    Usuario?             @relation("MascotaMedicoAsignado", fields: [medicoAsignadoId], references: [id], onDelete: SetNull)
  citas             Cita[]
  consultas         Consulta[]
  recetas           Receta[]
  signosVitales     ConsultaSignoVital[]
  vacunaciones      Vacunacion[]
  hospitalizaciones Hospitalizacion[]
  signosHospital    SignoVitalHospital[] @relation("SignoVitalHospitalMascota")

  @@unique([numeroExpediente])
  @@index([nombre])
  @@index([microchip])
  @@index([tutorClienteId])
  @@index([medicoAsignadoId])
  @@index([especie])
  @@index([isActive])
  @@map("mascotas")
}

model VacunaCatalogo {
  id                            String   @id @default(cuid())
  nombreComercial               String   @map("nombre_comercial")
  principioActivo               String?  @map("principio_activo")
  tipo                          String?
  aplicaHumano                  Boolean  @default(false) @map("aplica_humano")
  aplicaVet                     Boolean  @default(false) @map("aplica_vet")
  especiesAplicables            Json     @default("[]") @map("especies_aplicables")
  esquemaDefaultHumano          Json?    @map("esquema_default_humano")
  esquemaDefaultVet             Json?    @map("esquema_default_vet")
  viaAplicacion                 String?  @map("via_aplicacion")
  intervaloRefuerzosDias        Int?     @map("intervalo_refuerzos_dias")
  isObligatoriaCartillaNacional Boolean  @default(false) @map("is_obligatoria_cartilla_nacional")
  precioReferencia              Decimal? @map("precio_referencia") @db.Decimal(14, 2)
  isPrecargadoGlobal            Boolean  @default(false) @map("is_precargado_global")
  isActive                      Boolean  @default(true) @map("is_active")
  createdAt                     DateTime @default(now()) @map("created_at")
  updatedAt                     DateTime @updatedAt @map("updated_at")

  vacunaciones Vacunacion[]

  @@index([aplicaHumano])
  @@index([aplicaVet])
  @@index([nombreComercial])
  @@map("vacunas_catalogo")
}

model Vacunacion {
  id                       String    @id @default(cuid())
  pacienteId               String?   @map("paciente_id")
  mascotaId                String?   @map("mascota_id")
  vacunaCatalogoId         String    @map("vacuna_catalogo_id")
  medicoAplicadorId        String    @map("medico_aplicador_id")
  fechaAplicacion          DateTime  @map("fecha_aplicacion")
  numeroLote               String    @map("numero_lote")
  caducidadLote            DateTime  @map("caducidad_lote")
  marcaSnapshot            String?   @map("marca_snapshot")
  viaAdministracion        String?   @map("via_administracion")
  dosisAplicada            String?   @map("dosis_aplicada")
  reaccionAdversaObservada String?   @map("reaccion_adversa_observada")
  proximaAplicacionFecha   DateTime? @map("proxima_aplicacion_fecha")
  notas                    String?
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  vacuna          VacunaCatalogo @relation(fields: [vacunaCatalogoId], references: [id], onDelete: Restrict)
  medicoAplicador Usuario        @relation("VacunacionAplicador", fields: [medicoAplicadorId], references: [id], onDelete: Restrict)
  paciente        Paciente?      @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  mascota         Mascota?       @relation(fields: [mascotaId], references: [id], onDelete: Cascade)

  @@index([pacienteId, fechaAplicacion])
  @@index([mascotaId, fechaAplicacion])
  @@index([numeroLote])
  @@index([proximaAplicacionFecha])
  @@map("vacunaciones")
}

// ============================================================
// HITO 3.4 — Salud N3 hospitalización (vet + humano)
// Camas, Hospitalizacion, MedicacionProgramada, KardexAplicacion,
// SignoVitalHospital, CargoHospital. Polimorfismo XOR paciente/mascota
// validado en capa servicio.
// ============================================================

enum CamaTipo {
  general
  cuidados_intensivos
  aislamiento
  cirugia_recuperacion
  pediatria
}

enum CamaEstado {
  libre
  ocupada
  limpieza
  mantenimiento
  fuera_de_servicio
}

enum HospitalizacionEstado {
  activa
  alta
  fallecimiento
  fuga
  traslado_externo
}

enum MedicacionProgramadaEstado {
  activa
  suspendida
  completada
}

enum KardexAplicacionEstado {
  pendiente
  aplicada
  omitida
  reprogramada
}

enum CargoHospitalTipo {
  estancia_diaria
  medicamento
  procedimiento
  laboratorio
  imagenologia
  consumible
  honorarios_medicos
  otro
}

model Cama {
  id             String     @id @default(cuid())
  sucursalId     String     @map("sucursal_id")
  codigo         String
  nombre         String?
  tipo           CamaTipo   @default(general)
  estado         CamaEstado @default(libre)
  tarifaPorNoche Decimal?   @map("tarifa_por_noche") @db.Decimal(14, 2)
  notas          String?
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  sucursal          Sucursal          @relation(fields: [sucursalId], references: [id], onDelete: Cascade)
  hospitalizaciones Hospitalizacion[]

  @@unique([sucursalId, codigo])
  @@index([sucursalId, estado])
  @@index([tipo])
  @@map("camas")
}

model Hospitalizacion {
  id                      String                @id @default(cuid())
  folio                   String
  sucursalId              String                @map("sucursal_id")
  camaId                  String                @map("cama_id")
  pacienteId              String?               @map("paciente_id")
  mascotaId               String?               @map("mascota_id")
  medicoResponsableId     String                @map("medico_responsable_id")
  diagnosticoIngresoId    String?               @map("diagnostico_ingreso_id")
  diagnosticoIngresoTexto String?               @map("diagnostico_ingreso_texto")
  motivoIngreso           String                @map("motivo_ingreso")
  notasIngreso            String?               @map("notas_ingreso")
  fechaIngreso            DateTime              @map("fecha_ingreso")
  fechaEgreso             DateTime?             @map("fecha_egreso")
  motivoEgreso            String?               @map("motivo_egreso")
  altaPorId               String?               @map("alta_por_id")
  observacionesAlta       String?               @map("observaciones_alta")
  ventaAlAltaId           String?               @unique @map("venta_al_alta_id")
  estado                  HospitalizacionEstado @default(activa)
  tarifaEstanciaDiaria    Decimal?              @map("tarifa_estancia_diaria") @db.Decimal(14, 2)
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")

  sucursal                Sucursal               @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  cama                    Cama                   @relation(fields: [camaId], references: [id], onDelete: Restrict)
  paciente                Paciente?              @relation(fields: [pacienteId], references: [id], onDelete: Restrict)
  mascota                 Mascota?               @relation(fields: [mascotaId], references: [id], onDelete: Restrict)
  medicoResponsable       Usuario                @relation("HospitalizacionMedico", fields: [medicoResponsableId], references: [id], onDelete: Restrict)
  diagnosticoIngreso      DiagnosticoCatalogo?   @relation(fields: [diagnosticoIngresoId], references: [id], onDelete: SetNull)
  altaPor                 Usuario?               @relation("HospitalizacionAltaPor", fields: [altaPorId], references: [id], onDelete: SetNull)
  ventaAlAlta             Venta?                 @relation("HospitalizacionVentaAlAlta", fields: [ventaAlAltaId], references: [id], onDelete: SetNull)
  medicacionesProgramadas MedicacionProgramada[]
  signosVitales           SignoVitalHospital[]
  cargos                  CargoHospital[]

  @@unique([sucursalId, folio])
  @@index([estado, fechaIngreso])
  @@index([pacienteId])
  @@index([mascotaId])
  @@index([camaId])
  @@index([medicoResponsableId])
  @@map("hospitalizaciones")
}

model HospitalizacionFolioCounter {
  sucursalId  String   @id @map("sucursal_id")
  ultimoFolio Int      @default(0) @map("ultimo_folio")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@map("hospitalizacion_folio_counters")
}

model MedicacionProgramada {
  id                        String                     @id @default(cuid())
  hospitalizacionId         String                     @map("hospitalizacion_id")
  medicamentoCatalogoId     String                     @map("medicamento_catalogo_id")
  medicamentoNombreSnapshot String                     @map("medicamento_nombre_snapshot")
  dosis                     String
  via                       String
  frecuenciaHoras           Int                        @map("frecuencia_horas")
  horaInicio                DateTime                   @map("hora_inicio")
  duracionDias              Int                        @map("duracion_dias")
  indicacionMedica          String                     @map("indicacion_medica")
  recetaId                  String?                    @map("receta_id")
  estado                    MedicacionProgramadaEstado @default(activa)
  suspendidaAt              DateTime?                  @map("suspendida_at")
  motivoSuspension          String?                    @map("motivo_suspension")
  prescritaPorId            String                     @map("prescrita_por_id")
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")

  hospitalizacion Hospitalizacion     @relation(fields: [hospitalizacionId], references: [id], onDelete: Cascade)
  medicamento     MedicamentoCatalogo @relation(fields: [medicamentoCatalogoId], references: [id], onDelete: Restrict)
  receta          Receta?             @relation("MedicacionProgramadaReceta", fields: [recetaId], references: [id], onDelete: SetNull)
  prescritaPor    Usuario             @relation("MedicacionProgramadaPrescritaPor", fields: [prescritaPorId], references: [id], onDelete: Restrict)
  aplicaciones    KardexAplicacion[]

  @@index([hospitalizacionId, estado])
  @@index([medicamentoCatalogoId])
  @@map("medicaciones_programadas")
}

model KardexAplicacion {
  id                       String                 @id @default(cuid())
  medicacionProgramadaId   String                 @map("medicacion_programada_id")
  horaProgramada           DateTime               @map("hora_programada")
  horaAplicada             DateTime?              @map("hora_aplicada")
  enfermeraAplicadorId     String?                @map("enfermera_aplicador_id")
  estado                   KardexAplicacionEstado @default(pendiente)
  motivoOmision            String?                @map("motivo_omision")
  notas                    String?
  reaccionAdversaObservada String?                @map("reaccion_adversa_observada")
  alertaEnviadaAt          DateTime?              @map("alerta_enviada_at")
  createdAt                DateTime               @default(now()) @map("created_at")
  updatedAt                DateTime               @updatedAt @map("updated_at")

  medicacionProgramada MedicacionProgramada @relation(fields: [medicacionProgramadaId], references: [id], onDelete: Cascade)
  enfermeraAplicador   Usuario?             @relation("KardexEnfermeraAplicador", fields: [enfermeraAplicadorId], references: [id], onDelete: SetNull)

  @@index([medicacionProgramadaId, horaProgramada])
  @@index([estado, horaProgramada])
  @@index([alertaEnviadaAt])
  @@map("kardex_aplicaciones")
}

model SignoVitalHospital {
  id                      String   @id @default(cuid())
  hospitalizacionId       String   @map("hospitalizacion_id")
  pacienteId              String?  @map("paciente_id")
  mascotaId               String?  @map("mascota_id")
  capturadoPorId          String   @map("capturado_por_id")
  hora                    DateTime
  temperaturaC            Decimal? @map("temperatura_c") @db.Decimal(4, 2)
  frecuenciaCardiaca      Int?     @map("frecuencia_cardiaca")
  frecuenciaRespiratoria  Int?     @map("frecuencia_respiratoria")
  saturacionO2            Int?     @map("saturacion_o2")
  presionSistolica        Int?     @map("presion_sistolica")
  presionDiastolica       Int?     @map("presion_diastolica")
  glucosa                 Decimal? @db.Decimal(6, 2)
  dolorEscala             Int?     @map("dolor_escala")
  tiempoLlenadoCapilarSeg Decimal? @map("tiempo_llenado_capilar_seg") @db.Decimal(4, 2)
  mucosasColor            String?  @map("mucosas_color")
  observaciones           String?
  alertasMarcadas         Json     @default("[]") @map("alertas_marcadas")
  createdAt               DateTime @default(now()) @map("created_at")

  hospitalizacion Hospitalizacion @relation(fields: [hospitalizacionId], references: [id], onDelete: Cascade)
  paciente        Paciente?       @relation("SignoVitalHospitalPaciente", fields: [pacienteId], references: [id], onDelete: SetNull)
  mascota         Mascota?        @relation("SignoVitalHospitalMascota", fields: [mascotaId], references: [id], onDelete: SetNull)
  capturadoPor    Usuario         @relation("SignoVitalHospitalCapturadoPor", fields: [capturadoPorId], references: [id], onDelete: Restrict)

  @@index([hospitalizacionId, hora])
  @@map("signos_vitales_hospital")
}

model CargoHospital {
  id                 String            @id @default(cuid())
  hospitalizacionId  String            @map("hospitalizacion_id")
  tipo               CargoHospitalTipo
  descripcion        String
  cantidad           Decimal           @default(1) @db.Decimal(14, 3)
  precioUnitario     Decimal           @map("precio_unitario") @db.Decimal(14, 4)
  monto              Decimal           @db.Decimal(14, 4)
  productoId         String?           @map("producto_id")
  facturadoEnVentaId String?           @map("facturado_en_venta_id")
  facturadoAt        DateTime?         @map("facturado_at")
  capturadoPorId     String            @map("capturado_por_id")
  observaciones      String?
  createdAt          DateTime          @default(now()) @map("created_at")

  hospitalizacion  Hospitalizacion @relation(fields: [hospitalizacionId], references: [id], onDelete: Cascade)
  facturadoEnVenta Venta?          @relation("CargoHospitalFacturadoEnVenta", fields: [facturadoEnVentaId], references: [id], onDelete: SetNull)
  capturadoPor     Usuario         @relation("CargoHospitalCapturadoPor", fields: [capturadoPorId], references: [id], onDelete: Restrict)

  @@index([hospitalizacionId, tipo])
  @@index([facturadoEnVentaId])
  @@map("cargos_hospital")
}

// ============================================================
// HITO 3.5 — Despacho contable (Modelo 4.12)
// CFDIs recibidos (upload manual + descarga SAT) +
// auto-categorización IA Anthropic con fallback heurístico +
// OC a proveedores + DIOT export TXT formato SAT.
// ============================================================

enum CfdiRecibidoTipoComprobante {
  I
  E
  N
  P
  T
}

enum CfdiRecibidoEstado {
  vigente
  cancelado
}

enum CfdiRecibidoOrigen {
  upload_manual
  facturama_retrieve
  webhook
}

enum CategoriaContableTipo {
  activo
  pasivo
  capital
  ingreso
  gasto
  costo
}

enum CategorizadoPor {
  ia
  regla_heuristica
  manual
}

enum OrdenCompraEstado {
  borrador
  enviada
  recibida_parcial
  recibida_total
  cancelada
}

enum CfdiMetodoPagoEnum {
  PUE
  PPD
}

model CfdiRecibido {
  id                   String                      @id @default(cuid())
  uuidSat              String                      @unique @map("uuid_sat")
  tipoComprobante      CfdiRecibidoTipoComprobante @map("tipo_comprobante")
  serie                String?
  folio                String?
  emisorRfc            String                      @map("emisor_rfc")
  emisorRazonSocial    String                      @map("emisor_razon_social")
  receptorRfc          String                      @map("receptor_rfc")
  receptorRazonSocial  String?                     @map("receptor_razon_social")
  fechaEmision         DateTime                    @map("fecha_emision")
  fechaTimbrado        DateTime?                   @map("fecha_timbrado")
  subtotal             Decimal                     @db.Decimal(14, 4)
  descuento            Decimal                     @default(0) @db.Decimal(14, 4)
  ivaTrasladado        Decimal                     @default(0) @map("iva_trasladado") @db.Decimal(14, 4)
  ivaRetenido          Decimal                     @default(0) @map("iva_retenido") @db.Decimal(14, 4)
  isrRetenido          Decimal                     @default(0) @map("isr_retenido") @db.Decimal(14, 4)
  iepsTrasladado       Decimal                     @default(0) @map("ieps_trasladado") @db.Decimal(14, 4)
  total                Decimal                     @db.Decimal(14, 4)
  moneda               String                      @default("MXN")
  tipoCambio           Decimal                     @default(1) @map("tipo_cambio") @db.Decimal(10, 6)
  metodoPago           CfdiMetodoPagoEnum?         @map("metodo_pago")
  formaPago            String?                     @map("forma_pago")
  usoCfdi              String?                     @map("uso_cfdi")
  versionSat           String                      @default("4.0") @map("version_sat")
  xmlRaw               String                      @map("xml_raw")
  pdfUrl               String?                     @map("pdf_url")
  estado               CfdiRecibidoEstado          @default(vigente)
  canceladoAt          DateTime?                   @map("cancelado_at")
  origen               CfdiRecibidoOrigen          @default(upload_manual)
  uploadedByUsuarioId  String?                     @map("uploaded_by_usuario_id")
  procesado            Boolean                     @default(false)
  procesadoAt          DateTime?                   @map("procesado_at")
  errorProcesamiento   String?                     @map("error_procesamiento")
  ordenCompraId        String?                     @map("orden_compra_id")
  movimientoBancarioId String?                     @map("movimiento_bancario_id")
  createdAt            DateTime                    @default(now()) @map("created_at")
  updatedAt            DateTime                    @updatedAt @map("updated_at")

  uploadedPor    Usuario?                    @relation("CfdiRecibidoUploadedPor", fields: [uploadedByUsuarioId], references: [id], onDelete: SetNull)
  ordenCompra    OrdenCompra?                @relation(fields: [ordenCompraId], references: [id], onDelete: SetNull)
  categorizacion CfdiRecibidoCategorizacion?

  @@index([emisorRfc, fechaEmision])
  @@index([fechaEmision])
  @@index([estado])
  @@index([procesado])
  @@index([ordenCompraId])
  @@map("cfdis_recibidos")
}

model CategoriaContable {
  id                    String                @id @default(cuid())
  codigoContable        String                @unique @map("codigo_contable")
  nombre                String
  tipo                  CategoriaContableTipo
  esDeducibleSat        Boolean               @default(false) @map("es_deducible_sat")
  ivaAcreditable        Boolean               @default(false) @map("iva_acreditable")
  isrRetenibleDefault   Decimal?              @map("isr_retenible_default") @db.Decimal(5, 2)
  parentId              String?               @map("parent_id")
  colorUi               String?               @map("color_ui")
  descripcion           String?
  claveProdServSatRegex String?               @map("clave_prod_serv_sat_regex")
  isPrecargadoGlobal    Boolean               @default(false) @map("is_precargado_global")
  isActive              Boolean               @default(true) @map("is_active")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")

  parent           CategoriaContable?           @relation("CategoriaContableJerarquia", fields: [parentId], references: [id], onDelete: SetNull)
  hijos            CategoriaContable[]          @relation("CategoriaContableJerarquia")
  categorizaciones CfdiRecibidoCategorizacion[]

  @@index([tipo])
  @@index([esDeducibleSat])
  @@map("categorias_contables")
}

model CfdiRecibidoCategorizacion {
  id                   String          @id @default(cuid())
  cfdiRecibidoId       String          @unique @map("cfdi_recibido_id")
  categoriaContableId  String          @map("categoria_contable_id")
  categorizadoPor      CategorizadoPor @map("categorizado_por")
  iaModelo             String?         @map("ia_modelo")
  iaConfianza          Decimal?        @map("ia_confianza") @db.Decimal(4, 3)
  iaJustificacion      String?         @map("ia_justificacion")
  reglaAplicada        String?         @map("regla_aplicada")
  asignadoPorUsuarioId String?         @map("asignado_por_usuario_id")
  override             Boolean         @default(false)
  asignadoAt           DateTime        @default(now()) @map("asignado_at")

  cfdiRecibido CfdiRecibido      @relation(fields: [cfdiRecibidoId], references: [id], onDelete: Cascade)
  categoria    CategoriaContable @relation(fields: [categoriaContableId], references: [id], onDelete: Restrict)
  asignadoPor  Usuario?          @relation("CfdiCategorizacionAsignadoPor", fields: [asignadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([categoriaContableId])
  @@map("cfdi_recibido_categorizaciones")
}

model OrdenCompra {
  id                   String            @id @default(cuid())
  folio                String
  sucursalId           String            @map("sucursal_id")
  proveedorRfc         String            @map("proveedor_rfc")
  proveedorRazonSocial String            @map("proveedor_razon_social")
  proveedorEmail       String?           @map("proveedor_email")
  estado               OrdenCompraEstado @default(borrador)
  fechaCreacion        DateTime          @default(now()) @map("fecha_creacion")
  fechaEsperada        DateTime?         @map("fecha_esperada")
  fechaRecepcion       DateTime?         @map("fecha_recepcion")
  observaciones        String?
  subtotal             Decimal           @default(0) @db.Decimal(14, 4)
  ivaTotal             Decimal           @default(0) @map("iva_total") @db.Decimal(14, 4)
  total                Decimal           @default(0) @db.Decimal(14, 4)
  creadoPorUsuarioId   String            @map("creado_por_usuario_id")
  autorizadoPorId      String?           @map("autorizado_por_id")
  autorizadoAt         DateTime?         @map("autorizado_at")
  canceladaMotivo      String?           @map("cancelada_motivo")
  canceladaAt          DateTime?         @map("cancelada_at")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  sucursal        Sucursal           @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  creadoPor       Usuario            @relation("OrdenCompraCreadoPor", fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)
  autorizadoPor   Usuario?           @relation("OrdenCompraAutorizadoPor", fields: [autorizadoPorId], references: [id], onDelete: SetNull)
  lineas          OrdenCompraLinea[]
  cfdisVinculados CfdiRecibido[]

  @@unique([sucursalId, folio])
  @@index([estado, fechaCreacion])
