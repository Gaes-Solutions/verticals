}

model ProductoPublicado {
  id                    String    @id @default(cuid())
  productoId            String    @unique @map("producto_id")
  categoriaPublicaId    String?   @map("categoria_publica_id")
  tituloPublico         String    @map("titulo_publico")
  slugSeo               String    @map("slug_seo")
  descripcionMd         String?   @map("descripcion_md")
  descripcionCortaMd    String?   @map("descripcion_corta_md")
  metaTitulo            String?   @map("meta_titulo")
  metaDescripcion       String?   @map("meta_descripcion")
  fotosArray            Json      @default("[]") @map("fotos_array")
  videoUrl              String?   @map("video_url")
  precioPublicoOverride Decimal?  @map("precio_publico_override") @db.Decimal(14, 2)
  precioPromocion       Decimal?  @map("precio_promocion") @db.Decimal(14, 2)
  promocionVigenteHasta DateTime? @map("promocion_vigente_hasta")
  atributosPublicos     Json      @default("{}") @map("atributos_publicos")
  tags                  Json      @default("[]")
  rankingScore          Int       @default(0) @map("ranking_score")
  destacadoHome         Boolean   @default(false) @map("destacado_home")
  publicadoAt           DateTime  @default(now()) @map("publicado_at")
  relacionadosIds       Json      @default("[]") @map("relacionados_ids")
  isPublicado           Boolean   @default(true) @map("is_publicado")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  producto         Producto             @relation(fields: [productoId], references: [id], onDelete: Cascade)
  categoriaPublica CategoriaPublica?    @relation(fields: [categoriaPublicaId], references: [id], onDelete: SetNull)
  traducciones     ProductoTraduccion[]
  resenas          ProductoResena[]
  preguntas        PreguntaProducto[]

  @@unique([slugSeo])
  @@index([categoriaPublicaId])
  @@index([destacadoHome])
  @@index([isPublicado])
  @@map("productos_publicados")
}

model ProductoTraduccion {
  id                  String   @id @default(cuid())
  productoPublicadoId String   @map("producto_publicado_id")
  locale              String
  tituloPublico       String   @map("titulo_publico")
  descripcionMd       String?  @map("descripcion_md")
  metaTitulo          String?  @map("meta_titulo")
  metaDescripcion     String?  @map("meta_descripcion")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  productoPublicado ProductoPublicado @relation(fields: [productoPublicadoId], references: [id], onDelete: Cascade)

  @@unique([productoPublicadoId, locale])
  @@map("producto_traducciones")
}

model CarritoEcommerce {
  id                     String                      @id @default(cuid())
  sessionIdAnonimo       String?                     @map("session_id_anonimo")
  clienteId              String?                     @map("cliente_id")
  emailAnonimo           String?                     @map("email_anonimo")
  canal                  CarritoCanal                @default(web)
  items                  Json                        @default("[]")
  subtotal               Decimal                     @default(0) @db.Decimal(14, 4)
  descuentoTotal         Decimal                     @default(0) @map("descuento_total") @db.Decimal(14, 4)
  costoEnvio             Decimal                     @default(0) @map("costo_envio") @db.Decimal(14, 4)
  total                  Decimal                     @default(0) @db.Decimal(14, 4)
  moneda                 String                      @default("MXN")
  cuponCodigo            String?                     @map("cupon_codigo")
  promocionesAplicadas   Json                        @default("[]") @map("promociones_aplicadas")
  direccionEnvio         Json?                       @map("direccion_envio")
  direccionFactura       Json?                       @map("direccion_factura")
  metodoEnvio            PedidoEcommerceMetodoEnvio? @map("metodo_envio")
  metodoPagoSeleccionado String?                     @map("metodo_pago_seleccionado")
  status                 CarritoEstado               @default(activo)
  abandonadoAt           DateTime?                   @map("abandonado_at")
  recordatorio24hAt      DateTime?                   @map("recordatorio_24h_at")
  recordatorio72hAt      DateTime?                   @map("recordatorio_72h_at")
  recoveryCodigo         String?                     @unique @map("recovery_codigo")
  convertidoAPedidoId    String?                     @map("convertido_a_pedido_id")
  ip                     String?
  userAgent              String?                     @map("user_agent")
  referrer               String?
  utm                    Json?
  createdAt              DateTime                    @default(now()) @map("created_at")
  updatedAt              DateTime                    @updatedAt @map("updated_at")

  cliente Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  @@index([sessionIdAnonimo])
  @@index([clienteId])
  @@index([status, abandonadoAt])
  @@map("carritos_ecommerce")
}

model PedidoEcommerce {
  id               String                     @id @default(cuid())
  folioPublico     String                     @unique @map("folio_publico")
  carritoOrigenId  String?                    @map("carrito_origen_id")
  clienteId        String?                    @map("cliente_id")
  emailComprador   String                     @map("email_comprador")
  items            Json                       @default("[]")
  subtotal         Decimal                    @db.Decimal(14, 4)
  descuentoTotal   Decimal                    @default(0) @map("descuento_total") @db.Decimal(14, 4)
  costoEnvio       Decimal                    @default(0) @map("costo_envio") @db.Decimal(14, 4)
  total            Decimal                    @db.Decimal(14, 4)
  moneda           String                     @default("MXN")
  tipoCambio       Decimal                    @default(1) @map("tipo_cambio") @db.Decimal(10, 6)
  cuponesSnapshot  Json                       @default("[]") @map("cupones_snapshot")
  direccionEnvio   Json?                      @map("direccion_envio")
  direccionFactura Json?                      @map("direccion_factura")
  requiereFactura  Boolean                    @default(false) @map("requiere_factura")
  datosFactura     Json?                      @map("datos_factura")
  statusPago       PedidoEcommerceEstadoPago  @default(pendiente) @map("status_pago")
  paymentIntentId  String?                    @map("payment_intent_id")
  metodoPago       String?                    @map("metodo_pago")
  metodoEnvio      PedidoEcommerceMetodoEnvio @map("metodo_envio")
  sucursalPickupId String?                    @map("sucursal_pickup_id")
  paqueteria       EnvioPaqueteria?
  guiaTracking     String?                    @map("guia_tracking")
  costoEnvioReal   Decimal?                   @map("costo_envio_real") @db.Decimal(14, 4)
  statusPedido     PedidoEcommerceEstado      @default(recibido) @map("status_pedido")
  asignadoAId      String?                    @map("asignado_a_id")
  asignadoAt       DateTime?                  @map("asignado_at")
  ventaIdGenerada  String?                    @unique @map("venta_id_generada")
  facturaCfdiId    String?                    @map("factura_cfdi_id")
  pagoConfirmadoAt DateTime?                  @map("pago_confirmado_at")
  enviadoAt        DateTime?                  @map("enviado_at")
  entregadoAt      DateTime?                  @map("entregado_at")
  canceladoAt      DateTime?                  @map("cancelado_at")
  canceladoMotivo  String?                    @map("cancelado_motivo")
  createdAt        DateTime                   @default(now()) @map("created_at")
  updatedAt        DateTime                   @updatedAt @map("updated_at")

  cliente               Cliente?                @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  sucursalPickup        Sucursal?               @relation(fields: [sucursalPickupId], references: [id], onDelete: SetNull)
  asignadoA             Usuario?                @relation("PedidoEcommerceAsignado", fields: [asignadoAId], references: [id], onDelete: SetNull)
  ventaGenerada         Venta?                  @relation("PedidoEcommerceVenta", fields: [ventaIdGenerada], references: [id], onDelete: SetNull)
  eventos               PedidoEcommerceEvento[]
  envio                 EnvioPedido?
  pickup                PickupPedido?
  resenas               ProductoResena[]
  solicitudesDevolucion SolicitudDevolucion[]
  mensajes              MensajePedido[]

  @@index([clienteId])
  @@index([statusPedido, createdAt])
  @@index([statusPago])
  @@index([emailComprador])
  @@index([asignadoAId])
  @@map("pedidos_ecommerce")
}

model PedidoEcommerceEvento {
  id             String   @id @default(cuid())
  pedidoId       String   @map("pedido_id")
  tipo           String
  descripcion    String
  visibleCliente Boolean  @default(true) @map("visible_cliente")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  pedido PedidoEcommerce @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId, createdAt])
  @@map("pedidos_ecommerce_eventos")
}

model PedidoEcommerceFolioCounter {
  id          Int      @id @default(1)
  ultimoFolio Int      @default(0) @map("ultimo_folio")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("pedido_ecommerce_folio_counter")
}

/// Config personalizable del flujo de pedidos online por tenant (singleton).
/// etiquetasEstado: override de los nombres visibles de cada estado canónico
/// (ej. { "preparando": "Surtido", "en_camino": "En proceso" }).
model ConfigEcommerce {
  id              Int      @id @default(1)
  etiquetasEstado Json     @default("{}") @map("etiquetas_estado")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("config_ecommerce")
}

enum NotificacionDestinatario {
  usuario
  cliente
}

/// Notificación in-app (campana). Polimórfica: dirigida a un empleado del
/// tenant (usuarioId) o a un cliente de la tienda (clienteId).
model Notificacion {
  id               String                   @id @default(cuid())
  destinatarioTipo NotificacionDestinatario @map("destinatario_tipo")
  usuarioId        String?                  @map("usuario_id")
  clienteId        String?                  @map("cliente_id")
  tipo             String
  titulo           String
  cuerpo           String
  link             String?
  leida            Boolean                  @default(false)
  leidaAt          DateTime?                @map("leida_at")
  metadata         Json?
  createdAt        DateTime                 @default(now()) @map("created_at")

  usuario Usuario? @relation("NotificacionUsuario", fields: [usuarioId], references: [id], onDelete: Cascade)
  cliente Cliente? @relation("NotificacionCliente", fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([usuarioId, leida, createdAt])
  @@index([clienteId, leida, createdAt])
  @@map("notificaciones")
}

enum SolicitudDevolucionEstado {
  solicitada
  aprobada
  rechazada
  cancelada
}

/// Solicitud de devolución iniciada por el cliente desde la tienda (flujo con
/// aprobación, estilo Mercado Libre). Al aprobarse genera una Devolucion real
/// contra la venta ligada al pedido (repone stock + reembolso + CFDI Egreso).
model SolicitudDevolucion {
  id                String                    @id @default(cuid())
  folio             String                    @unique
  pedidoEcommerceId String                    @map("pedido_ecommerce_id")
  clienteId         String                    @map("cliente_id")
  motivo            DevolucionMotivo
  descripcion       String?
  items             Json                      @default("[]")
  fotos             Json                      @default("[]")
  estado            SolicitudDevolucionEstado @default(solicitada)
  rechazoMotivo     String?                   @map("rechazo_motivo")
  devolucionId      String?                   @unique @map("devolucion_id")
  resueltaPorId     String?                   @map("resuelta_por_id")
  resueltaAt        DateTime?                 @map("resuelta_at")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  pedido      PedidoEcommerce @relation(fields: [pedidoEcommerceId], references: [id], onDelete: Cascade)
  cliente     Cliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  devolucion  Devolucion?     @relation("SolicitudDevolucionGenerada", fields: [devolucionId], references: [id], onDelete: SetNull)
  resueltaPor Usuario?        @relation("SolicitudDevolucionResueltaPor", fields: [resueltaPorId], references: [id], onDelete: SetNull)

  @@index([estado, createdAt])
  @@index([clienteId])
  @@index([pedidoEcommerceId])
  @@map("solicitudes_devolucion")
}

enum MensajePedidoAutor {
  cliente
  empleado
}

/// Mensaje en el hilo pedido↔cliente (preguntas/soporte estilo Mercado Libre).
model MensajePedido {
  id                String             @id @default(cuid())
  pedidoEcommerceId String             @map("pedido_ecommerce_id")
  autorTipo         MensajePedidoAutor @map("autor_tipo")
  usuarioId         String?            @map("usuario_id")
  clienteId         String?            @map("cliente_id")
  cuerpo            String
  leidoPorCliente   Boolean            @default(false) @map("leido_por_cliente")
  leidoPorEmpleado  Boolean            @default(false) @map("leido_por_empleado")
  createdAt         DateTime           @default(now()) @map("created_at")

  pedido  PedidoEcommerce @relation(fields: [pedidoEcommerceId], references: [id], onDelete: Cascade)
  usuario Usuario?        @relation("MensajePedidoUsuario", fields: [usuarioId], references: [id], onDelete: SetNull)
  cliente Cliente?        @relation("MensajePedidoCliente", fields: [clienteId], references: [id], onDelete: SetNull)

  @@index([pedidoEcommerceId, createdAt])
  @@map("mensajes_pedido")
}

model ZonaEnvio {
