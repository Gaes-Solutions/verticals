enum PreguntaEstado {
  pendiente
  publicada
  rechazada
}

/// Pregunta pública sobre un producto (Q&A estilo Mercado Libre). El cliente
/// pregunta, la tienda responde; las respondidas+publicadas se ven en el producto.
model PreguntaProducto {
  id                  String         @id @default(cuid())
  productoPublicadoId String         @map("producto_publicado_id")
  clienteId           String?        @map("cliente_id")
  autorNombre         String?        @map("autor_nombre")
  pregunta            String
  respuesta           String?
  respondidaPorId     String?        @map("respondida_por_id")
  respondidaAt        DateTime?      @map("respondida_at")
  estado              PreguntaEstado @default(pendiente)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  productoPublicado ProductoPublicado @relation(fields: [productoPublicadoId], references: [id], onDelete: Cascade)
  cliente           Cliente?          @relation("PreguntaProductoCliente", fields: [clienteId], references: [id], onDelete: SetNull)
  respondidaPor     Usuario?          @relation("PreguntaRespondidaPor", fields: [respondidaPorId], references: [id], onDelete: SetNull)

  @@index([productoPublicadoId, estado])
  @@index([estado, createdAt])
  @@map("preguntas_producto")
}

model Wishlist {
  id          String   @id @default(cuid())
  clienteId   String   @map("cliente_id")
  nombre      String   @default("Mi lista")
  esPublica   Boolean  @default(false) @map("es_publica")
  slugPublico String?  @unique @map("slug_publico")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cliente Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  items   WishlistItem[]

  @@index([clienteId])
  @@map("wishlists")
}

model WishlistItem {
  id                  String   @id @default(cuid())
  wishlistId          String   @map("wishlist_id")
  productoPublicadoId String   @map("producto_publicado_id")
  agregadoAt          DateTime @default(now()) @map("agregado_at")

  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productoPublicadoId])
  @@map("wishlist_items")
}

model ConfigPickupSucursal {
  id                           String   @id @default(cuid())
  sucursalId                   String   @unique @map("sucursal_id")
  activa                       Boolean  @default(false)
  horarioPickup                Json     @default("{}") @map("horario_pickup")
  tiempoPreparacionPromedioMin Int      @default(60) @map("tiempo_preparacion_promedio_min")
  requiereIdRecoger            Boolean  @default(true) @map("requiere_id_recoger")
  notificacionListoCanal       String   @default("email") @map("notificacion_listo_canal")
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@map("config_pickup_sucursal")
}

model PickupPedido {
  id                String    @id @default(cuid())
  pedidoId          String    @unique @map("pedido_id")
  sucursalId        String    @map("sucursal_id")
  listoAt           DateTime? @map("listo_at")
  recogidoAt        DateTime? @map("recogido_at")
  recogidoPorNombre String?   @map("recogido_por_nombre")
  recogidoPorId     String?   @map("recogido_por_id")
  responsableUserId String?   @map("responsable_user_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  pedido          PedidoEcommerce @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  sucursal        Sucursal        @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  responsableUser Usuario?        @relation("PickupResponsable", fields: [responsableUserId], references: [id], onDelete: SetNull)

  @@map("pickup_pedidos")
}

model SeoConfiguracionTienda {
  id                       String   @id @default(cuid())
  robotsTxt                String?  @map("robots_txt")
  sitemapAuto              Boolean  @default(true) @map("sitemap_auto")
  redirects301             Json     @default("[]") @map("redirects_301")
  structuredDataTemplate   Json?    @map("structured_data_template")
  googleSearchConsoleVerif String?  @map("google_search_console_verif")
  bingVerif                String?  @map("bing_verif")
  canonicalDominio         String?  @map("canonical_dominio")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@map("seo_configuracion_tienda")
}

/// Configuración de la plantilla de carga masiva de productos (singleton por tenant).
/// El dueño elige qué columnas opcionales incluir y cuáles son obligatorias para su
/// negocio. SKU, Nombre y Precio siempre van (obligatorias fijas, no se guardan aquí).
model ConfigImportacionProductos {
  id                   String   @id @default(cuid())
  columnasActivas      Json     @default("[]") @map("columnas_activas")
  columnasObligatorias Json     @default("[]") @map("columnas_obligatorias")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("config_importacion_productos")
}

// ============================================================
// HITO 4.2 — Marketing (Modelo 4.18)
// Promociones automáticas, segmentación RFM, campañas multicanal,
// lealtad por puntos, triggers. Worker de envíos in-process V1.
// ============================================================

enum PromocionTipo {
  dos_x_uno
  tres_x_n
  mxn
  compra_x_lleva_y
  descuento_pct
  descuento_monto
  precio_especial
  regalo_con_compra
  escalonado_volumen
  happy_hour
}

enum PromocionStatus {
  draft
  programada
  activa
  pausada
  expirada
  cancelada
}

enum PromocionProductoRol {
  incluido
  excluido
  regalo
  comprado
  requerido
}

enum SegmentoTipo {
  estatico
  dinamico_rfm
  dinamico_query
}

enum SegmentoRfm {
  champion
  leal
  en_riesgo
  perdido
  nuevo
  hibernando
}

enum CampanaCanal {
  whatsapp
  email
  sms
  push
  multi
}

enum CampanaTipoDisparo {
  inmediato
  programado
  recurrente
  trigger_event
}

enum CampanaStatus {
  draft
  programada
  enviando
  enviada
  pausada
  cancelada
}

enum CampanaEnvioStatus {
  pendiente
  enviado
  entregado
  abierto
  click
  convertido
  opt_out
  bounce
  fallido
}

enum PlantillaCanal {
  whatsapp
  email
  sms
  push
}

enum PlantillaTipo {
  transaccional
  promocional
  utility
  servicio
}

enum PlantillaScope {
  gaessoft_global
  tenant_propia
}

enum OptOutTipo {
  promocional
  todo
}

enum LoyaltyTipo {
  puntos_por_peso
  puntos_por_visita
  tiers_volumen
  mixto
}

enum LoyaltyMovimientoTipo {
  acumulacion
  canje
  expiracion
  ajuste_admin
  reverso
}

model Promocion {
  id                   String          @id @default(cuid())
  nombre               String
  descripcion          String?
  tipo                 PromocionTipo
  condiciones          Json            @default("{}")
  acciones             Json            @default("{}")
  vigenciaInicio       DateTime        @map("vigencia_inicio")
  vigenciaFin          DateTime?       @map("vigencia_fin")
  horarios             Json?
  canales              Json            @default("[\"todos\"]")
  sucursalesAplicables Json            @default("[]") @map("sucursales_aplicables")
  stackConOtras        Boolean         @default(false) @map("stack_con_otras")
  prioridad            Int             @default(100)
  limiteUsosTotal      Int?            @map("limite_usos_total")
  limiteUsosCliente    Int?            @map("limite_usos_cliente")
  usosActuales         Int             @default(0) @map("usos_actuales")
  requiereCodigo       Boolean         @default(false) @map("requiere_codigo")
  codigo               String?
  visiblePublico       Boolean         @default(true) @map("visible_publico")
  bannerUrl            String?         @map("banner_url")
  status               PromocionStatus @default(draft)
  tags                 Json            @default("[]")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  productos    PromocionProducto[]
  aplicaciones PromocionAplicacion[]

  @@unique([codigo])
  @@index([status, vigenciaInicio])
  @@index([prioridad])
  @@map("promociones")
}

model PromocionProducto {
  id          String               @id @default(cuid())
  promocionId String               @map("promocion_id")
  productoId  String               @map("producto_id")
  rol         PromocionProductoRol @default(incluido)

  promocion Promocion @relation(fields: [promocionId], references: [id], onDelete: Cascade)
  producto  Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([promocionId, productoId, rol])
  @@index([productoId])
  @@map("promociones_productos")
}

model PromocionAplicacion {
  id                 String    @id @default(cuid())
  promocionId        String    @map("promocion_id")
  ventaId            String    @map("venta_id")
  clienteId          String?   @map("cliente_id")
  montoDescuento     Decimal   @map("monto_descuento") @db.Decimal(14, 4)
  productosAfectados Json      @default("[]") @map("productos_afectados")
  revocadaAt         DateTime? @map("revocada_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  promocion Promocion @relation(fields: [promocionId], references: [id], onDelete: Restrict)
  venta     Venta     @relation("VentaPromociones", fields: [ventaId], references: [id], onDelete: Cascade)

  @@index([promocionId])
  @@index([ventaId])
  @@map("promociones_aplicaciones")
}

model SegmentoCliente {
  id            String       @id @default(cuid())
  nombre        String
  descripcion   String?
  tipo          SegmentoTipo @default(dinamico_rfm)
  definicion    Json         @default("{}")
  countClientes Int          @default(0) @map("count_clientes")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  miembros SegmentoClienteMiembro[]
  campanas Campana[]

  @@index([tipo])
  @@map("segmentos_clientes")
}

model SegmentoClienteMiembro {
  id               String   @id @default(cuid())
  segmentoId       String   @map("segmento_id")
  clienteId        String   @map("cliente_id")
  snapshotMetricas Json?    @map("snapshot_metricas")
  agregadoAt       DateTime @default(now()) @map("agregado_at")

  segmento SegmentoCliente @relation(fields: [segmentoId], references: [id], onDelete: Cascade)
  cliente  Cliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([segmentoId, clienteId])
  @@index([clienteId])
  @@map("segmentos_clientes_miembros")
}

model ClienteMetricasRfm {
  id                   String       @id @default(cuid())
  clienteId            String       @unique @map("cliente_id")
  recencyDias          Int?         @map("recency_dias")
  frequency            Int          @default(0)
  monetary             Decimal      @default(0) @db.Decimal(14, 2)
  scoreR               Int?         @map("score_r")
  scoreF               Int?         @map("score_f")
  scoreM               Int?         @map("score_m")
  segmentoRfmCalculado SegmentoRfm? @map("segmento_rfm_calculado")
  ultimaCompraAt       DateTime?    @map("ultima_compra_at")
  refreshedAt          DateTime     @default(now()) @map("refreshed_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([segmentoRfmCalculado])
  @@map("clientes_metricas_rfm")
}

model PlantillaMensaje {
  id                   String         @id @default(cuid())
  nombre               String
  canal                PlantillaCanal
  tipo                 PlantillaTipo
  idioma               String         @default("es-MX")
  asunto               String?
  contenidoHandlebars  String         @map("contenido_handlebars")
  variablesDisponibles Json           @default("[]") @map("variables_disponibles")
  aprobacionMetaStatus String         @default("no_aplica") @map("aprobacion_meta_status")
  metaTemplateId       String?        @map("meta_template_id")
  scope                PlantillaScope @default(tenant_propia)
  isActive             Boolean        @default(true) @map("is_active")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  campanas Campana[]

  @@index([canal, tipo])
  @@map("plantillas_mensajes")
}

model Campana {
  id                     String             @id @default(cuid())
  nombre                 String
  objetivo               String
  canal                  CampanaCanal
  segmentoId             String?            @map("segmento_id")
  plantillaId            String?            @map("plantilla_id")
  variablesDinamicas     Json               @default("{}") @map("variables_dinamicas")
  tipoDisparo            CampanaTipoDisparo @default(inmediato) @map("tipo_disparo")
  triggerEventConfig     Json?              @map("trigger_event_config")
  recurrenteCron         String?            @map("recurrente_cron")
  ventanaHorarioEnvio    Json               @default("{\"desde\":\"09:00\",\"hasta\":\"21:00\"}") @map("ventana_horario_envio")
  status                 CampanaStatus      @default(draft)
  stats                  Json               @default("{}")
  presupuestoMaxCreditos Decimal            @default(500) @map("presupuesto_max_creditos") @db.Decimal(14, 2)
  creditosConsumidos     Decimal            @default(0) @map("creditos_consumidos") @db.Decimal(14, 2)
  programadaPara         DateTime?          @map("programada_para")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  segmento  SegmentoCliente?  @relation(fields: [segmentoId], references: [id], onDelete: SetNull)
  plantilla PlantillaMensaje? @relation(fields: [plantillaId], references: [id], onDelete: SetNull)
  envios    CampanaEnvio[]
  triggers  CampanaTrigger[]

  @@index([status, tipoDisparo])
  @@map("campanas")
}

model CampanaEnvio {
  id             String             @id @default(cuid())
  campanaId      String             @map("campana_id")
  clienteId      String?            @map("cliente_id")
  destino        String
  canal          CampanaCanal
  status         CampanaEnvioStatus @default(pendiente)
  proveedorMsgId String?            @map("proveedor_msg_id")
  creditos       Decimal            @default(0) @db.Decimal(14, 4)
  errorMensaje   String?            @map("error_mensaje")
  enviadoAt      DateTime?          @map("enviado_at")
  entregadoAt    DateTime?          @map("entregado_at")
  abiertoAt      DateTime?          @map("abierto_at")
  clickAt        DateTime?          @map("click_at")
  convertidoAt   DateTime?          @map("convertido_at")
  createdAt      DateTime           @default(now()) @map("created_at")

  campana Campana  @relation(fields: [campanaId], references: [id], onDelete: Cascade)
  cliente Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  @@index([campanaId, status])
  @@index([clienteId, createdAt])
  @@index([status])
  @@map("campanas_envios")
}

model CampanaTrigger {
  id                         String   @id @default(cuid())
  evento                     String
  campanaId                  String   @map("campana_id")
  ventanaEnvio               Json?    @map("ventana_envio")
  frecuenciaMaxPorCliente30d Int      @default(1) @map("frecuencia_max_por_cliente_30d")
  isActive                   Boolean  @default(true) @map("is_active")
  createdAt                  DateTime @default(now()) @map("created_at")

  campana Campana @relation(fields: [campanaId], references: [id], onDelete: Cascade)

  @@index([evento, isActive])
  @@map("campanas_triggers")
}

model ClienteOptOut {
  id        String       @id @default(cuid())
  clienteId String       @map("cliente_id")
  canal     CampanaCanal
  tipo      OptOutTipo   @default(promocional)
  createdAt DateTime     @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, canal, tipo])
  @@index([clienteId])
  @@map("clientes_opt_outs")
}

model LoyaltyProgram {
  id                     String      @id @default(cuid())
  nombre                 String
  tipo                   LoyaltyTipo @default(puntos_por_peso)
  reglaAcumulacion       Json        @default("{}") @map("regla_acumulacion")
  valorPuntoRedimible    Decimal     @default(0.1) @map("valor_punto_redimible") @db.Decimal(10, 4)
  caducidadPuntosMeses   Int         @default(12) @map("caducidad_puntos_meses")
  tiers                  Json        @default("[]")
  inscripcionAutomatica  Boolean     @default(false) @map("inscripcion_automatica")
  requiereConsentimiento Boolean     @default(true) @map("requiere_consentimiento")
  isActive               Boolean     @default(true) @map("is_active")
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")

  inscritos   ClienteLoyalty[]
  movimientos LoyaltyMovimiento[]

  @@map("loyalty_programs")
}

model ClienteLoyalty {
  id                String    @id @default(cuid())
  loyaltyProgramId  String    @map("loyalty_program_id")
  clienteId         String    @map("cliente_id")
  puntosActuales    Int       @default(0) @map("puntos_actuales")
  lifetimeAcumulado Int       @default(0) @map("lifetime_acumulado")
  lifetimeCanjeado  Int       @default(0) @map("lifetime_canjeado")
  tierActual        String?   @map("tier_actual")
  fechaAlcanzoTier  DateTime? @map("fecha_alcanzo_tier")
  consentimientoAt  DateTime? @map("consentimiento_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  programa LoyaltyProgram @relation(fields: [loyaltyProgramId], references: [id], onDelete: Cascade)
  cliente  Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([loyaltyProgramId, clienteId])
  @@index([clienteId])
  @@map("clientes_loyalty")
}

model LoyaltyMovimiento {
  id               String                @id @default(cuid())
  loyaltyProgramId String                @map("loyalty_program_id")
  clienteId        String                @map("cliente_id")
  tipo             LoyaltyMovimientoTipo
  puntos           Int
  saldoResultante  Int                   @map("saldo_resultante")
  origenVentaId    String?               @map("origen_venta_id")
  origenCampanaId  String?               @map("origen_campana_id")
  origenAdminId    String?               @map("origen_admin_id")
  caducaAt         DateTime?             @map("caduca_at")
  notas            String?
  createdAt        DateTime              @default(now()) @map("created_at")

  programa LoyaltyProgram @relation(fields: [loyaltyProgramId], references: [id], onDelete: Cascade)

  @@index([clienteId, createdAt])
  @@index([caducaAt])
  @@map("loyalty_movimientos")
}

// ─────────────────────────────────────────────────────────────────────────────
// Sync engine offline-first (Hito 5, Análisis 8)
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Registro idempotente de operaciones empujadas por dispositivos offline.
 * Misma idempotency_key ⇒ se retorna el resultado almacenado (no se re-aplica).
 */
model SyncProcessedOp {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique @map("idempotency_key")
  entityType     String   @map("entity_type")
  entityIdLocal  String   @map("entity_id_local")
  entityIdRemoto String?  @map("entity_id_remoto")
  status         String
  resultSnapshot Json?    @map("result_snapshot")
  deviceId       String?  @map("device_id")
  processedAt    DateTime @default(now()) @map("processed_at")

  @@index([entityType])
  @@index([processedAt])
  @@map("sync_processed_ops")
}

/**
 * Lápidas de borrados duros para que el pull entregue tombstones a los
 * dispositivos (la mayoría de entidades usan soft-delete, esto cubre el resto).
 */
model SyncTombstone {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  deletedAt  DateTime @default(now()) @map("deleted_at")

  @@index([entityType, deletedAt])
  @@map("sync_tombstones")
}
