model Cita {
  id                        String     @id @default(cuid())
  folio                     String
  pacienteId                String?    @map("paciente_id")
  mascotaId                 String?    @map("mascota_id")
  medicoUsuarioId           String     @map("medico_usuario_id")
  sucursalId                String     @map("sucursal_id")
  motivoCitaId              String?    @map("motivo_cita_id")
  motivoTexto               String?    @map("motivo_texto")
  consultorioRoom           String?    @map("consultorio_room")
  recursosClinicosAsignados Json       @default("[]") @map("recursos_clinicos_asignados")
  fechaProgramada           DateTime   @map("fecha_programada")
  duracionEstimadaMinutos   Int        @default(30) @map("duracion_estimada_minutos")
  estado                    CitaEstado @default(programada)
  pesoCheckinKg             Decimal?   @map("peso_checkin_kg") @db.Decimal(6, 2)
  temperaturaCheckinC       Decimal?   @map("temperatura_checkin_c") @db.Decimal(4, 1)
  preQuestionsResponses     Json?      @map("pre_questions_responses")
  notasRecepcion            String?    @map("notas_recepcion")
  fechaCheckinAt            DateTime?  @map("fecha_checkin_at")
  checkinPorId              String?    @map("checkin_por_id")
  fechaInicioConsulta       DateTime?  @map("fecha_inicio_consulta")
  fechaFinConsulta          DateTime?  @map("fecha_fin_consulta")
  tiempoEsperaMinutos       Int?       @map("tiempo_espera_minutos")
  duracionConsultaMinutos   Int?       @map("duracion_consulta_minutos")
  canceladoAt               DateTime?  @map("cancelado_at")
  canceladoPorId            String?    @map("cancelado_por_id")
  canceladoMotivo           String?    @map("cancelado_motivo")
  createdAt                 DateTime   @default(now()) @map("created_at")
  updatedAt                 DateTime   @updatedAt @map("updated_at")

  paciente     Paciente?           @relation(fields: [pacienteId], references: [id], onDelete: Restrict)
  mascota      Mascota?            @relation(fields: [mascotaId], references: [id], onDelete: Restrict)
  medico       Usuario             @relation("CitaMedico", fields: [medicoUsuarioId], references: [id], onDelete: Restrict)
  sucursal     Sucursal            @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  motivoCita   MotivoCitaCatalogo? @relation(fields: [motivoCitaId], references: [id], onDelete: SetNull)
  checkinPor   Usuario?            @relation("CitaCheckinPor", fields: [checkinPorId], references: [id], onDelete: SetNull)
  canceladoPor Usuario?            @relation("CitaCanceladaPor", fields: [canceladoPorId], references: [id], onDelete: SetNull)
  consulta     Consulta?

  @@unique([sucursalId, folio])
  @@index([medicoUsuarioId, fechaProgramada])
  @@index([pacienteId, fechaProgramada])
  @@index([mascotaId, fechaProgramada])
  @@index([estado, fechaProgramada])
  @@map("citas")
}

