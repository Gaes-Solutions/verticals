model Consulta {
  id                          String             @id @default(cuid())
  citaId                      String?            @unique @map("cita_id")
  pacienteId                  String?            @map("paciente_id")
  mascotaId                   String?            @map("mascota_id")
  medicoUsuarioId             String             @map("medico_usuario_id")
  enfermeraAsistenteId        String?            @map("enfermera_asistente_id")
  sucursalId                  String             @map("sucursal_id")
  fechaConsulta               DateTime           @map("fecha_consulta")
  duracionMinutos             Int?               @map("duracion_minutos")
  tipo                        ConsultaTipo       @default(seguimiento)
  motivoConsulta              String?            @map("motivo_consulta")
  sintomas                    Json               @default("[]")
  tiempoEvolucion             String?            @map("tiempo_evolucion")
