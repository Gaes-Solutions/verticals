}

model CategoriaPublica {
  id              String   @id @default(cuid())
  nombre          String
  slugSeo         String   @map("slug_seo")
  parentId        String?  @map("parent_id")
  descripcion     String?
  imagenUrl       String?  @map("imagen_url")
  orden           Int      @default(0)
  metaTitulo      String?  @map("meta_titulo")
  metaDescripcion String?  @map("meta_descripcion")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  parent              CategoriaPublica?   @relation("CategoriaPublicaJerarquia", fields: [parentId], references: [id], onDelete: SetNull)
  hijos               CategoriaPublica[]  @relation("CategoriaPublicaJerarquia")
  productosPublicados ProductoPublicado[]

  @@unique([slugSeo])
  @@index([parentId])
