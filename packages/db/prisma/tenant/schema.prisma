  @@id([listaPrecioId, varianteId])
  @@index([varianteId])
  @@map("lista_precio_items")
}

model ProductoPrecioEscalonado {
  id             String   @id @default(cuid())
  varianteId     String   @map("variante_id")
  nivel          Int
  cantidadMinima Decimal  @map("cantidad_minima") @db.Decimal(18, 3)
  cantidadMaxima Decimal? @map("cantidad_maxima") @db.Decimal(18, 3)
  precioUnitario Decimal  @map("precio_unitario") @db.Decimal(14, 4)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  variante ProductoVariante @relation(fields: [varianteId], references: [id], onDelete: Cascade)

  @@unique([varianteId, nivel])
  @@index([varianteId, isActive])
  @@map("producto_precios_escalonados")
}

model ReglaPrecio {
  id                            String           @id @default(cuid())
  codigo                        String           @unique
  nombre                        String
  descripcion                   String?
  tipo                          ReglaPrecioTipo
  prioridad                     Int              @default(100)
  stackable                     Boolean          @default(false)
  excluyeProductosConEscalonado Boolean          @default(true) @map("excluye_productos_con_escalonado")
  aplicaA                       ReglaPrecioCanal @default(todos) @map("aplica_a")
  condicion                     Json             @default("{}")
  accion                        Json             @default("{}")
  vigenteDesde                  DateTime?        @map("vigente_desde")
  vigenteHasta                  DateTime?        @map("vigente_hasta")
  diasSemana                    Json?            @map("dias_semana")
  horarios                      Json?
  usosMaxPorCliente             Int?             @map("usos_max_por_cliente")
  usosTotal                     Int?             @map("usos_total")
  usosActuales                  Int              @default(0) @map("usos_actuales")
  isActive                      Boolean          @default(true) @map("is_active")
  createdAt                     DateTime         @default(now()) @map("created_at")
  updatedAt                     DateTime         @updatedAt @map("updated_at")

  productos  ReglaPrecioProducto[]
  categorias ReglaPrecioCategoria[]

  @@index([tipo, isActive])
  @@index([vigenteDesde, vigenteHasta])
  @@map("reglas_precio")
}

model ReglaPrecioProducto {
  reglaId    String @map("regla_id")
  productoId String @map("producto_id")

  regla    ReglaPrecio @relation(fields: [reglaId], references: [id], onDelete: Cascade)
  producto Producto    @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@id([reglaId, productoId])
  @@map("regla_precio_productos")
}

model ReglaPrecioCategoria {
  reglaId     String @map("regla_id")
  categoriaId String @map("categoria_id")

  regla     ReglaPrecio @relation(fields: [reglaId], references: [id], onDelete: Cascade)
  categoria Categoria   @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@id([reglaId, categoriaId])
  @@map("regla_precio_categorias")
}

model CuponTenant {
  id                   String    @id @default(cuid())
  codigo               String    @unique
  nombre               String
  tipo                 CuponTipo
  valor                Decimal   @db.Decimal(14, 4)
  montoMinimoCompra    Decimal?  @map("monto_minimo_compra") @db.Decimal(14, 2)
  productosAplicables  Json      @default("[]") @map("productos_aplicables")
  categoriasAplicables Json      @default("[]") @map("categorias_aplicables")
  clientesAplicables   Json      @default("[]") @map("clientes_aplicables")
  usosMaxPorCliente    Int?      @map("usos_max_por_cliente")
  usosTotal            Int?      @map("usos_total")
  usosActuales         Int       @default(0) @map("usos_actuales")
  vigenteDesde         DateTime? @map("vigente_desde")
  vigenteHasta         DateTime? @map("vigente_hasta")
  isActive             Boolean   @default(true) @map("is_active")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("cupones_tenant")
}

// ============================================================
// 4.9 — Ventas, líneas, pagos (subset retail V1)
// Apartados, CxC, devoluciones parciales diferidos a Hito 2+
// CFDI integration diferido a Hito 1.5 (campo cfdiId nullable)
// ============================================================

enum VentaEstado {
  borrador
  cobrada
  cancelada
}

enum VentaCanal {
  pos
  ecommerce
  mayoreo
}

enum VentaPagoMetodo {
  efectivo
  tarjeta_debito
  tarjeta_credito
  transferencia
  vale
  monedero
  credito_fiado
  credito_b2b
  otro
}

model Venta {
  id                String      @id @default(cuid())
  folio             String
  sucursalId        String      @map("sucursal_id")
  cajaId            String?     @map("caja_id")
  usuarioId         String      @map("usuario_id")
  clienteId         String?     @map("cliente_id")
  clienteB2bId      String?     @map("cliente_b2b_id")
  estado            VentaEstado @default(borrador)
  canal             VentaCanal  @default(pos)
  moneda            String      @default("MXN")
  listaPrecioCodigo String?     @map("lista_precio_codigo")
  cuponCodigo       String?     @map("cupon_codigo")
  subtotal          Decimal     @default(0) @db.Decimal(14, 4)
  descuentoTotal    Decimal     @default(0) @map("descuento_total") @db.Decimal(14, 4)
  ivaTotal          Decimal     @default(0) @map("iva_total") @db.Decimal(14, 4)
  iepsTotal         Decimal     @default(0) @map("ieps_total") @db.Decimal(14, 4)
  total             Decimal     @default(0) @db.Decimal(14, 4)
  totalCobrado      Decimal     @default(0) @map("total_cobrado") @db.Decimal(14, 4)
  cambioDado        Decimal     @default(0) @map("cambio_dado") @db.Decimal(14, 4)
  observaciones     String?
  cfdiId            String?     @unique @map("cfdi_id")
  canceladaMotivo   String?     @map("cancelada_motivo")
  canceladaPorId    String?     @map("cancelada_por_id")
  cobradaAt         DateTime?   @map("cobrada_at")
  canceladaAt       DateTime?   @map("cancelada_at")
  apartadoId        String?     @unique @map("apartado_id")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  sucursal                 Sucursal              @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  caja                     Caja?                 @relation(fields: [cajaId], references: [id], onDelete: SetNull)
  usuario                  Usuario               @relation("VentaUsuarioCreador", fields: [usuarioId], references: [id], onDelete: Restrict)
  canceladaPor             Usuario?              @relation("VentaUsuarioCancelador", fields: [canceladaPorId], references: [id], onDelete: SetNull)
  cliente                  Cliente?              @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  clienteB2b               ClienteB2b?           @relation(fields: [clienteB2bId], references: [id], onDelete: SetNull)
  apartado                 Apartado?             @relation(fields: [apartadoId], references: [id], onDelete: SetNull)
  lineas                   VentaLinea[]
  pagos                    VentaPago[]
  cfdis                    Cfdi[]
  fiadoCargos              FiadoMovimiento[]
  cuentaCobrar             CuentaCobrar?
  devoluciones             Devolucion[]
  pedido                   Pedido?
  recargas                 Recarga[]
  hospitalizacionAlta      Hospitalizacion?      @relation("HospitalizacionVentaAlAlta")
  cargosHospitalFacturados CargoHospital[]       @relation("CargoHospitalFacturadoEnVenta")
  pedidoEcommerce          PedidoEcommerce?      @relation("PedidoEcommerceVenta")
  promocionesAplicadas     PromocionAplicacion[] @relation("VentaPromociones")

  @@unique([sucursalId, folio])
  @@index([estado, createdAt])
  @@index([sucursalId, cobradaAt])
  @@index([clienteId])
  @@index([clienteB2bId])
  @@map("ventas")
}

model VentaLinea {
  id                  String  @id @default(cuid())
  ventaId             String  @map("venta_id")
  numero              Int
  productoId          String  @map("producto_id")
  varianteId          String  @map("variante_id")
  loteId              String? @map("lote_id")
  serieId             String? @map("serie_id")
  cantidad            Decimal @db.Decimal(18, 3)
  precioUnitario      Decimal @map("precio_unitario") @db.Decimal(14, 4)
  precioOriginal      Decimal @map("precio_original") @db.Decimal(14, 4)
  descuentoUnitario   Decimal @default(0) @map("descuento_unitario") @db.Decimal(14, 4)
  subtotal            Decimal @db.Decimal(14, 4)
  ivaUnitario         Decimal @default(0) @map("iva_unitario") @db.Decimal(14, 4)
  ivaTotal            Decimal @default(0) @map("iva_total") @db.Decimal(14, 4)
  iepsUnitario        Decimal @default(0) @map("ieps_unitario") @db.Decimal(14, 4)
  iepsTotal           Decimal @default(0) @map("ieps_total") @db.Decimal(14, 4)
  totalLinea          Decimal @map("total_linea") @db.Decimal(14, 4)
  descuentosAplicados Json    @default("[]") @map("descuentos_aplicados")
  snapshotProducto    Json    @map("snapshot_producto")

  venta            Venta             @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  devolucionLineas DevolucionLinea[]

  @@unique([ventaId, numero])
  @@index([productoId])
  @@index([varianteId])
  @@map("venta_lineas")
}

model VentaPago {
  id                 String          @id @default(cuid())
  ventaId            String          @map("venta_id")
  metodo             VentaPagoMetodo
  monto              Decimal         @db.Decimal(14, 4)
  referencia         String?
  autorizacion       String?
  terminalReferencia String?         @map("terminal_referencia")
  ultimosCuatro      String?         @map("ultimos_cuatro")
  createdAt          DateTime        @default(now()) @map("created_at")

  venta Venta @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  @@index([ventaId])
  @@map("venta_pagos")
}

model VentaFolioCounter {
  sucursalId   String   @id @map("sucursal_id")
  ultimoNumero Int      @default(0) @map("ultimo_numero")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@map("venta_folio_counters")
}

// ============================================================
// 4.11 — Cortes X/Z + apertura/cierre caja + movimientos
// ============================================================

enum CajaAperturaEstado {
  abierta
  cerrada
}

enum CajaMovimientoTipo {
  entrada_fondo
  entrada_prestamo
  entrada_devolucion
  entrada_otro
  salida_retiro
  salida_gasto
  salida_deposito
  salida_otro
}

enum CorteTipo {
  X
  Z
}

model CajaApertura {
  id                    String             @id @default(cuid())
  cajaId                String             @map("caja_id")
  sucursalId            String             @map("sucursal_id")
  usuarioId             String             @map("usuario_id")
  montoInicial          Decimal            @map("monto_inicial") @db.Decimal(14, 4)
  observacionesApertura String?            @map("observaciones_apertura")
  estado                CajaAperturaEstado @default(abierta)
  cerradaAt             DateTime?          @map("cerrada_at")
  cerradaPorId          String?            @map("cerrada_por_id")
  cerradaForzosa        Boolean            @default(false) @map("cerrada_forzosa")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  caja        Caja             @relation(fields: [cajaId], references: [id], onDelete: Restrict)
  usuario     Usuario          @relation("CajaAperturaUsuario", fields: [usuarioId], references: [id], onDelete: Restrict)
  cerradaPor  Usuario?         @relation("CajaAperturaCerradaPor", fields: [cerradaPorId], references: [id], onDelete: SetNull)
  movimientos CajaMovimiento[]
  cortes      Corte[]
  recargas    Recarga[]

  @@index([cajaId, estado])
  @@index([sucursalId, estado])
  @@index([usuarioId, estado])
  @@map("caja_aperturas")
}

model CajaMovimiento {
  id         String             @id @default(cuid())
  aperturaId String             @map("apertura_id")
  tipo       CajaMovimientoTipo
  monto      Decimal            @db.Decimal(14, 4)
  motivo     String
  referencia String?
  usuarioId  String             @map("usuario_id")
  createdAt  DateTime           @default(now()) @map("created_at")

  apertura CajaApertura @relation(fields: [aperturaId], references: [id], onDelete: Restrict)
  usuario  Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([aperturaId, createdAt])
  @@map("caja_movimientos")
}

model Corte {
  id                  String    @id @default(cuid())
  aperturaId          String    @map("apertura_id")
  tipo                CorteTipo
  numero              Int
  desdeAt             DateTime  @map("desde_at")
  hastaAt             DateTime  @map("hasta_at")
  ventasCount         Int       @map("ventas_count")
  ventasCanceladas    Int       @default(0) @map("ventas_canceladas")
  ventasTotal         Decimal   @map("ventas_total") @db.Decimal(14, 4)
  efectivoEsperado    Decimal   @map("efectivo_esperado") @db.Decimal(14, 4)
  efectivoContado     Decimal   @map("efectivo_contado") @db.Decimal(14, 4)
  diferencia          Decimal   @db.Decimal(14, 4)
  desglosePorMetodo   Json      @map("desglose_por_metodo")
  desgloseMovimientos Json      @map("desglose_movimientos")
  denominaciones      Json
  observaciones       String?
  usuarioId           String    @map("usuario_id")
  createdAt           DateTime  @default(now()) @map("created_at")

  apertura CajaApertura @relation(fields: [aperturaId], references: [id], onDelete: Restrict)
  usuario  Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@unique([aperturaId, numero])
  @@index([aperturaId, tipo])
  @@map("cortes")
}

// ============================================================
// 4.19 — CFDI 4.0 emisión vía Facturama + autofactura QR
// Certificados .cer/.key NO almacenados V1 (Facturama panel los tiene)
// XML/PDF inline V1; S3 a V1.5
// ============================================================

enum CfdiAmbiente {
  sandbox
  prod
}

enum CfdiEstado {
  pendiente
  vigente
  cancelado
  error
}

enum CfdiTipoComprobante {
  I
  E
  T
  N
  P
}

enum CfdiMetodoPago {
  PUE
  PPD
}

model CfdiConfig {
  id                 String       @id @default(cuid())
  rfcEmisor          String       @map("rfc_emisor")
  razonSocialEmisor  String       @map("razon_social_emisor")
  regimenFiscalSat   String       @map("regimen_fiscal_sat")
  codigoPostalEmisor String       @map("codigo_postal_emisor")
  lugarExpedicion    String       @map("lugar_expedicion")
  serieDefault       String       @default("A") @map("serie_default")
  folioCounter       Int          @default(0) @map("folio_counter")
  facturamaApiKey    String       @map("facturama_api_key")
  facturamaAmbiente  CfdiAmbiente @default(sandbox) @map("facturama_ambiente")
  correoEmisor       String?      @map("correo_emisor")
  telefonoEmisor     String?      @map("telefono_emisor")
  autofacturaActiva  Boolean      @default(true) @map("autofactura_activa")
  diasAutofactura    Int          @default(30) @map("dias_autofactura")
  isActive           Boolean      @default(true) @map("is_active")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  @@unique([rfcEmisor])
  @@map("cfdi_config")
}

model Cfdi {
  id                       String              @id @default(cuid())
  ventaId                  String              @map("venta_id")
  devolucionId             String?             @unique @map("devolucion_id")
  tipoRelacionSat          String?             @map("tipo_relacion_sat")
  cfdiRelacionadoUuids     String[]            @default([]) @map("cfdi_relacionado_uuids")
  serie                    String
  folio                    String
  folioFiscal              String?             @unique @map("folio_fiscal")
  fechaEmision             DateTime            @default(now()) @map("fecha_emision")
  fechaTimbrado            DateTime?           @map("fecha_timbrado")
  tipoComprobante          CfdiTipoComprobante @default(I) @map("tipo_comprobante")
  metodoPago               CfdiMetodoPago      @default(PUE) @map("metodo_pago")
  formaPago                String              @map("forma_pago")
  usoCfdi                  String              @map("uso_cfdi")
  rfcEmisor                String              @map("rfc_emisor")
  razonSocialEmisor        String              @map("razon_social_emisor")
  regimenFiscalEmisor      String              @map("regimen_fiscal_emisor")
  lugarExpedicion          String              @map("lugar_expedicion")
  rfcReceptor              String              @map("rfc_receptor")
  razonSocialReceptor      String              @map("razon_social_receptor")
  codigoPostalReceptor     String              @map("codigo_postal_receptor")
  regimenFiscalReceptor    String              @map("regimen_fiscal_receptor")
  correoReceptor           String?             @map("correo_receptor")
  subtotal                 Decimal             @db.Decimal(14, 4)
  descuento                Decimal             @default(0) @db.Decimal(14, 4)
  iva                      Decimal             @default(0) @db.Decimal(14, 4)
  ieps                     Decimal             @default(0) @db.Decimal(14, 4)
  total                    Decimal             @db.Decimal(14, 4)
  moneda                   String              @default("MXN")
  estado                   CfdiEstado          @default(pendiente)
  facturamaId              String?             @map("facturama_id")
  selloDigitalCfdi         String?             @map("sello_digital_cfdi")
  selloSat                 String?             @map("sello_sat")
  noCertificadoSat         String?             @map("no_certificado_sat")
  cadenaOriginalSat        String?             @map("cadena_original_sat")
  xml                      String?             @db.Text
  pdfBase64                String?             @map("pdf_base64") @db.Text
  errorMensaje             String?             @map("error_mensaje")
  cancelacionMotivo        String?             @map("cancelacion_motivo")
  cancelacionFolioRelacion String?             @map("cancelacion_folio_relacion")
  canceladoAt              DateTime?           @map("cancelado_at")
  emitidoPorId             String              @map("emitido_por_id")
  canceladoPorId           String?             @map("cancelado_por_id")
  autofacturaToken         String?             @unique @map("autofactura_token")
  esAutofactura            Boolean             @default(false) @map("es_autofactura")
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")

  venta        Venta       @relation(fields: [ventaId], references: [id], onDelete: Restrict)
  emitidoPor   Usuario     @relation("CfdiEmitidoPor", fields: [emitidoPorId], references: [id], onDelete: Restrict)
  canceladoPor Usuario?    @relation("CfdiCanceladoPor", fields: [canceladoPorId], references: [id], onDelete: SetNull)
  devolucion   Devolucion? @relation("DevolucionCfdiEgreso", fields: [devolucionId], references: [id], onDelete: SetNull)

  @@unique([serie, folio])
  @@index([estado])
  @@index([ventaId])
  @@index([rfcReceptor])
  @@index([fechaEmision])
  @@map("cfdis")
}

// ============================================================
// 4.8 — Clientes B2C + grupos + etiquetas + direcciones + teléfonos + fiados
// B2B (clientes_b2b) → 2.2 ; vinculación PHR → Hito 3 Salud ; pgvector → V1.5
// ============================================================

enum ClienteTipo {
  publico_general
  frecuente
  vip
  empleado
}

enum FiadoEstado {
  activo
  liquidado
  incobrable
}

enum FiadoMovimientoTipo {
  cargo_venta
  abono_pago
  ajuste_positivo
  ajuste_negativo
  regularizacion_cxc
}

model Cliente {
  id                   String      @id @default(cuid())
  tipo                 ClienteTipo @default(frecuente)
  isDefault            Boolean     @default(false) @map("is_default")
  nombre               String
  apellidos            String?
  emailPrincipal       String?     @map("email_principal")
  passwordHash         String?     @map("password_hash")
  telefonoPrincipal    String?     @map("telefono_principal")
  fechaNacimiento      DateTime?   @map("fecha_nacimiento") @db.Date
  genero               String?
  rfc                  String?
  regimenFiscalSat     String?     @map("regimen_fiscal_sat")
  usoCfdiDefault       String?     @map("uso_cfdi_default")
  codigoPostalFiscal   String?     @map("codigo_postal_fiscal")
  direccionFacturacion Json?       @map("direccion_facturacion")
  clienteGrupoId       String?     @map("cliente_grupo_id")
  vendedorAsignadoId   String?     @map("vendedor_asignado_id")
  permiteFiado         Boolean     @default(false) @map("permite_fiado")
  limiteFiado          Decimal     @default(0) @map("limite_fiado") @db.Decimal(14, 2)
  aceptaMarketing      Boolean     @default(false) @map("acepta_marketing")
  idiomaPreferido      String      @default("es-MX") @map("idioma_preferido")
  notas                String?
  isActive             Boolean     @default(true) @map("is_active")
  archivedAt           DateTime?   @map("archived_at")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  grupo                 ClienteGrupo?            @relation(fields: [clienteGrupoId], references: [id], onDelete: SetNull)
  vendedorAsignado      Usuario?                 @relation("ClienteVendedorAsignado", fields: [vendedorAsignadoId], references: [id], onDelete: SetNull)
  direcciones           ClienteDireccion[]
  telefonos             ClienteTelefono[]
  etiquetas             ClienteEtiqueta[]
  fiado                 Fiado?
  ventas                Venta[]
  apartados             Apartado[]
  cuentasCobrar         CuentaCobrar[]
  pacientesTutor        Paciente[]               @relation("PacienteTutor")
  mascotasTutor         Mascota[]                @relation("MascotaTutor")
  carritosEcommerce     CarritoEcommerce[]
  pedidosEcommerce      PedidoEcommerce[]
  resenas               ProductoResena[]
  wishlists             Wishlist[]
  segmentosMiembro      SegmentoClienteMiembro[]
  metricasRfm           ClienteMetricasRfm?
  campanasEnvios        CampanaEnvio[]
  optOuts               ClienteOptOut[]
  loyalty               ClienteLoyalty[]
  notificaciones        Notificacion[]           @relation("NotificacionCliente")
  solicitudesDevolucion SolicitudDevolucion[]
  mensajesPedido        MensajePedido[]          @relation("MensajePedidoCliente")
  preguntasProducto     PreguntaProducto[]       @relation("PreguntaProductoCliente")

  @@unique([rfc])
  @@index([nombre])
  @@index([telefonoPrincipal])
  @@index([emailPrincipal])
  @@index([isActive])
  @@index([clienteGrupoId])
  @@map("clientes")
}

model ClienteDireccion {
  id                   String   @id @default(cuid())
  clienteId            String   @map("cliente_id")
  etiqueta             String
  calle                String
  numeroExterior       String?  @map("numero_exterior")
  numeroInterior       String?  @map("numero_interior")
  colonia              String?
  municipio            String?
  estado               String?
  codigoPostal         String?  @map("codigo_postal")
  pais                 String   @default("MX")
  referencias          String?
  lat                  Decimal? @db.Decimal(10, 7)
  lng                  Decimal? @db.Decimal(10, 7)
  isDefaultEnvio       Boolean  @default(false) @map("is_default_envio")
  isDefaultFacturacion Boolean  @default(false) @map("is_default_facturacion")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@map("cliente_direcciones")
}

model ClienteTelefono {
  id          String   @id @default(cuid())
  clienteId   String   @map("cliente_id")
  etiqueta    String
  telefono    String
  whatsapp    Boolean  @default(false)
  esPrincipal Boolean  @default(false) @map("es_principal")
  createdAt   DateTime @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([telefono])
  @@map("cliente_telefonos")
}

model ClienteGrupo {
  id                  String   @id @default(cuid())
  codigo              String   @unique
  nombre              String
  descripcion         String?
  descuentoDefaultPct Decimal? @map("descuento_default_pct") @db.Decimal(5, 2)
  listaPrecioCodigo   String?  @map("lista_precio_codigo")
  color               String?
  icono               String?
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  clientes Cliente[]

  @@map("cliente_grupos")
}

model ClienteEtiqueta {
  clienteId String   @map("cliente_id")
  etiqueta  String
  createdAt DateTime @default(now()) @map("created_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@id([clienteId, etiqueta])
  @@index([etiqueta])
  @@map("cliente_etiquetas")
}

model Fiado {
  id                    String      @id @default(cuid())
  clienteId             String      @unique @map("cliente_id")
  montoTotal            Decimal     @default(0) @map("monto_total") @db.Decimal(14, 2)
  fechaUltimoMovimiento DateTime?   @map("fecha_ultimo_movimiento")
  estado                FiadoEstado @default(activo)
  notas                 String?
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  cliente     Cliente           @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  movimientos FiadoMovimiento[]

  @@index([estado])
  @@map("fiados")
}

model FiadoMovimiento {
  id             String              @id @default(cuid())
  fiadoId        String              @map("fiado_id")
  tipo           FiadoMovimientoTipo
  monto          Decimal             @db.Decimal(14, 2)
  ventaId        String?             @map("venta_id")
  referenciaTipo String?             @map("referencia_tipo")
  referenciaId   String?             @map("referencia_id")
  metodoPago     String?             @map("metodo_pago")
  comprobanteUrl String?             @map("comprobante_url")
  motivo         String?
  usuarioId      String              @map("usuario_id")
  createdAt      DateTime            @default(now()) @map("created_at")

  fiado   Fiado   @relation(fields: [fiadoId], references: [id], onDelete: Restrict)
  venta   Venta?  @relation(fields: [ventaId], references: [id], onDelete: SetNull)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([fiadoId, createdAt])
  @@index([ventaId])
  @@map("fiado_movimientos")
}

// ============================================================
// 4.8.b — Clientes B2B + crédito formal + multi-vendedor con comisión
// Documentos S3 → V1.5 ; portal autoservicio (usuarios) → Hito 3
// ============================================================

enum CondicionesPagoB2b {
  contado
  credito
  mixto
}

enum FormatoFacturaB2b {
  pdf
  xml
  pdf_xml
}

enum VendedorB2bTipo {
  principal
  secundario
  cobranza
}

model ClienteB2b {
  id                         String             @id @default(cuid())
  razonSocial                String             @map("razon_social")
  nombreComercial            String?            @map("nombre_comercial")
  rfc                        String             @unique
  regimenFiscalSat           String             @map("regimen_fiscal_sat")
  usoCfdiDefault             String?            @map("uso_cfdi_default")
  codigoPostalFiscal         String?            @map("codigo_postal_fiscal")
  direccionFiscal            Json?              @map("direccion_fiscal")
  emailPrincipal             String?            @map("email_principal")
  telefonoPrincipal          String?            @map("telefono_principal")
  sitioWeb                   String?            @map("sitio_web")
  representanteLegal         String?            @map("representante_legal")
  industria                  String?
  tamanoNegocio              String?            @map("tamano_negocio")
  nivelMayoreoId             String?            @map("nivel_mayoreo_id")
  listaPrecioPrincipalCodigo String?            @map("lista_precio_principal_codigo")
  diasCreditoDefault         Int                @default(0) @map("dias_credito_default")
  condicionesPago            CondicionesPagoB2b @default(contado) @map("condiciones_pago")
  requiereOrdenCompra        Boolean            @default(false) @map("requiere_orden_compra")
  formatoFacturaPreferido    FormatoFacturaB2b  @default(pdf_xml) @map("formato_factura_preferido")
  requiereAprobacionInterna  Boolean            @default(false) @map("requiere_aprobacion_interna")
  montoAprobacionRequired    Decimal?           @map("monto_aprobacion_required") @db.Decimal(14, 2)
  notas                      String?
  isActive                   Boolean            @default(true) @map("is_active")
  archivedAt                 DateTime?          @map("archived_at")
  createdAt                  DateTime           @default(now()) @map("created_at")
  updatedAt                  DateTime           @updatedAt @map("updated_at")

  nivelMayoreo        NivelPrecioMayoreo?          @relation(fields: [nivelMayoreoId], references: [id], onDelete: SetNull)
  contactos           ClienteB2bContacto[]
  direcciones         ClienteB2bDireccion[]
  creditos            ClienteB2bCredito[]
  listasPrecio        ClienteB2bListaPrecio[]
  vendedoresAsignados ClienteB2bVendedorAsignado[]
  usuariosPortal      ClienteB2bUsuario[]
  ventas              Venta[]
  apartados           Apartado[]
  cuentasCobrar       CuentaCobrar[]
  cotizaciones        Cotizacion[]
  pedidos             Pedido[]

  @@index([razonSocial])
  @@index([rfc])
  @@index([nivelMayoreoId])
  @@index([isActive])
  @@map("clientes_b2b")
}

model ClienteB2bContacto {
  id           String   @id @default(cuid())
  clienteB2bId String   @map("cliente_b2b_id")
  nombre       String
  apellidos    String?
  puesto       String?
  email        String?
  telefono     String?
  whatsapp     Boolean  @default(false)
  esDecisor    Boolean  @default(false) @map("es_decisor")
  esPagador    Boolean  @default(false) @map("es_pagador")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  clienteB2b ClienteB2b @relation(fields: [clienteB2bId], references: [id], onDelete: Cascade)

  @@index([clienteB2bId])
  @@map("cliente_b2b_contactos")
}

model ClienteB2bDireccion {
  id                        String   @id @default(cuid())
  clienteB2bId              String   @map("cliente_b2b_id")
  etiqueta                  String
  calle                     String
  numeroExterior            String?  @map("numero_exterior")
  numeroInterior            String?  @map("numero_interior")
  colonia                   String?
  municipio                 String?
  estado                    String?
  codigoPostal              String?  @map("codigo_postal")
  pais                      String   @default("MX")
  referencias               String?
  lat                       Decimal? @db.Decimal(10, 7)
  lng                       Decimal? @db.Decimal(10, 7)
  contactoRecepcionNombre   String?  @map("contacto_recepcion_nombre")
  contactoRecepcionTelefono String?  @map("contacto_recepcion_telefono")
  horarioRecepcion          String?  @map("horario_recepcion")
  isDefaultEnvio            Boolean  @default(false) @map("is_default_envio")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  clienteB2b ClienteB2b @relation(fields: [clienteB2bId], references: [id], onDelete: Cascade)
  pedidos    Pedido[]

  @@index([clienteB2bId])
  @@map("cliente_b2b_direcciones")
}

model ClienteB2bCredito {
  id                      String    @id @default(cuid())
  clienteB2bId            String    @map("cliente_b2b_id")
  lineaAutorizada         Decimal   @map("linea_autorizada") @db.Decimal(14, 2)
  diasCredito             Int       @default(30) @map("dias_credito")
  tasaInteresMoraPct      Decimal?  @map("tasa_interes_mora_pct") @db.Decimal(5, 2)
  permiteFacturasVencidas Boolean   @default(false) @map("permite_facturas_vencidas")
  garantiaDocumentada     String?   @map("garantia_documentada")
  vigenteDesde            DateTime  @default(now()) @map("vigente_desde")
  vigenteHasta            DateTime? @map("vigente_hasta")
  aprobadoPorId           String    @map("aprobado_por_id")
  aprobadoAt              DateTime  @default(now()) @map("aprobado_at")
  notasAutorizacion       String?   @map("notas_autorizacion")
  isActive                Boolean   @default(true) @map("is_active")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  clienteB2b  ClienteB2b @relation(fields: [clienteB2bId], references: [id], onDelete: Cascade)
  aprobadoPor Usuario    @relation("ClienteB2bCreditoAprobadoPor", fields: [aprobadoPorId], references: [id], onDelete: Restrict)

  @@index([clienteB2bId, isActive])
  @@map("cliente_b2b_creditos")
}

model ClienteB2bListaPrecio {
  clienteB2bId  String    @map("cliente_b2b_id")
  listaPrecioId String    @map("lista_precio_id")
  prioridad     Int       @default(100)
  vigenteDesde  DateTime? @map("vigente_desde")
  vigenteHasta  DateTime? @map("vigente_hasta")
  createdAt     DateTime  @default(now()) @map("created_at")

  clienteB2b ClienteB2b  @relation(fields: [clienteB2bId], references: [id], onDelete: Cascade)
  lista      ListaPrecio @relation(fields: [listaPrecioId], references: [id], onDelete: Restrict)

  @@id([clienteB2bId, listaPrecioId])
  @@index([clienteB2bId])
  @@map("cliente_b2b_listas_precio")
}

model ClienteB2bVendedorAsignado {
  clienteB2bId        String          @map("cliente_b2b_id")
  usuarioId           String          @map("usuario_id")
  tipo                VendedorB2bTipo @default(principal)
  comisionPctOverride Decimal?        @map("comision_pct_override") @db.Decimal(5, 2)
  vigenteDesde        DateTime        @default(now()) @map("vigente_desde")
  vigenteHasta        DateTime?       @map("vigente_hasta")
  createdAt           DateTime        @default(now()) @map("created_at")

  clienteB2b ClienteB2b @relation(fields: [clienteB2bId], references: [id], onDelete: Cascade)
  usuario    Usuario    @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@id([clienteB2bId, usuarioId, tipo])
  @@index([usuarioId])
  @@map("cliente_b2b_vendedores_asignados")
}

enum ClienteB2bUsuarioRol {
  admin // gestiona usuarios de su empresa + todo lo de comprador
  comprador // catálogo, pedidos, cotizaciones, estado de cuenta
}

/// Usuario del portal B2B (login del cliente mayorista). El tenant los da de
/// alta (invitación) — no hay self-signup B2B.
model ClienteB2bUsuario {
  id           String               @id @default(cuid())
  clienteB2bId String               @map("cliente_b2b_id")
  nombre       String
  email        String               @unique
  passwordHash String               @map("password_hash")
  rol          ClienteB2bUsuarioRol @default(comprador)
  isActive     Boolean              @default(true) @map("is_active")
  lastLoginAt  DateTime?            @map("last_login_at")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  clienteB2b ClienteB2b @relation(fields: [clienteB2bId], references: [id], onDelete: Cascade)

  @@index([clienteB2bId])
  @@map("cliente_b2b_usuarios")
}

// ============================================================
// 4.9.b — Apartados (reserva stock + abonos + liquidación a venta)
// Job nocturno apartado_expirado → V2 con BullMQ ; documentos S3 → V1.5
// ============================================================

enum ApartadoEstado {
  activo
  liquidado_y_entregado
  cancelado
  expirado
}

enum ApartadoAbonoMetodo {
  efectivo
  tarjeta_debito
  tarjeta_credito
  transferencia
  vale
  otro
}

model Apartado {
  id                  String         @id @default(cuid())
  folio               String
  sucursalId          String         @map("sucursal_id")
  cajaId              String?        @map("caja_id")
  usuarioId           String         @map("usuario_id")
  clienteId           String?        @map("cliente_id")
  clienteB2bId        String?        @map("cliente_b2b_id")
  estado              ApartadoEstado @default(activo)
  moneda              String         @default("MXN")
  subtotal            Decimal        @db.Decimal(14, 4)
  descuentoTotal      Decimal        @default(0) @map("descuento_total") @db.Decimal(14, 4)
  ivaTotal            Decimal        @default(0) @map("iva_total") @db.Decimal(14, 4)
  iepsTotal           Decimal        @default(0) @map("ieps_total") @db.Decimal(14, 4)
  total               Decimal        @db.Decimal(14, 4)
  montoPagado         Decimal        @default(0) @map("monto_pagado") @db.Decimal(14, 4)
  fechaApartado       DateTime       @default(now()) @map("fecha_apartado")
  fechaLimite         DateTime       @map("fecha_limite")
  observaciones       String?
  politicaCancelacion String?        @map("politica_cancelacion")
  penaCancelacionPct  Decimal        @default(0) @map("pena_cancelacion_pct") @db.Decimal(5, 2)
  motivoCancelacion   String?        @map("motivo_cancelacion")
  canceladaPorId      String?        @map("cancelada_por_id")
  liquidadoAt         DateTime?      @map("liquidado_at")
  canceladoAt         DateTime?      @map("cancelado_at")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  sucursal     Sucursal        @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  caja         Caja?           @relation(fields: [cajaId], references: [id], onDelete: SetNull)
  usuario      Usuario         @relation("ApartadoUsuarioCreador", fields: [usuarioId], references: [id], onDelete: Restrict)
  canceladaPor Usuario?        @relation("ApartadoUsuarioCancelador", fields: [canceladaPorId], references: [id], onDelete: SetNull)
  cliente      Cliente?        @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  clienteB2b   ClienteB2b?     @relation(fields: [clienteB2bId], references: [id], onDelete: SetNull)
  lineas       ApartadoLinea[]
  abonos       ApartadoAbono[]
  venta        Venta?

  @@unique([sucursalId, folio])
  @@index([estado, fechaLimite])
  @@index([clienteId])
  @@index([clienteB2bId])
  @@map("apartados")
}

model ApartadoLinea {
  id                  String  @id @default(cuid())
  apartadoId          String  @map("apartado_id")
  numero              Int
  productoId          String  @map("producto_id")
  varianteId          String  @map("variante_id")
  cantidad            Decimal @db.Decimal(18, 3)
  precioUnitario      Decimal @map("precio_unitario") @db.Decimal(14, 4)
  precioOriginal      Decimal @map("precio_original") @db.Decimal(14, 4)
  descuentoUnitario   Decimal @default(0) @map("descuento_unitario") @db.Decimal(14, 4)
  subtotal            Decimal @db.Decimal(14, 4)
  ivaUnitario         Decimal @default(0) @map("iva_unitario") @db.Decimal(14, 4)
  ivaTotal            Decimal @default(0) @map("iva_total") @db.Decimal(14, 4)
  iepsUnitario        Decimal @default(0) @map("ieps_unitario") @db.Decimal(14, 4)
  iepsTotal           Decimal @default(0) @map("ieps_total") @db.Decimal(14, 4)
  totalLinea          Decimal @map("total_linea") @db.Decimal(14, 4)
  descuentosAplicados Json    @default("[]") @map("descuentos_aplicados")
  snapshotProducto    Json    @map("snapshot_producto")

  apartado Apartado         @relation(fields: [apartadoId], references: [id], onDelete: Cascade)
  variante ProductoVariante @relation(fields: [varianteId], references: [id], onDelete: Restrict)

  @@unique([apartadoId, numero])
  @@index([varianteId])
  @@map("apartado_lineas")
}

model ApartadoAbono {
  id             String              @id @default(cuid())
  apartadoId     String              @map("apartado_id")
  metodo         ApartadoAbonoMetodo
  monto          Decimal             @db.Decimal(14, 4)
  referencia     String?
  comprobanteUrl String?             @map("comprobante_url")
  usuarioId      String              @map("usuario_id")
  createdAt      DateTime            @default(now()) @map("created_at")

  apartado Apartado @relation(fields: [apartadoId], references: [id], onDelete: Cascade)
  usuario  Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([apartadoId, createdAt])
  @@map("apartado_abonos")
}

model ApartadoFolioCounter {
  sucursalId   String   @id @map("sucursal_id")
  ultimoNumero Int      @default(0) @map("ultimo_numero")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@map("apartado_folio_counters")
}

// ============================================================
// 4.9.c — Cuentas por Cobrar formal (CFDI-able)
// Distinta a Fiado informal (sin papeles, libreta de abarrotes)
// Job nocturno interés moratorio + recordatorios → V2 con BullMQ
// ============================================================

enum CxcTipoOrigen {
  venta_credito
  regularizacion_fiado
  manual
  apertura_saldo_inicial
}

enum CxcEstado {
  activa
  vencida
  liquidada
  incobrable
  condonada
}

model CuentaCobrar {
  id                      String        @id @default(cuid())
  folio                   String
  sucursalId              String        @map("sucursal_id")
  tipoOrigen              CxcTipoOrigen @map("tipo_origen")
  clienteId               String?       @map("cliente_id")
  clienteB2bId            String?       @map("cliente_b2b_id")
  ventaId                 String?       @unique @map("venta_id")
  vendedorId              String?       @map("vendedor_id")
  comisionPagadaAVendedor Boolean       @default(false) @map("comision_pagada_a_vendedor")
  montoOriginal           Decimal       @map("monto_original") @db.Decimal(14, 4)
  montoPagado             Decimal       @default(0) @map("monto_pagado") @db.Decimal(14, 4)
  currency                String        @default("MXN")
  fechaEmision            DateTime      @default(now()) @map("fecha_emision")
  fechaVencimiento        DateTime      @map("fecha_vencimiento")
  diasCreditoOtorgados    Int           @map("dias_credito_otorgados")
  tasaInteresMoraPct      Decimal?      @map("tasa_interes_mora_pct") @db.Decimal(5, 2)
  interesAcumulado        Decimal       @default(0) @map("interes_acumulado") @db.Decimal(14, 4)
  estado                  CxcEstado     @default(activa)
  notas                   String?
  liquidadaAt             DateTime?     @map("liquidada_at")
  condonadaAt             DateTime?     @map("condonada_at")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  sucursal   Sucursal    @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  cliente    Cliente?    @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  clienteB2b ClienteB2b? @relation(fields: [clienteB2bId], references: [id], onDelete: SetNull)
  venta      Venta?      @relation(fields: [ventaId], references: [id], onDelete: SetNull)
  vendedor   Usuario?    @relation("CuentaCobrarVendedor", fields: [vendedorId], references: [id], onDelete: SetNull)
  pagos      CxcPago[]

  @@unique([sucursalId, folio])
  @@index([estado, fechaVencimiento])
  @@index([clienteId])
  @@index([clienteB2bId])
  @@map("cuentas_cobrar")
}

model CxcPago {
  id             String          @id @default(cuid())
  cuentaCobrarId String          @map("cuenta_cobrar_id")
  metodo         VentaPagoMetodo
  monto          Decimal         @db.Decimal(14, 4)
  referencia     String?
  comprobanteUrl String?         @map("comprobante_url")
  usuarioId      String          @map("usuario_id")
  createdAt      DateTime        @default(now()) @map("created_at")

  cuentaCobrar CuentaCobrar @relation(fields: [cuentaCobrarId], references: [id], onDelete: Cascade)
  usuario      Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([cuentaCobrarId, createdAt])
  @@map("cxc_pagos")
}

model CxcFolioCounter {
  sucursalId   String   @id @map("sucursal_id")
  ultimoNumero Int      @default(0) @map("ultimo_numero")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@map("cxc_folio_counters")
}

// ============================================================
// 4.9.d — Devoluciones (Hito 2.5)
// ============================================================

enum DevolucionTipo {
  total
  parcial
}

enum DevolucionMotivo {
  defectuoso
  cambio_opinion
  talla_color
  error_cobro
  garantia
  otro
}

enum DevolucionReembolsoMetodo {
  efectivo
  tarjeta_misma
  saldo_a_favor
  vale
  transferencia
  nota_credito_cxc
  nota_credito_fiado
}

enum DevolucionEstado {
  procesada
  cancelada
}

model Devolucion {
  id                  String                    @id @default(cuid())
  folio               String
  sucursalId          String                    @map("sucursal_id")
  cajaId              String?                   @map("caja_id")
  usuarioId           String                    @map("usuario_id")
  ventaId             String                    @map("venta_id")
  tipo                DevolucionTipo
  motivo              DevolucionMotivo
  motivoDetalle       String?                   @map("motivo_detalle")
  subtotalDevuelto    Decimal                   @map("subtotal_devuelto") @db.Decimal(14, 4)
  descuentoDevuelto   Decimal                   @default(0) @map("descuento_devuelto") @db.Decimal(14, 4)
  ivaDevuelto         Decimal                   @default(0) @map("iva_devuelto") @db.Decimal(14, 4)
  iepsDevuelto        Decimal                   @default(0) @map("ieps_devuelto") @db.Decimal(14, 4)
  totalDevuelto       Decimal                   @map("total_devuelto") @db.Decimal(14, 4)
  metodoReembolso     DevolucionReembolsoMetodo @map("metodo_reembolso")
  referenciaReembolso String?                   @map("referencia_reembolso")
  reponeStockDefault  Boolean                   @default(true) @map("repone_stock_default")
  estado              DevolucionEstado          @default(procesada)
  notas               String?
  aprobadoPorId       String?                   @map("aprobado_por_id")
  procesadoAt         DateTime                  @default(now()) @map("procesado_at")
  canceladaMotivo     String?                   @map("cancelada_motivo")
  canceladoAt         DateTime?                 @map("cancelado_at")
  canceladoPorId      String?                   @map("cancelado_por_id")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")

  sucursal        Sucursal             @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  caja            Caja?                @relation(fields: [cajaId], references: [id], onDelete: SetNull)
  usuario         Usuario              @relation("DevolucionProcesadaPor", fields: [usuarioId], references: [id], onDelete: Restrict)
  venta           Venta                @relation(fields: [ventaId], references: [id], onDelete: Restrict)
  aprobadoPor     Usuario?             @relation("DevolucionAprobadaPor", fields: [aprobadoPorId], references: [id], onDelete: SetNull)
  canceladoPor    Usuario?             @relation("DevolucionCanceladaPor", fields: [canceladoPorId], references: [id], onDelete: SetNull)
  lineas          DevolucionLinea[]
  cfdiEgreso      Cfdi?                @relation("DevolucionCfdiEgreso")
  solicitudOrigen SolicitudDevolucion? @relation("SolicitudDevolucionGenerada")

  @@unique([sucursalId, folio])
  @@index([ventaId])
  @@index([sucursalId, procesadoAt])
  @@index([estado])
  @@map("devoluciones")
}

model DevolucionLinea {
  id               String            @id @default(cuid())
  devolucionId     String            @map("devolucion_id")
  ventaLineaId     String            @map("venta_linea_id")
  numero           Int
  varianteId       String            @map("variante_id")
  cantidadDevuelta Decimal           @map("cantidad_devuelta") @db.Decimal(18, 3)
  precioUnitario   Decimal           @map("precio_unitario") @db.Decimal(14, 4)
  subtotal         Decimal           @db.Decimal(14, 4)
  ivaTotal         Decimal           @default(0) @map("iva_total") @db.Decimal(14, 4)
  iepsTotal        Decimal           @default(0) @map("ieps_total") @db.Decimal(14, 4)
  totalLinea       Decimal           @map("total_linea") @db.Decimal(14, 4)
  reponeStock      Boolean           @map("repone_stock")
  motivoLinea      DevolucionMotivo? @map("motivo_linea")
  snapshotProducto Json              @map("snapshot_producto")

  devolucion Devolucion @relation(fields: [devolucionId], references: [id], onDelete: Cascade)
  ventaLinea VentaLinea @relation(fields: [ventaLineaId], references: [id], onDelete: Restrict)

  @@unique([devolucionId, numero])
  @@unique([devolucionId, ventaLineaId])
  @@index([ventaLineaId])
  @@index([varianteId])
  @@map("devolucion_lineas")
}

model DevolucionFolioCounter {
  sucursalId   String   @id @map("sucursal_id")
  ultimoNumero Int      @default(0) @map("ultimo_numero")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@map("devolucion_folio_counters")
}

// ============================================================
// 4.10 — Cotizaciones y Pedidos B2B (Hito 2.6)
// ============================================================

enum CotizacionEstado {
  borrador
  enviada
  aceptada
  rechazada
  vencida
  convertida
}

enum CotizacionCanalEnvio {
  email
  whatsapp
  descarga
  otro
}

enum PedidoEstado {
  creado
  preparando
  enviado
  entregado
  cancelado
}

enum PedidoEstadoAprobacion {
  no_requiere
  pendiente
  aprobada
  rechazada
}

model Cotizacion {
  id                String                @id @default(cuid())
  folio             String
  sucursalId        String                @map("sucursal_id")
  clienteB2bId      String                @map("cliente_b2b_id")
  vendedorId        String                @map("vendedor_id")
  estado            CotizacionEstado      @default(borrador)
  moneda            String                @default("MXN")
  listaPrecioCodigo String?               @map("lista_precio_codigo")
  cuponCodigo       String?               @map("cupon_codigo")
  subtotal          Decimal               @default(0) @db.Decimal(14, 4)
  descuentoTotal    Decimal               @default(0) @map("descuento_total") @db.Decimal(14, 4)
  ivaTotal          Decimal               @default(0) @map("iva_total") @db.Decimal(14, 4)
  iepsTotal         Decimal               @default(0) @map("ieps_total") @db.Decimal(14, 4)
  total             Decimal               @default(0) @db.Decimal(14, 4)
  fechaEmision      DateTime              @default(now()) @map("fecha_emision")
  fechaVencimiento  DateTime              @map("fecha_vencimiento")
  condicionesPago   String?               @map("condiciones_pago")
  notas             String?
  pdfFirmadoUrl     String?               @map("pdf_firmado_url")
  enviadoAt         DateTime?             @map("enviado_at")
  enviadoCanal      CotizacionCanalEnvio? @map("enviado_canal")
  enviadoDestino    String?               @map("enviado_destino")
  aceptadoAt        DateTime?             @map("aceptado_at")
  rechazadoAt       DateTime?             @map("rechazado_at")
  rechazoMotivo     String?               @map("rechazo_motivo")
  pedidoId          String?               @unique @map("pedido_id")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  sucursal   Sucursal          @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  clienteB2b ClienteB2b        @relation(fields: [clienteB2bId], references: [id], onDelete: Restrict)
  vendedor   Usuario           @relation("CotizacionVendedor", fields: [vendedorId], references: [id], onDelete: Restrict)
  lineas     CotizacionLinea[]
  pedido     Pedido?           @relation("PedidoFromCotizacion")

  @@unique([sucursalId, folio])
  @@index([estado, fechaVencimiento])
  @@index([clienteB2bId])
  @@index([vendedorId])
  @@map("cotizaciones")
}

model CotizacionLinea {
  id                  String  @id @default(cuid())
  cotizacionId        String  @map("cotizacion_id")
  numero              Int
  productoId          String  @map("producto_id")
  varianteId          String  @map("variante_id")
  cantidad            Decimal @db.Decimal(18, 3)
  precioUnitario      Decimal @map("precio_unitario") @db.Decimal(14, 4)
  precioOriginal      Decimal @map("precio_original") @db.Decimal(14, 4)
  descuentoUnitario   Decimal @default(0) @map("descuento_unitario") @db.Decimal(14, 4)
  subtotal            Decimal @db.Decimal(14, 4)
  ivaUnitario         Decimal @default(0) @map("iva_unitario") @db.Decimal(14, 4)
  ivaTotal            Decimal @default(0) @map("iva_total") @db.Decimal(14, 4)
  iepsUnitario        Decimal @default(0) @map("ieps_unitario") @db.Decimal(14, 4)
  iepsTotal           Decimal @default(0) @map("ieps_total") @db.Decimal(14, 4)
  totalLinea          Decimal @map("total_linea") @db.Decimal(14, 4)
  descuentosAplicados Json    @default("[]") @map("descuentos_aplicados")
  snapshotProducto    Json    @map("snapshot_producto")

  cotizacion Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  @@unique([cotizacionId, numero])
  @@index([varianteId])
  @@map("cotizacion_lineas")
}

model CotizacionFolioCounter {
  sucursalId   String   @id @map("sucursal_id")
  ultimoNumero Int      @default(0) @map("ultimo_numero")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@map("cotizacion_folio_counters")
}

model Pedido {
  id                   String                 @id @default(cuid())
  folio                String
  sucursalId           String                 @map("sucursal_id")
  clienteB2bId         String                 @map("cliente_b2b_id")
  vendedorId           String                 @map("vendedor_id")
  cotizacionId         String?                @unique @map("cotizacion_id")
  estado               PedidoEstado           @default(creado)
  estadoAprobacion     PedidoEstadoAprobacion @default(no_requiere) @map("estado_aprobacion")
  aprobadoPorId        String?                @map("aprobado_por_id")
  aprobadoAt           DateTime?              @map("aprobado_at")
  rechazadoMotivo      String?                @map("rechazado_motivo")
  moneda               String                 @default("MXN")
  subtotal             Decimal                @default(0) @db.Decimal(14, 4)
  descuentoTotal       Decimal                @default(0) @map("descuento_total") @db.Decimal(14, 4)
  ivaTotal             Decimal                @default(0) @map("iva_total") @db.Decimal(14, 4)
  iepsTotal            Decimal                @default(0) @map("ieps_total") @db.Decimal(14, 4)
  total                Decimal                @default(0) @db.Decimal(14, 4)
  ordenCompraCliente   String?                @map("orden_compra_cliente")
  direccionEnvioId     String?                @map("direccion_envio_id")
  paqueteria           String?
  trackingExterno      String?                @map("tracking_externo")
  trackingUrl          String?                @map("tracking_url")
  fechaEntregaEstimada DateTime?              @map("fecha_entrega_estimada")
  notas                String?
  ventaId              String?                @unique @map("venta_id")
  enviadoAt            DateTime?              @map("enviado_at")
  entregadoAt          DateTime?              @map("entregado_at")
  canceladoAt          DateTime?              @map("cancelado_at")
  canceladoPorId       String?                @map("cancelado_por_id")
  canceladoMotivo      String?                @map("cancelado_motivo")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")

  sucursal       Sucursal             @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  clienteB2b     ClienteB2b           @relation(fields: [clienteB2bId], references: [id], onDelete: Restrict)
  vendedor       Usuario              @relation("PedidoVendedor", fields: [vendedorId], references: [id], onDelete: Restrict)
  cotizacion     Cotizacion?          @relation("PedidoFromCotizacion", fields: [cotizacionId], references: [id], onDelete: SetNull)
  aprobadoPor    Usuario?             @relation("PedidoAprobadoPor", fields: [aprobadoPorId], references: [id], onDelete: SetNull)
  canceladoPor   Usuario?             @relation("PedidoCanceladoPor", fields: [canceladoPorId], references: [id], onDelete: SetNull)
  direccionEnvio ClienteB2bDireccion? @relation(fields: [direccionEnvioId], references: [id], onDelete: SetNull)
  venta          Venta?               @relation(fields: [ventaId], references: [id], onDelete: SetNull)
  lineas         PedidoLinea[]

  @@unique([sucursalId, folio])
  @@index([estado])
  @@index([estadoAprobacion])
  @@index([clienteB2bId])
  @@index([vendedorId])
  @@map("pedidos")
}

model PedidoLinea {
  id                  String  @id @default(cuid())
  pedidoId            String  @map("pedido_id")
  numero              Int
  productoId          String  @map("producto_id")
  varianteId          String  @map("variante_id")
  cantidad            Decimal @db.Decimal(18, 3)
  precioUnitario      Decimal @map("precio_unitario") @db.Decimal(14, 4)
  precioOriginal      Decimal @map("precio_original") @db.Decimal(14, 4)
  descuentoUnitario   Decimal @default(0) @map("descuento_unitario") @db.Decimal(14, 4)
  subtotal            Decimal @db.Decimal(14, 4)
  ivaUnitario         Decimal @default(0) @map("iva_unitario") @db.Decimal(14, 4)
  ivaTotal            Decimal @default(0) @map("iva_total") @db.Decimal(14, 4)
  iepsUnitario        Decimal @default(0) @map("ieps_unitario") @db.Decimal(14, 4)
  iepsTotal           Decimal @default(0) @map("ieps_total") @db.Decimal(14, 4)
  totalLinea          Decimal @map("total_linea") @db.Decimal(14, 4)
  descuentosAplicados Json    @default("[]") @map("descuentos_aplicados")
  snapshotProducto    Json    @map("snapshot_producto")

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@unique([pedidoId, numero])
  @@index([varianteId])
  @@map("pedido_lineas")
}

model PedidoFolioCounter {
  sucursalId   String   @id @map("sucursal_id")
  ultimoNumero Int      @default(0) @map("ultimo_numero")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@map("pedido_folio_counters")
}

// ============================================================
// 4.14 — Recargas tiempo aire + servicios (Hito 3.1 Abarrotes)
// ============================================================

enum RecargaProveedorCodigo {
  recargaki
  mtscellular
  pymeya
  mock
}

enum RecargaCompaniaCodigo {
  telcel
  movistar
  att
  bait
  unefon
  virgin_mobile
  maz
  spentel
  freedom_pop
  bait_pospago
}

enum RecargaTipo {
  tiempo_aire
  pago_servicio
}

enum RecargaEstado {
  pendiente
  exitosa
  fallida
  reembolsada
  disputada
}

model RecargaProveedorConfig {
  id                     String                 @id @default(cuid())
  proveedorCodigo        RecargaProveedorCodigo @unique @map("proveedor_codigo")
  apiUrl                 String?                @map("api_url")
  apiKeyEncrypted        String?                @map("api_key_encrypted")
  webhookSecretEncrypted String?                @map("webhook_secret_encrypted")
  isPrimario             Boolean                @default(false) @map("is_primario")
  isActive               Boolean                @default(true) @map("is_active")
  saldoPrefondeado       Decimal                @default(0) @map("saldo_prefondeado") @db.Decimal(14, 4)
  saldoAlertaMinimo      Decimal                @default(500) @map("saldo_alerta_minimo") @db.Decimal(14, 4)
  comisionProveedorPct   Decimal?               @map("comision_proveedor_pct") @db.Decimal(5, 2)
  lastRechargeAt         DateTime?              @map("last_recharge_at")
  totalConsumidoLifetime Decimal                @default(0) @map("total_consumido_lifetime") @db.Decimal(14, 4)
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")

  recargas Recarga[]

  @@index([isPrimario])
  @@index([isActive])
  @@map("recarga_proveedor_config")
}

model Recarga {
  id                  String                 @id @default(cuid())
  folio               String
  sucursalId          String                 @map("sucursal_id")
  cajaAperturaId      String?                @map("caja_apertura_id")
  usuarioId           String                 @map("usuario_id")
  ventaId             String?                @map("venta_id")
  tipo                RecargaTipo            @default(tiempo_aire)
  companiaCodigo      RecargaCompaniaCodigo  @map("compania_codigo")
  proveedorConfigId   String                 @map("proveedor_config_id")
  proveedorCodigo     RecargaProveedorCodigo @map("proveedor_codigo")
  numeroTelefonico    String                 @map("numero_telefonico")
  referenciaCapturada String?                @map("referencia_capturada")
  montoSolicitado     Decimal                @map("monto_solicitado") @db.Decimal(14, 4)
  montoCobradoCliente Decimal                @map("monto_cobrado_cliente") @db.Decimal(14, 4)
  comisionTenant      Decimal                @default(0) @map("comision_tenant") @db.Decimal(14, 4)
  comisionProveedor   Decimal                @default(0) @map("comision_proveedor") @db.Decimal(14, 4)
  costoRealTenant     Decimal                @map("costo_real_tenant") @db.Decimal(14, 4)
  folioProveedor      String?                @map("folio_proveedor")
  respuestaProveedor  Json?                  @map("respuesta_proveedor")
  estado              RecargaEstado          @default(pendiente)
  motivoFalla         String?                @map("motivo_falla")
  intentosTotales     Int                    @default(0) @map("intentos_totales")
  reembolsadaAt       DateTime?              @map("reembolsada_at")
  reembolsadaPorId    String?                @map("reembolsada_por_id")
  reembolsoMotivo     String?                @map("reembolso_motivo")
  disputadaAt         DateTime?              @map("disputada_at")
  disputaMotivo       String?                @map("disputa_motivo")
  procesadoAt         DateTime?              @map("procesado_at")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  sucursal        Sucursal               @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  cajaApertura    CajaApertura?          @relation(fields: [cajaAperturaId], references: [id], onDelete: SetNull)
  usuario         Usuario                @relation("RecargaProcesadaPor", fields: [usuarioId], references: [id], onDelete: Restrict)
  reembolsadaPor  Usuario?               @relation("RecargaReembolsadaPor", fields: [reembolsadaPorId], references: [id], onDelete: SetNull)
  venta           Venta?                 @relation(fields: [ventaId], references: [id], onDelete: SetNull)
  proveedorConfig RecargaProveedorConfig @relation(fields: [proveedorConfigId], references: [id], onDelete: Restrict)
  reintentos      RecargaReintento[]

  @@unique([sucursalId, folio])
  @@index([estado, createdAt])
  @@index([companiaCodigo])
  @@index([proveedorCodigo])
  @@index([numeroTelefonico])
  @@index([ventaId])
  @@map("recargas")
}

model RecargaReintento {
  id            String   @id @default(cuid())
  recargaId     String   @map("recarga_id")
  intentoNumero Int      @map("intento_numero")
  respuesta     Json?
  errorMensaje  String?  @map("error_mensaje")
  createdAt     DateTime @default(now()) @map("created_at")

  recarga Recarga @relation(fields: [recargaId], references: [id], onDelete: Cascade)

  @@unique([recargaId, intentoNumero])
  @@index([recargaId, createdAt])
  @@map("recarga_reintentos")
}

model RecargaFolioCounter {
  sucursalId   String   @id @map("sucursal_id")
  ultimoNumero Int      @default(0) @map("ultimo_numero")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@map("recarga_folio_counters")
}

// ============================================================
// 4.15 — Salud Humana V1 (Hito 3.2)
// Scope V1: Paciente local + Médico + Agenda + Cita + Consulta SOAP + Receta.
// Diferidos: PHR cross-tenant master DB, vacunas+cartilla+pediatría, motor
// reglas interacciones automático (V1 catálogo data, sin cruce auto).
// REGLA: NO IA clínica decisional — ni diagnóstico, ni dosis, ni interpretación.
// ============================================================

enum PacienteSexo {
  masculino
  femenino
  otro
  no_especificado
}

enum PacienteClasificacionRiesgo {
  bajo
  medio
  alto
  critico
}

enum ConsultaTipo {
  primera_vez
  seguimiento
  urgencia
  control_post_cirugia
  telemedicina
}

enum ConsultaPronostico {
  favorable
  reservado
  grave
  desconocido
}

enum ConsultaEstado {
  borrador
  firmada
  enmendada
  cancelada
}

enum CitaEstado {
  programada
  confirmada
  checkin
  en_consulta
  completada
  cancelada
  no_asistio
}

enum AgendaBloqueoTipo {
  vacaciones
  congreso
  personal
  incapacidad
  cerrado_sucursal
}

enum RecetaEstado {
  emitida
  surtida
  cancelada
  expirada
}

enum MedicamentoClasificacionCofepris {
  G_I
  G_II
  G_III
  G_IV
  G_V
  G_VI
  vet
  OTC
}

model Paciente {
  id                       String                       @id @default(cuid())
  numeroExpediente         String                       @map("numero_expediente")
  nombre                   String
  apellidoPaterno          String?                      @map("apellido_paterno")
  apellidoMaterno          String?                      @map("apellido_materno")
  fechaNacimiento          DateTime?                    @map("fecha_nacimiento")
  sexo                     PacienteSexo                 @default(no_especificado)
  curp                     String?
  rfc                      String?
  telefonoPrincipal        String?                      @map("telefono_principal")
  emailPrincipal           String?                      @map("email_principal")
  direccion                Json?
  ocupacion                String?
  estadoCivil              String?                      @map("estado_civil")
  contactoEmergenciaNombre String?                      @map("contacto_emergencia_nombre")
  contactoEmergenciaTel    String?                      @map("contacto_emergencia_tel")
  tipoSangre               String?                      @map("tipo_sangre")
  alergias                 Json                         @default("[]")
  antecedentesPatologicos  Json                         @default("[]") @map("antecedentes_patologicos")
  antecedentesFamiliares   Json                         @default("[]") @map("antecedentes_familiares")
  medicamentosCronicos     Json                         @default("[]") @map("medicamentos_cronicos")
  tutorClienteId           String?                      @map("tutor_cliente_id")
  medicoAsignadoId         String?                      @map("medico_asignado_id")
  etiquetas                Json                         @default("[]")
  notasInternas            String?                      @map("notas_internas")
  alertasPersonalizadas    Json                         @default("[]") @map("alertas_personalizadas")
  clasificacionRiesgo      PacienteClasificacionRiesgo? @map("clasificacion_riesgo")
  fechaPrimeraVisita       DateTime?                    @map("fecha_primera_visita")
  isActive                 Boolean                      @default(true) @map("is_active")
  archivedAt               DateTime?                    @map("archived_at")
  createdAt                DateTime                     @default(now()) @map("created_at")
  updatedAt                DateTime                     @updatedAt @map("updated_at")

  tutor             Cliente?             @relation("PacienteTutor", fields: [tutorClienteId], references: [id], onDelete: SetNull)
  medicoAsignado    Usuario?             @relation("PacienteMedicoAsignado", fields: [medicoAsignadoId], references: [id], onDelete: SetNull)
  citas             Cita[]
  consultas         Consulta[]
  recetas           Receta[]
  signosVitales     ConsultaSignoVital[]
  vacunaciones      Vacunacion[]
  hospitalizaciones Hospitalizacion[]
  signosHospital    SignoVitalHospital[] @relation("SignoVitalHospitalPaciente")

  @@unique([numeroExpediente])
  @@index([nombre, apellidoPaterno])
  @@index([curp])
  @@index([telefonoPrincipal])
  @@index([medicoAsignadoId])
  @@index([isActive])
  @@map("pacientes")
}

model Medico {
