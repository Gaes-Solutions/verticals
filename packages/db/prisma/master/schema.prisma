// Master DB schema — datos cross-tenant.
// Cada tenant tiene su propio schema postgres separado (ver tenant.template.prisma).
// Ver ADR-001 (multi-tenancy schema-per-tenant) y docs/analisis/04-modelo-datos/4.1-tenants-billing.md

generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/master"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_MASTER")
}

// Roles predefinidos gobernados por el SUPERADMIN, por vertical (o "todas").
// Se replican (mirror) como roles isPreset en el schema de cada tenant cuya
// vertical coincida; editar aquí propaga el cambio a todos (vínculo vivo).
model RolePlantilla {
  id          String   @id @default(cuid())
  vertical    String // TenantVertical (valor) o "todas"
  codigo      String
  nombre      String
  descripcion String?
  permisos    String[] @default([])
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([vertical, codigo])
  @@map("role_plantillas")
}

// Plan de subscripción (Hito 0 mínimo, se expande con billing/coupons en Hito 6)
model Plan {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  priceCents  Int      @map("price_cents")
  currency    String   @default("MXN")
  description String?
  tierOrder   Int      @default(0) @map("tier_order")
  isPublic    Boolean  @default(true) @map("is_public")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenants       Tenant[]
  features      PlanFeature[]
  prices        PlanPrice[]
  subscriptions Subscription[]

  @@map("plans")
}

// Tenant = una cuenta SaaS (un negocio cliente)
model Tenant {
  id                     String          @id @default(cuid())
  slug                   String          @unique
  name                   String
  legalName              String?         @map("legal_name")
  commercialName         String?         @map("commercial_name")
  rfc                    String?
  vertical               TenantVertical?
  verticalSubtype        String?         @map("vertical_subtype")
  country                String          @default("MX")
  currencyDefault        String          @default("MXN") @map("currency_default")
  languageDefault        String          @default("es-MX") @map("language_default")
  timezone               String          @default("America/Mexico_City")
  schemaName             String          @unique @map("schema_name")
  status                 TenantStatus    @default(trial)
  planId                 String          @map("plan_id")
  parentTenantId         String?         @map("parent_tenant_id")
  partnerId              String?         @map("partner_id")
  partnerAttributedUntil DateTime?       @map("partner_attributed_until")
  trialEndsAt            DateTime?       @map("trial_ends_at")
  onboardingCompletedAt  DateTime?       @map("onboarding_completed_at")
  healthScore            Int?            @map("health_score")
  healthScoreUpdatedAt   DateTime?       @map("health_score_updated_at")
  metadata               Json?
  deletedAt              DateTime?       @map("deleted_at")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")

  plan              Plan                  @relation(fields: [planId], references: [id])
  parentTenant      Tenant?               @relation("TenantPadreHijo", fields: [parentTenantId], references: [id])
  childTenants      Tenant[]              @relation("TenantPadreHijo")
  partner           Partner?              @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  subscriptions     Subscription[]
  invoices          Invoice[]
  paymentMethods    PaymentMethod[]
  couponRedemptions CouponRedemption[]
  adminUsers        TenantUserAdmin[]
  supportTickets    SupportTicket[]
  settingsMaster    TenantSettingsMaster?

  @@unique([rfc, country])
  @@index([status])
  @@index([parentTenantId])
  @@index([partnerId])
  @@index([deletedAt])
  @@map("tenants")
}

enum TenantStatus {
  trial
  active
  past_due
  suspended
  unpaid
  cancelled
  archived

  @@map("tenant_status")
}

enum TenantVertical {
  retail_mayoreo
  abarrotes
  salud_vet
  salud_humana
  despacho_contable
  otro

  @@map("tenant_vertical")
}

// Usuarios de GaesSoft (superadmin, soporte, billing). Distinto de los usuarios
// de cada tenant (que viven en el schema del tenant — análisis 4.6).
// Ver análisis 4.4 (soporte/audit) y flujo 10 (superadmin).
model AdminUser {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String    @map("password_hash")
  name           String
  role           AdminRole @default(superadmin)
  active         Boolean   @default(true)
  mfaSecret      String?   @map("mfa_secret")
  mfaVerifiedAt  DateTime? @map("mfa_verified_at")
  mfaBackupCodes String[]  @default([]) @map("mfa_backup_codes")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  refreshTokens   RefreshToken[]
  assignedTickets SupportTicket[]

  @@index([active])
  @@map("admin_users")
}

enum AdminRole {
  superadmin
  support
  billing

  @@map("admin_role")
}

// Refresh tokens persistidos para revocación (rotación + invalidación al logout).
// access JWT 15min queda en memoria del cliente; refresh 30d HttpOnly cookie.
model RefreshToken {
  id          String    @id @default(cuid())
  tokenHash   String    @unique @map("token_hash")
  adminUserId String    @map("admin_user_id")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  userAgent   String?   @map("user_agent")
  ipAddress   String?   @map("ip_address")
  createdAt   DateTime  @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// Audit log master (acciones cross-tenant: superadmin, billing, etc.)
// Tenant tiene su propio audit log en su schema.
model AuditLog {
  id         String   @id @default(cuid())
  actor      String
  action     String
  resource   String?
  resourceId String?  @map("resource_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([actor])
  @@index([resource, resourceId])
  @@map("audit_log")
}

// ============================================================
// HITO 3.5 — Programa Partners (cross-tenant, master DB)
// Modelo 4.2 · Análisis flujo 9 Partner Contador
// Comisión lifetime 25-40% según nivel sobre subscriptions
// pagadas de tenants referidos por el partner.
// ============================================================

enum PartnerTipo {
  contador
  integrador
  consultor
  agencia
  otro

  @@map("partner_tipo")
}

enum PartnerNivel {
  bronze
  silver
  gold
  diamond

  @@map("partner_nivel")
}

enum PartnerEstado {
  invitado
  activo
  pausado
  terminado

  @@map("partner_estado")
}

enum ReferralEstado {
  click
  signup
  trial
  paying
  churned

  @@map("referral_estado")
}

enum CommissionEstado {
  pendiente
  aprobada
  pagada
  rechazada
  disputada

  @@map("commission_estado")
}

enum PayoutEstado {
  pendiente
  en_proceso
  pagado
  fallido

  @@map("payout_estado")
}

enum PayoutMetodo {
  spei
  paypal
  stripe_connect
  otro

  @@map("payout_metodo")
}

model Partner {
  id                      String        @id @default(cuid())
  codigo                  String        @unique
  razonSocial             String        @map("razon_social")
  rfc                     String?       @unique
  emailContacto           String        @unique @map("email_contacto")
  telefonoContacto        String?       @map("telefono_contacto")
  passwordHash            String?       @map("password_hash")
  mfaSecret               String?       @map("mfa_secret")
  mfaVerifiedAt           DateTime?     @map("mfa_verified_at")
  mfaBackupCodes          String[]      @default([]) @map("mfa_backup_codes")
  lastLoginAt             DateTime?     @map("last_login_at")
  tipo                    PartnerTipo
  nivel                   PartnerNivel  @default(bronze)
  comisionPctOverride     Decimal?      @map("comision_pct_override") @db.Decimal(5, 2)
  estado                  PartnerEstado @default(invitado)
  termsAcceptedAt         DateTime?     @map("terms_accepted_at")
  isAcceptingNewReferrals Boolean       @default(true) @map("is_accepting_new_referrals")
  bankAccount             Json?         @map("bank_account")
  ciudad                  String?
  estadoMx                String?       @map("estado_mx")
  paginaWeb               String?       @map("pagina_web")
  notasInternas           String?       @map("notas_internas")
  fechaIngreso            DateTime?     @map("fecha_ingreso")
  fechaTerminacion        DateTime?     @map("fecha_terminacion")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  branding     PartnerBranding?
  links        PartnerLink[]
  referrals    Referral[]
  commissions  Commission[]
  payouts      Payout[]
  invitaciones PartnerInvitacion[]
  tenants      Tenant[]
  coupons      Coupon[]

  @@index([nivel])
  @@index([estado])
  @@index([tipo])
  @@map("partners")
}

model PartnerBranding {
  id              String   @id @default(cuid())
  partnerId       String   @unique @map("partner_id")
  slugPublico     String   @unique @map("slug_publico")
  logoUrl         String?  @map("logo_url")
  colorPrimario   String?  @map("color_primario")
  colorSecundario String?  @map("color_secundario")
  tagline         String?
  dominioPartner  String?  @unique @map("dominio_partner")
  bioPublica      String?  @map("bio_publica")
  isPublicoActivo Boolean  @default(false) @map("is_publico_activo")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("partner_branding")
}

model PartnerLink {
  id              String   @id @default(cuid())
  partnerId       String   @map("partner_id")
  slug            String   @unique
  nombre          String
  targetPath      String   @default("/signup") @map("target_path")
  utmSource       String?  @map("utm_source")
  utmMedium       String?  @map("utm_medium")
  utmCampaign     String?  @map("utm_campaign")
  isActive        Boolean  @default(true) @map("is_active")
  clicksTotal     Int      @default(0) @map("clicks_total")
  signupsTotal    Int      @default(0) @map("signups_total")
  paidConversions Int      @default(0) @map("paid_conversions")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  partner   Partner    @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  referrals Referral[]

  @@index([partnerId])
  @@map("partner_links")
}

model Referral {
  id                   String         @id @default(cuid())
  partnerId            String         @map("partner_id")
  linkId               String         @map("link_id")
  tenantId             String?        @unique @map("tenant_id")
  estado               ReferralEstado @default(click)
  cookieValue          String?        @unique @map("cookie_value")
  firstClickAt         DateTime?      @map("first_click_at")
  signupAt             DateTime?      @map("signup_at")
  trialStartAt         DateTime?      @map("trial_start_at")
  paidStartAt          DateTime?      @map("paid_start_at")
  churnedAt            DateTime?      @map("churned_at")
  atribucionExpiraEn   DateTime?      @map("atribucion_expira_en")
  ipPrimerClick        String?        @map("ip_primer_click")
  userAgentPrimerClick String?        @map("user_agent_primer_click")
  notas                String?
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  partner     Partner      @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  link        PartnerLink  @relation(fields: [linkId], references: [id], onDelete: Restrict)
  commissions Commission[]

  @@index([partnerId, estado])
  @@index([linkId])
  @@index([tenantId])
  @@index([atribucionExpiraEn])
  @@map("referrals")
}

model Commission {
  id                  String           @id @default(cuid())
  partnerId           String           @map("partner_id")
  referralId          String           @map("referral_id")
  tenantId            String           @map("tenant_id")
  periodoYyyymm       String           @map("periodo_yyyymm")
  montoBaseTenantPaid Decimal          @map("monto_base_tenant_paid") @db.Decimal(14, 2)
  porcentajeAplicado  Decimal          @map("porcentaje_aplicado") @db.Decimal(5, 2)
  montoComision       Decimal          @map("monto_comision") @db.Decimal(14, 2)
  moneda              String           @default("MXN")
  estado              CommissionEstado @default(pendiente)
  aprobadaAt          DateTime?        @map("aprobada_at")
  aprobadaPorAdminId  String?          @map("aprobada_por_admin_id")
  rechazadaAt         DateTime?        @map("rechazada_at")
  rechazadaMotivo     String?          @map("rechazada_motivo")
  pagadaAt            DateTime?        @map("pagada_at")
  payoutId            String?          @map("payout_id")
  notas               String?
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  partner  Partner  @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  referral Referral @relation(fields: [referralId], references: [id], onDelete: Restrict)
  payout   Payout?  @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@unique([referralId, periodoYyyymm])
  @@index([partnerId, periodoYyyymm])
  @@index([estado])
  @@index([payoutId])
  @@map("commissions")
}

model Payout {
  id                String       @id @default(cuid())
  partnerId         String       @map("partner_id")
  periodoYyyymm     String       @map("periodo_yyyymm")
  montoTotal        Decimal      @map("monto_total") @db.Decimal(14, 2)
  retencionIsr      Decimal      @default(0) @map("retencion_isr") @db.Decimal(14, 2)
  retencionIva      Decimal      @default(0) @map("retencion_iva") @db.Decimal(14, 2)
  montoNeto         Decimal      @map("monto_neto") @db.Decimal(14, 2)
  moneda            String       @default("MXN")
  metodoPago        PayoutMetodo
  estado            PayoutEstado @default(pendiente)
  folioBancario     String?      @map("folio_bancario")
  fechaPago         DateTime?    @map("fecha_pago")
  invoicePartnerUrl String?      @map("invoice_partner_url")
  motivoFalla       String?      @map("motivo_falla")
  creadoPorAdminId  String?      @map("creado_por_admin_id")
  notas             String?
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  partner     Partner      @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  commissions Commission[]

  @@unique([partnerId, periodoYyyymm])
  @@index([estado])
  @@map("payouts")
}

model PartnerInvitacion {
  id           String    @id @default(cuid())
  partnerId    String    @map("partner_id")
  token        String    @unique
  expiresAt    DateTime  @map("expires_at")
  acceptedAt   DateTime? @map("accepted_at")
  enviadaA     String    @map("enviada_a")
  enviadaPorId String?   @map("enviada_por_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([expiresAt])
  @@map("partner_invitaciones")
}

// ============================================================
// HITO 4.3 — Portal Doctoralia (Modelo 4.17, master DB cross-tenant)
// Perfiles médicos publicables + búsqueda + reseñas portables al médico.
// Reservas portal→tenant y telemedicina Daily.co diferidos a 4.3 fase 2.
// ============================================================

enum ProfesionalTipo {
  medico_humano
  veterinario
  dentista
  nutriologo
  psicologo
}

enum ProfesionalStatus {
  borrador
  en_revision
  publicado
  suspendido
  desactivado
}

enum ReviewModeracionStatus {
  pendiente
  auto_aprobado_ia
  revision_humana
  publicado
  rechazado
  denunciado_medico
}

/**
 * Paciente cross-tenant. Cimiento mínimo del PHR (4.4 lo expande con FHIR).
 */
enum PatientSexAtBirth {
  male
  female
  intersex
  unknown
}

enum FhirResourceType {
  Encounter
  Observation
  Condition
  AllergyIntolerance
  Immunization
  MedicationRequest
  DiagnosticReport
  Procedure
  CarePlan
}

enum PatientRecordStatus {
  draft
  final
  amended
  cancelled
}

enum ConsentScope {
  full_phr
  appointments_only
  prescriptions_only
  vaccines_only
}

enum ConsentSubjectType {
  patient
  pet
}

enum FamilyRelationship {
  mother
  father
  legal_guardian
  spouse
  caregiver
  sibling
  other
}

enum FamilyPermissionScope {
  full
  view_only
  agendar_only
  custom
}

enum FamilyConsentStatus {
  pending
  accepted
  revoked
}

enum PhrAuditActorType {
  patient
  tenant_user
  system
}

enum PhrAuditAction {
  viewed_summary
  viewed_record
  created_record
  modified_record
  shared_record
  exported_data
}

/**
 * Paciente del PHR cross-tenant. Identidad principal = phoneE164 (WhatsApp, ref.
 * Apple Health/Doctoralia). email opcional sigue sirviendo a reseñas Doctoralia.
 * Cifrado at-rest de campos sensibles diferido a hito de hardening.
 */
model PacienteMaster {
  id                String             @id @default(cuid())
  phoneE164         String?            @unique @map("phone_e164")
  email             String?            @unique
  nombre            String
  apellidos         String?
  preferredName     String?            @map("preferred_name")
  birthDate         DateTime?          @map("birth_date") @db.Date
  sexAtBirth        PatientSexAtBirth? @map("sex_at_birth")
  genderIdentity    String?            @map("gender_identity")
  rfc               String?
  curp              String?
  country           String             @default("MX")
  address           Json?
  bloodType         String?            @map("blood_type")
  languagePreferred String             @default("es-MX") @map("language_preferred")
  weightKg          Decimal?           @map("weight_kg") @db.Decimal(6, 2)
  heightCm          Decimal?           @map("height_cm") @db.Decimal(6, 2)
  metadata          Json?
  telefono          String?
  otpVerificadoAt   DateTime?          @map("otp_verificado_at")
  archivedAt        DateTime?          @map("archived_at")
  deletedAt         DateTime?          @map("deleted_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  reviews      PublicReview[]
  logins       PatientLogin[]
  records      PatientRecord[]
  consents     PatientConsent[]
  emergencyQr  PatientEmergencyQr?
  auditLogs    PatientAuditLog[]
  dependientes PatientFamily[]     @relation("dependiente")
  tutorias     PatientFamily[]     @relation("tutor")

  @@index([email])
  @@index([phoneE164])
  @@index([rfc, country])
  @@index([curp])
  @@map("pacientes_master")
}

model PatientLogin {
  id                 String    @id @default(cuid())
  patientId          String    @map("patient_id")
  deviceFingerprint  String    @map("device_fingerprint")
  deviceName         String?   @map("device_name")
  deviceTrustedUntil DateTime? @map("device_trusted_until")
  lastOtpSentAt      DateTime? @map("last_otp_sent_at")
  otpMethod          String?   @map("otp_method")
  lastLoginAt        DateTime? @map("last_login_at")
  lastLoginIp        String?   @map("last_login_ip")
  revokedAt          DateTime? @map("revoked_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  patient PacienteMaster @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, deviceFingerprint])
  @@index([patientId])
  @@map("patient_logins")
}

/**
 * Reto OTP para login sin contraseña. Se guarda el hash del código (no el código)
 * y expira. V1 envía vía mensajeria mock (WhatsApp).
 */
model PatientAuthChallenge {
  id         String    @id @default(cuid())
  phoneE164  String    @map("phone_e164")
  codeHash   String    @map("code_hash")
  method     String    @default("whatsapp")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([phoneE164, consumedAt])
  @@map("patient_auth_challenges")
}

model PatientFamily {
  id                           String                @id @default(cuid())
  dependienteId                String                @map("dependiente_id")
  tutorId                      String                @map("tutor_id")
  relationshipType             FamilyRelationship    @map("relationship_type")
  permissionScope              FamilyPermissionScope @default(view_only) @map("permission_scope")
  permissionDetails            Json?                 @map("permission_details")
  consentStatus                FamilyConsentStatus   @default(pending) @map("consent_status")
  consentRequiredFromDependent Boolean               @default(false) @map("consent_required_from_dependent")
  consentAcceptedAt            DateTime?             @map("consent_accepted_at")
  validUntil                   DateTime?             @map("valid_until")
  createdAt                    DateTime              @default(now()) @map("created_at")
  updatedAt                    DateTime              @updatedAt @map("updated_at")

  dependiente PacienteMaster @relation("dependiente", fields: [dependienteId], references: [id], onDelete: Cascade)
  tutor       PacienteMaster @relation("tutor", fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([dependienteId, tutorId])
  @@index([tutorId])
  @@map("patient_family")
}

/**
 * Consentimiento del paciente/tutor a un tenant para leer/escribir PHR.
 * Máx 1 activo por (subjectType, subjectId, tenantId) — enforced en servicio.
 */
model PatientConsent {
  id           String             @id @default(cuid())
  subjectType  ConsentSubjectType @default(patient) @map("subject_type")
  subjectId    String             @map("subject_id")
  patientId    String             @map("patient_id")
  tenantId     String             @map("tenant_id")
  scope        ConsentScope       @default(full_phr)
  revocable    Boolean            @default(true)
  termsVersion String             @default("v1") @map("terms_version")
  ipAtGrant    String?            @map("ip_at_grant")
  grantedAt    DateTime           @default(now()) @map("granted_at")
  revokedAt    DateTime?          @map("revoked_at")

  patient PacienteMaster @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([subjectType, subjectId, tenantId])
  @@index([tenantId])
  @@map("patient_consents")
}

/**
 * Evento clínico cross-tenant en formato FHIR R4 (JSONB). Lo publica la clínica
 * (tenant) con consent; el portal del paciente lo lee cross-tenant.
 */
model PatientRecord {
  id                 String              @id @default(cuid())
  patientId          String              @map("patient_id")
  tenantId           String              @map("tenant_id")
  createdByUserId    String?             @map("created_by_user_id")
  resourceType       FhirResourceType    @map("resource_type")
  resourceSubtype    String?             @map("resource_subtype")
  effectiveDate      DateTime            @map("effective_date")
  status             PatientRecordStatus @default(final)
  data               Json
  summaryText        String?             @map("summary_text")
  isCritical         Boolean             @default(false) @map("is_critical")
  isVisibleToPatient Boolean             @default(true) @map("is_visible_to_patient")
  parentRecordId     String?             @map("parent_record_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  patient PacienteMaster @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, effectiveDate])
  @@index([patientId, resourceType, effectiveDate])
  @@index([tenantId, createdAt])
  @@index([isCritical, patientId])
  @@map("patient_records")
}

model PatientEmergencyQr {
  id            String   @id @default(cuid())
  patientId     String   @unique @map("patient_id")
  qrToken       String   @unique @map("qr_token")
  isActive      Boolean  @default(true) @map("is_active")
  visibleFields Json     @default("[]") @map("visible_fields")
  regeneratedAt DateTime @default(now()) @map("regenerated_at")
  createdAt     DateTime @default(now()) @map("created_at")

  patient PacienteMaster @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_emergency_qr")
}

/**
 * Bitácora append-only de accesos al PHR (LFPDPPP + ARCO). Toda lectura
 * cross-tenant escribe aquí.
 */
model PatientAuditLog {
  id           String             @id @default(cuid())
  patientId    String             @map("patient_id")
  subjectType  ConsentSubjectType @default(patient) @map("subject_type")
  subjectId    String             @map("subject_id")
  tenantId     String?            @map("tenant_id")
  actorType    PhrAuditActorType  @map("actor_type")
  userId       String?            @map("user_id")
  action       PhrAuditAction
  resourceType String?            @map("resource_type")
  resourceId   String?            @map("resource_id")
  reason       String?
  ipAddress    String?            @map("ip_address")
  userAgent    String?            @map("user_agent")
  createdAt    DateTime           @default(now()) @map("created_at")

  patient PacienteMaster @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@index([tenantId, createdAt])
  @@map("patient_audit_log")
}

model PublicProfessional {
  id                   String            @id @default(cuid())
  tenantIdPrincipal    String            @map("tenant_id_principal")
  tenantIdsAdicionales Json              @default("[]") @map("tenant_ids_adicionales")
  medicoIdLocal        String?           @map("medico_id_local")
  tipo                 ProfesionalTipo
  nombrePublico        String            @map("nombre_publico")
  slugSeo              String            @unique @map("slug_seo")
  cedulaProfesional    String?           @map("cedula_profesional")
  cedulaEspecialidad   String?           @map("cedula_especialidad")
  especialidades       Json              @default("[]")
  validadaSsaAt        DateTime?         @map("validada_ssa_at")
  validadaPorAdminAt   DateTime?         @map("validada_por_admin_at")
  fotoPerfilUrl        String?           @map("foto_perfil_url")
  bioCorta             String?           @map("bio_corta")
  bioLarga             String?           @map("bio_larga")
  anosExperiencia      Int?              @map("anos_experiencia")
  idiomas              Json              @default("[\"es-MX\"]")
  genero               String?
  atiendeNinos         Boolean           @default(true) @map("atiende_ninos")
  atiendeAdultos       Boolean           @default(true) @map("atiende_adultos")
  aceptaTelemedicina   Boolean           @default(false) @map("acepta_telemedicina")
  aceptaMismoDia       Boolean           @default(false) @map("acepta_mismo_dia")
  status               ProfesionalStatus @default(borrador)
  scorePromedio        Decimal           @default(0) @map("score_promedio") @db.Decimal(3, 2)
  totalResenas         Int               @default(0) @map("total_resenas")
  feePlataformaPct     Decimal           @default(5) @map("fee_plataforma_pct") @db.Decimal(5, 2)
  archivedAt           DateTime?         @map("archived_at")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  ubicaciones PublicProfessionalLocation[]
  reviews     PublicReview[]
  searchIndex PublicProfessionalSearchIndex?

  @@unique([tenantIdPrincipal, medicoIdLocal])
  @@index([tipo, status])
  @@index([cedulaProfesional])
  @@map("public_professionals")
}

model PublicProfessionalLocation {
  id              String   @id @default(cuid())
  professionalId  String   @map("professional_id")
  tenantId        String   @map("tenant_id")
  nombreLugar     String   @map("nombre_lugar")
  direccion       String?
  lat             Decimal? @db.Decimal(10, 7)
  lng             Decimal? @db.Decimal(10, 7)
  ciudad          String
  estado          String
  colonia         String?
  cp              String?
  telefonoPublico String?  @map("telefono_publico")
  horarioAtencion Json?    @map("horario_atencion")
  esPrincipal     Boolean  @default(false) @map("es_principal")
  activa          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  professional PublicProfessional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@index([ciudad, estado])
  @@map("public_professional_locations")
}

model PublicReview {
  id                String                 @id @default(cuid())
  professionalId    String                 @map("professional_id")
  pacienteMasterId  String                 @map("paciente_master_id")
  bookingId         String?                @map("booking_id")
  verificada        Boolean                @default(false)
  ratingGeneral     Int                    @map("rating_general")
  ratingPuntualidad Int?                   @map("rating_puntualidad")
  ratingExplicacion Int?                   @map("rating_explicacion")
  ratingTrato       Int?                   @map("rating_trato")
  comentario        String?
  moderacionStatus  ReviewModeracionStatus @default(pendiente) @map("moderacion_status")
  moderacionIaScore Json?                  @map("moderacion_ia_score")
  publicadaAt       DateTime?              @map("publicada_at")
  helpfulCount      Int                    @default(0) @map("helpful_count")
  reportadaCount    Int                    @default(0) @map("reportada_count")
  respuestaMedico   String?                @map("respuesta_medico")
  arcoAnonymizedAt  DateTime?              @map("arco_anonymized_at")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  professional PublicProfessional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  paciente     PacienteMaster     @relation(fields: [pacienteMasterId], references: [id], onDelete: Restrict)

  @@index([professionalId, moderacionStatus])
  @@index([pacienteMasterId])
  @@map("public_reviews")
}

model PublicProfessionalSearchIndex {
  professionalId     String          @id @map("professional_id")
  searchText         String          @map("search_text")
  ciudad             String?
  estado             String?
  tipo               ProfesionalTipo
  scoreRanking       Decimal         @default(0) @map("score_ranking") @db.Decimal(8, 4)
  aceptaTelemedicina Boolean         @default(false) @map("acepta_telemedicina")
  aceptaMismoDia     Boolean         @default(false) @map("acepta_mismo_dia")
  idiomas            Json            @default("[]")
  atiendeNinos       Boolean         @default(true) @map("atiende_ninos")
  atiendeAdultos     Boolean         @default(true) @map("atiende_adultos")
  refreshedAt        DateTime        @default(now()) @map("refreshed_at")

  professional PublicProfessional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([ciudad, estado])
  @@index([tipo])
  @@index([scoreRanking])
  @@map("public_professional_search_index")
}

// ─────────────────────────────────────────────────────────────────────────────
// Billing del SaaS (Hito 6, Modelo 4.1)
// Stripe-style billing adaptado a México: CFDI propio + dual provider + cupones
// ─────────────────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  paused
  unpaid

  @@map("subscription_status")
}

enum SubscriptionInterval {
  monthly
  yearly

  @@map("subscription_interval")
}

enum InvoiceStatus {
  draft
  open
  paid
  void
  uncollectible

  @@map("invoice_status")
}

enum InvoicePaymentStatus {
  pending
  succeeded
  failed
  refunded

  @@map("invoice_payment_status")
}

enum PaymentMethodType {
  card
  oxxo
  spei
  manual

  @@map("payment_method_type")
}

enum CouponDiscountType {
  percent
  fixed

  @@map("coupon_discount_type")
}

enum CouponDuration {
  once
  repeating
  forever

  @@map("coupon_duration")
}

enum AdminTenantRole {
  owner
  billing_only
  viewer

  @@map("admin_tenant_role")
}

/**
 * Características y límites por plan (gating dinámico sin código duro).
 */
model PlanFeature {
  id         String   @id @default(cuid())
  planId     String   @map("plan_id")
  featureKey String   @map("feature_key")
  value      String
  valueType  String   @default("string") @map("value_type")
  createdAt  DateTime @default(now()) @map("created_at")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@map("plan_features")
}

/**
 * Precio por (moneda, intervalo) — multi-currency desde día 1.
 */
model PlanPrice {
  id          String               @id @default(cuid())
  planId      String               @map("plan_id")
  currency    String
  interval    SubscriptionInterval
  unitAmount  Int                  @map("unit_amount")
  taxBehavior String               @default("inclusive") @map("tax_behavior")
  isActive    Boolean              @default(true) @map("is_active")
  createdAt   DateTime             @default(now()) @map("created_at")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, currency, interval])
  @@map("plan_prices")
}

model Subscription {
  id                     String               @id @default(cuid())
  tenantId               String               @map("tenant_id")
  planId                 String               @map("plan_id")
  status                 SubscriptionStatus   @default(trialing)
  currency               String
  interval               SubscriptionInterval @default(monthly)
  currentPeriodStart     DateTime             @map("current_period_start")
  currentPeriodEnd       DateTime             @map("current_period_end")
  trialStart             DateTime?            @map("trial_start")
  trialEnd               DateTime?            @map("trial_end")
  canceledAt             DateTime?            @map("canceled_at")
  cancelAtPeriodEnd      Boolean              @default(false) @map("cancel_at_period_end")
  pauseCollectionUntil   DateTime?            @map("pause_collection_until")
  discountCouponId       String?              @map("discount_coupon_id")
  externalSubscriptionId String?              @map("external_subscription_id")
  externalProvider       String?              @map("external_provider")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan              Plan               @relation(fields: [planId], references: [id])
  discountCoupon    Coupon?            @relation(fields: [discountCouponId], references: [id])
  items             SubscriptionItem[]
  invoices          Invoice[]
  couponRedemptions CouponRedemption[]

  @@index([tenantId, status])
  @@index([status, currentPeriodEnd])
  @@map("subscriptions")
}

model SubscriptionItem {
  id             String   @id @default(cuid())
  subscriptionId String   @map("subscription_id")
  type           String
  quantity       Int      @default(1)
  unitAmount     Int      @map("unit_amount")
  externalItemId String?  @map("external_item_id")
  createdAt      DateTime @default(now()) @map("created_at")

  subscription Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]

  @@index([subscriptionId])
  @@map("subscription_items")
}

model Invoice {
  id                String        @id @default(cuid())
  tenantId          String        @map("tenant_id")
  subscriptionId    String?       @map("subscription_id")
  invoiceNumber     String        @unique @map("invoice_number")
  status            InvoiceStatus @default(open)
  periodStart       DateTime?     @map("period_start")
  periodEnd         DateTime?     @map("period_end")
  subtotal          Int
  tax               Int           @default(0)
  total             Int
  currency          String
  dueDate           DateTime      @map("due_date")
  paidAt            DateTime?     @map("paid_at")
  attempts          Int           @default(0)
  nextRetryAt       DateTime?     @map("next_retry_at")
  cfdiUuid          String?       @map("cfdi_uuid")
  cfdiPdfUrl        String?       @map("cfdi_pdf_url")
  cfdiXmlUrl        String?       @map("cfdi_xml_url")
  externalInvoiceId String?       @map("external_invoice_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription?    @relation(fields: [subscriptionId], references: [id])
  items        InvoiceItem[]
  payments     InvoicePayment[]

  @@index([tenantId, status, dueDate])
  @@index([status, nextRetryAt])
  @@map("invoices")
}

model InvoiceItem {
  id                 String   @id @default(cuid())
  invoiceId          String   @map("invoice_id")
  description        String
  quantity           Int      @default(1)
  unitAmount         Int      @map("unit_amount")
  amount             Int
  taxRate            Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  subscriptionItemId String?  @map("subscription_item_id")
  createdAt          DateTime @default(now()) @map("created_at")

  invoice          Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  subscriptionItem SubscriptionItem? @relation(fields: [subscriptionItemId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model InvoicePayment {
  id               String               @id @default(cuid())
  invoiceId        String               @map("invoice_id")
  amount           Int
  currency         String
  paymentMethodId  String?              @map("payment_method_id")
  status           InvoicePaymentStatus @default(pending)
  externalChargeId String?              @map("external_charge_id")
  failureReason    String?              @map("failure_reason")
  paidAt           DateTime?            @map("paid_at")
  createdAt        DateTime             @default(now()) @map("created_at")

  invoice       Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  @@index([invoiceId])
  @@index([status])
  @@map("invoice_payments")
}

model PaymentMethod {
  id               String            @id @default(cuid())
  tenantId         String            @map("tenant_id")
  type             PaymentMethodType
  isDefault        Boolean           @default(false) @map("is_default")
  externalMethodId String?           @map("external_method_id")
  last4            String?
  brand            String?
  expMonth         Int?              @map("exp_month")
  expYear          Int?              @map("exp_year")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments InvoicePayment[]

  @@index([tenantId, isDefault])
  @@map("payment_methods")
}

model Coupon {
  id                String             @id @default(cuid())
  code              String             @unique
  name              String
  partnerId         String?            @map("partner_id")
  discountType      CouponDiscountType @map("discount_type")
  discountValue     Int                @map("discount_value")
  currency          String?
  duration          CouponDuration     @default(once)
  durationInMonths  Int?               @map("duration_in_months")
  maxRedemptions    Int?               @map("max_redemptions")
  timesRedeemed     Int                @default(0) @map("times_redeemed")
  applicablePlanIds Json               @default("[]") @map("applicable_plan_ids")
  validFrom         DateTime?          @map("valid_from")
  validUntil        DateTime?          @map("valid_until")
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  partner       Partner?           @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  redemptions   CouponRedemption[]
  subscriptions Subscription[]

  @@index([isActive, validUntil])
  @@map("coupons")
}

model CouponRedemption {
  id                  String   @id @default(cuid())
  couponId            String   @map("coupon_id")
  tenantId            String   @map("tenant_id")
  subscriptionId      String?  @map("subscription_id")
  discountAmountTotal Int      @default(0) @map("discount_amount_total")
  redeemedAt          DateTime @default(now()) @map("redeemed_at")

  coupon       Coupon        @relation(fields: [couponId], references: [id], onDelete: Cascade)
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([couponId, tenantId])
  @@map("coupon_redemptions")
}

/**
 * Quien administra la cuenta SaaS del tenant (paga, cambia plan, billing).
 * Distinto del `Usuario` del schema tenant que opera el negocio en el producto.
 */
model TenantUserAdmin {
  id           String          @id @default(cuid())
  tenantId     String          @map("tenant_id")
  email        String
  passwordHash String          @map("password_hash")
  name         String
  phone        String?
  roleAdmin    AdminTenantRole @default(owner) @map("role_admin")
  isPrimary    Boolean         @default(false) @map("is_primary")
  mfaEnabled   Boolean         @default(false) @map("mfa_enabled")
  lastLoginAt  DateTime?       @map("last_login_at")
  archivedAt   DateTime?       @map("archived_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([email])
  @@map("tenant_users_admin")
}

model TenantSettingsMaster {
  id                      String   @id @default(cuid())
  tenantId                String   @unique @map("tenant_id")
  billingEmail            String   @map("billing_email")
  billingAddress          Json?    @map("billing_address")
  taxData                 Json?    @map("tax_data")
  notificationPreferences Json?    @map("notification_preferences")
  autoChargeEnabled       Boolean  @default(true) @map("auto_charge_enabled")
  dunningPolicy           String   @default("default") @map("dunning_policy")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings_master")
}

enum TicketStatus {
  open
  pending
  resolved
  closed

  @@map("ticket_status")
}

enum TicketPriority {
  low
  normal
  high
  urgent

  @@map("ticket_priority")
}

enum TicketCategory {
  billing
  technical
  onboarding
  account
  other

  @@map("ticket_category")
}

enum TicketAuthorType {
  admin
  tenant
  system

  @@map("ticket_author_type")
}

model SupportTicket {
  id             String         @id @default(cuid())
  tenantId       String?        @map("tenant_id")
  subject        String
  status         TicketStatus   @default(open)
  priority       TicketPriority @default(normal)
  category       TicketCategory @default(other)
  assignedToId   String?        @map("assigned_to_id")
  createdByEmail String         @map("created_by_email")
  lastMessageAt  DateTime       @default(now()) @map("last_message_at")
  closedAt       DateTime?      @map("closed_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  tenant     Tenant?                @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  assignedTo AdminUser?             @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  messages   SupportTicketMessage[]

  @@index([status])
  @@index([tenantId])
  @@map("support_ticket")
}

model SupportTicketMessage {
  id           String           @id @default(cuid())
  ticketId     String           @map("ticket_id")
  authorType   TicketAuthorType @map("author_type")
  authorEmail  String           @map("author_email")
  body         String
  internalNote Boolean          @default(false) @map("internal_note")
  createdAt    DateTime         @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_ticket_message")
}
