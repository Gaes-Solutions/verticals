# Master DB (Postgres 16, schema public)
DATABASE_URL_MASTER="postgresql://gaespos:devsecret@localhost:5432/gaespos_master?schema=public"

# Tenant DB connection (mismo Postgres, schema variable por tenant)
# El cliente Prisma de tenant aplica `SET search_path TO tenant_xxx` por request.
DATABASE_URL_TENANT="postgresql://gaespos:devsecret@localhost:5432/gaespos_master"

# Redis (BullMQ + cache + sessions)
REDIS_URL="redis://localhost:6380"

# Node env
NODE_ENV="development"
LOG_LEVEL="info"

# API server
HOST="0.0.0.0"
PORT="3000"
CORS_ORIGIN="http://localhost:5173"
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW="1 minute"

# Auth — generar con: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Mínimo 32 caracteres cada uno. NUNCA reusar entre dev/staging/prod.
JWT_SECRET="dev-only-jwt-secret-replace-with-48-bytes-base64url-en-prod"
JWT_REFRESH_SECRET="dev-only-refresh-secret-replace-with-48-bytes-base64url-en-prod"
COOKIE_SECRET="dev-only-cookie-secret-replace-with-48-bytes-base64url-en-prod"
ACCESS_TOKEN_TTL_MIN="15"
REFRESH_TOKEN_TTL_DAYS="30"

# Seed (opcional — overrides admin default)
# SEED_ADMIN_EMAIL="admin@gaessoft.local"
# SEED_ADMIN_PASSWORD="ChangeMe!2026"

# Pagos — proveedores reales (en dev se usa el mock; deja vacío para mock)
# Conekta (tarjeta + MSI + OXXO/SPEI MX). La PRIVADA va aquí (backend); la
# PÚBLICA va en apps/web-tienda (.env.local → NEXT_PUBLIC_CONEKTA_PUBLIC_KEY).
# CONEKTA_API_KEY="key_test_xxxxxxxx"
# CONEKTA_WEBHOOK_SECRET="conekta_wh_secret_xxxx"
# STRIPE_API_KEY="sk_test_xxxxxxxx"
# STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxx"
