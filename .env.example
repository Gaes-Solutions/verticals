# Master DB (Postgres 16, schema public)
DATABASE_URL_MASTER="postgresql://gaespos:devsecret@localhost:5432/gaespos_master?schema=public"

# Tenant DB connection (mismo Postgres, schema variable por tenant)
# El cliente Prisma de tenant aplica `SET search_path TO tenant_xxx` por request.
DATABASE_URL_TENANT="postgresql://gaespos:devsecret@localhost:5432/gaespos_master"

# Redis (BullMQ + cache + sessions)
REDIS_URL="redis://localhost:6380"

# Node env
NODE_ENV="development"
LOG_LEVEL="info"

# API server
HOST="0.0.0.0"
PORT="3000"
CORS_ORIGIN="http://localhost:5173"
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW="1 minute"

# Automatizaciones (flows): scheduler en proceso que dispara los triggers de
# marketing por tenant. Default apagado; en prod poner "true".
FLOWS_SCHEDULER_ENABLED="false"
FLOWS_RUN_INTERVAL_MIN="360"

# Recordatorios de citas (anti-no-show): scheduler que avisa al tutor antes de
# su cita con un link de confirmación. Default apagado; en prod poner "true".
# PUBLIC_BASE_URL = dominio público del API (base del link de confirmación).
RECORDATORIOS_SCHEDULER_ENABLED="false"
RECORDATORIOS_RUN_INTERVAL_MIN="60"
PUBLIC_BASE_URL="http://localhost:3000"

# Auth — generar con: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Mínimo 32 caracteres cada uno. NUNCA reusar entre dev/staging/prod.
JWT_SECRET="dev-only-jwt-secret-replace-with-48-bytes-base64url-en-prod"
JWT_REFRESH_SECRET="dev-only-refresh-secret-replace-with-48-bytes-base64url-en-prod"
COOKIE_SECRET="dev-only-cookie-secret-replace-with-48-bytes-base64url-en-prod"
ACCESS_TOKEN_TTL_MIN="15"
REFRESH_TOKEN_TTL_DAYS="30"

# Seed (opcional — overrides admin default)
# SEED_ADMIN_EMAIL="admin@gaessoft.local"
# SEED_ADMIN_PASSWORD="ChangeMe!2026"

# Pagos — proveedores reales (en dev se usa el mock; deja vacío para mock)
# Conekta (tarjeta + MSI + OXXO/SPEI MX). La PRIVADA va aquí (backend); la
# PÚBLICA va en apps/web-tienda (.env.local → NEXT_PUBLIC_CONEKTA_PUBLIC_KEY).
# CONEKTA_API_KEY="key_test_xxxxxxxx"
# CONEKTA_WEBHOOK_SECRET="conekta_wh_secret_xxxx"
# STRIPE_API_KEY="sk_test_xxxxxxxx"
# STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxx"

# Paqueterías — agregadores multi-paquetería MX (en dev se usa el mock; deja vacío).
# El tenant elige el proveedor en Admin → Tienda → Envíos automáticos.
# SKYDROPX_API_KEY="sk_live_xxxxxxxx"
# SKYDROPX_WEBHOOK_SECRET="sky_wh_secret_xxxx"
# ENVIA_API_KEY="xxxxxxxx"
# ENVIA_WEBHOOK_SECRET="envia_wh_secret_xxxx"

# Web Push (PWA) — genera el par con `npx web-push generate-vapid-keys`.
# Sin estas llaves el push queda deshabilitado (no rompe nada).
# VAPID_PUBLIC_KEY="B....."
# VAPID_PRIVATE_KEY="......"
# VAPID_SUBJECT="mailto:soporte@gaessoft.mx"

# Observabilidad — Sentry (errores backend). Sin DSN queda apagado (no-op).
# SENTRY_DSN="https://xxxx@oXXXX.ingest.sentry.io/XXXX"
# SENTRY_TRACES_SAMPLE_RATE="0.1"
# SENTRY_RELEASE="gaespos@<git-sha>"

# Telemedicina (Daily.co) — sin llave usa mock. Sala de video para citas telemedicina.
DAILY_API_KEY=""

# Storefront multi-tienda — apex de la plataforma para subdominios de tienda.
# Con "gaessoft.shop", la tienda del tenant queda en <subdominio>.gaessoft.shop y
# su host se registra en master.tienda_dominio al guardar la config (resolve del
# middleware de web-tienda). Sin esta variable NO se registran subdominios y la
# tienda solo funciona con el tenant fallback TIENDA_TENANT_SLUG.
# Si se define/cambia DESPUÉS de que existan tiendas configuradas, correr:
#   pnpm --filter @gaespos/api backfill:tienda-dominios
# STOREFRONT_APEX="gaessoft.shop"
# STOREFRONT_CNAME_TARGET="stores.gaessoft.mx"
