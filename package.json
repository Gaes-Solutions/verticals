{
  "name": "gaespos",
  "version": "0.0.0",
  "private": true,
  "description": "GaesSoft POS — SaaS multi-tenant POS para México (Retail, Abarrotes, Salud Vet/Humana)",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "husky",
    "dev:db": "docker compose up -d",
    "dev:db:down": "docker compose down",
    "dev:db:reset": "docker compose down -v",
    "dev:db:logs": "docker compose logs -f",
    "db:generate": "dotenv -e .env -- pnpm --filter @gaespos/db prisma:generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @gaespos/db prisma:migrate",
    "db:migrate:deploy": "dotenv -e .env -- pnpm --filter @gaespos/db prisma:migrate:deploy",
    "db:studio": "dotenv -e .env -- pnpm --filter @gaespos/db prisma:studio",
    "db:reset": "dotenv -e .env -- pnpm --filter @gaespos/db prisma:reset",
    "db:seed": "dotenv -e .env -- pnpm --filter @gaespos/db seed:master",
    "gaes-migrate": "dotenv -e .env -- pnpm --filter @gaespos/db migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/node": "^22.10.2",
    "dotenv-cli": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc}": ["biome check --write --no-errors-on-unmatched"]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
